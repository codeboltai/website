---
const { brand = {}, columns = [], bottom = {}, logo = {} } = Astro.props;
---
<footer class="w-full bg-background border-t border-border text-sm dark:border-neutral-900">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 py-20 border-b border-border gap-12 lg:gap-0 dark:border-neutral-900">
      <div class="lg:col-span-4 flex flex-col justify-between h-full pr-12">
        <div>
          <a href="/" class="flex items-center gap-2 mb-8 group">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-foreground">
              <path d="M12 2L3 7V17L12 22L21 17V7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none" />
              <path d="M12 2V12" stroke="currentColor" stroke-width="1.5" />
              <path d="M3 7L12 12" stroke="currentColor" stroke-width="1.5" />
              <path d="M21 7L12 12" stroke="currentColor" stroke-width="1.5" />
              <path d="M12 12V22" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <span class="font-bold text-foreground group-hover:text-primary transition-colors">
              {logo.text}<span class="text-primary">{logo.highlight}</span>
            </span>
          </a>
          <p class="text-muted-foreground leading-relaxed max-w-sm">
            {brand.tagline}
          </p>
        </div>
      </div>

      <div class="lg:col-span-8 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 lg:border-l border-border lg:pl-16 dark:border-neutral-900">
        {columns.map((col) => (
          <div class="flex flex-col gap-6">
            <h3 class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground">
              {col.heading}
            </h3>
            <ul class="flex flex-col gap-4">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="block text-sm transition-colors duration-200 text-muted-foreground hover:text-foreground"
                    {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 py-10">
      <div class="text-muted-foreground text-xs font-medium">
        © {bottom.copyright}
      </div>
      <div class="flex items-center gap-6">
        {bottom.links && bottom.links.map((link) => (
          <a href={link.href} class="text-xs text-muted-foreground hover:text-foreground transition-colors">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
