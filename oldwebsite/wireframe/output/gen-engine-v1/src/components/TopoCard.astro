---
import { cn } from '../lib/utils';

const { index, tag, title, description, tagVariant = 'default', showConnector = true, className } = Astro.props;

const tagVariants = {
  default: 'bg-muted dark:bg-zinc-800 text-muted-foreground dark:text-zinc-400',
  primary: 'bg-primary/10 text-primary dark:bg-cyan-500/10 dark:text-cyan-400',
  emerald: 'bg-emerald-500/10 text-emerald-500',
  amber: 'bg-amber-500/10 text-amber-500',
  indigo: 'bg-indigo-500/10 text-indigo-400',
};
---

<div class={cn('group relative', className)}>
  {showConnector && (
    <div>
      <div class="absolute -top-6 left-0 w-full h-px bg-border dark:bg-zinc-800 hidden md:block" />
      <div class="absolute -top-6 left-0 w-px h-6 bg-border dark:bg-zinc-800 hidden md:block" />
    </div>
  )}

  <div class="border border-border dark:border-zinc-800 p-6 h-full bg-card dark:bg-[#050505] group-hover:border-muted-foreground/60 dark:group-hover:border-zinc-700 transition-colors duration-500">
    <div class="flex justify-between items-start mb-4">
      <span class="font-mono text-[10px] text-muted-foreground/60 dark:text-zinc-600">
        {index}
      </span>
      <span class={cn('font-mono text-[10px] px-2 py-0.5 rounded-sm', tagVariants[tagVariant] ?? tagVariants.default)}>
        {tag}
      </span>
    </div>

    <h4 class="text-foreground dark:text-white font-medium mb-3">
      {title}
    </h4>

    <p class="text-xs text-muted-foreground dark:text-zinc-400 leading-relaxed">
      {description}
    </p>
  </div>
</div>
