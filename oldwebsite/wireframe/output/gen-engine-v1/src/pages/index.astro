---
// Auto-generated from site.yaml — edit site.yaml and regenerate
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, navigation } from '../data/site-data.js';
import Hero from '../components/Hero.astro';
import HighlightBanner from '../components/HighlightBanner.astro';
import StatGrid from '../components/StatGrid.astro';
import CenteredText from '../components/CenteredText.astro';
import CardGrid from '../components/CardGrid.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import ComparisonColumns from '../components/ComparisonColumns.astro';
import IconGrid from '../components/IconGrid.astro';
import PersonaGrid from '../components/PersonaGrid.astro';
import CtaBlock from '../components/CtaBlock.astro';
---
<BaseLayout title="Codebolt — The Most Powerful Agent Engine Ever Built" navbarVariant="transparent" site={site} navigation={navigation}>
  <Hero
    heading="The Most Powerful Agent Engine Ever Built"
    subheading="One engine that can be a coding CLI, an IDE, a personal agent, a large-scale orchestration system, or the infrastructure for an autonomous company. Start simple. Scale without limits."
    buttons={[{"label":"Get Started","href":"/pricing","variant":"primary"},{"label":"See the Engine","href":"/engine","variant":"secondary"}]}
  />
  <HighlightBanner
    tone="accent"
    content={`Start like Claude Code. Scale like nothing else exists. <span class="text-primary">One engine. Every scale.</span>
`}
  />
  <StatGrid
    tone="muted"
    columns={4}
    stats={[{"label":"SDK Modules","value":"63+"},{"label":"LLM Providers","value":"17+"},{"label":"Communication Channels","value":"3"},{"label":"Environments","value":"Unlimited"}]}
  />
  <CenteredText
    variant="thesis"
    text="Claude Code is an agent. OpenClaw is an assistant. Cursor is an editor. Codebolt is the engine that can become any of them — and scale beyond all of them."
  />
  <CardGrid
    heading="One Engine. Every Format."
    columns={2}
    cards={[{"title":"Codebolt as CLI","body":"A coding agent in your terminal. Like Claude Code, but with a 63-module SDK, any LLM provider, and the ability to spawn environments, run plugins, and scale to multi-agent when you're ready. Start here.","visual":"$ codebolt --agent my-agent\n$ codebolt --prompt \"refactor auth\"\n$ codebolt --server (headless)\n"},{"title":"Codebolt as IDE","body":"A full desktop IDE with Monaco editor, integrated terminal, file explorer, and agent workspace. Like Cursor, but you control the agents. Write custom agents. Install plugins. Coordinate multiple agents on the same codebase.","visual":"Electron + Monaco Editor\nAgent panel + Terminal\nPlugin system + TUI sidebar\n"},{"title":"Codebolt as Personal Agent","body":"A 24/7 agent with persistent memory, plugin integrations, and proactive capabilities. Like OpenClaw, but running on a platform with 63+ SDK modules, multi-environment support, and a plugin system that connects to everything.","visual":"Persistent memory (3-tier)\nPlugin integrations\nProactive scheduling\nAlways running, always learning\n"},{"title":"Codebolt as Orchestration Engine","body":"Run 50-100+ agents across Docker, cloud, and hierarchical environments. Stigmergy-based coordination, agent deliberation councils, automatic review and merge, drift tracking. The infrastructure for autonomous companies.","visual":"50+ agents → coordinated\nMulti-environment scaling\nAuto review & merge\nDrift tracking + guardrails\n"}]}
  />
  <QuoteBlock
    variant="muted"
    align="center"
    quote="The same engine that powers a simple coding CLI also powers a 100-agent autonomous company. Everything you build — agents, plugins, memory, workflows — carries forward as you scale."
    attribution="Codebolt Engineering"
  />
  <CenteredText
    variant="identity"
    text="About the Engine"
  />
  <FeatureBlock
    heading="Scales from one agent to an autonomous company"
    body="Codebolt is an advanced agent execution engine that scales from running a single coding agent to orchestrating hundreds of agents across multiple systems. It is more extensible than any other system in the market — giving you complete control over agents and their execution. It incorporates stigmergy-based coordination, narrative management, drift tracking, and swarm intelligence to handle 100+ agents running across multiple environments simultaneously."
    diagram="1 agent ──→ CLI / coding tool
          ↓
5 agents ──→ IDE / team workspace
          ↓
20 agents ──→ personal agent / workflows
          ↓
100+ agents ──→ autonomous company
"
  />
  <ComparisonColumns
    problem={{"heading":"Other tools","items":["Claude Code — great CLI agent, but you can't customize the loop or scale beyond one agent","Cursor — great IDE, but agents are fixed and there's no plugin system","OpenClaw — great personal agent, but no multi-agent coordination or enterprise scaling","LangChain/CrewAI — agent frameworks, but no execution environment","Each tool is one thing. If you outgrow it, you start over."]}}
    solution={{"heading":"Codebolt","items":["One engine that starts as a CLI and scales to orchestrate 100+ agents","Full control over the agentic loop — write agents in code, not prompts","Plugin system with 3 communication channels — plugins run inside the platform","Multi-environment scaling across local, Docker, cloud, and hierarchical setups","Everything carries forward. Agents, plugins, memory, workflows — nothing gets rebuilt."]}}
  />
  <IconGrid
    tone="muted"
    kicker="ENGINE CAPABILITIES"
    title="What makes the engine powerful
63+ modules. 3 channels. Unlimited scale.
"
    description="Every capability is available at every scale — from CLI to autonomous company."
    columns={3}
    features={[{"icon":"layers","title":"63+ SDK Modules","description":"Filesystem, git, browser, terminal, LLM, vector DB, memory, knowledge graph, code search, and more."},{"icon":"cpu","title":"3 Communication Channels","description":"Agent channel (codeboltjs), Plugin channel (WS + HTTP), Client channel (UI/TUI/Web). Each serves a purpose."},{"icon":"git-branch","title":"Multi-Environment","description":"Local, Docker, cloud, hierarchical. State transfer via git bundles. Heartbeat monitoring. Full lifecycle management."},{"icon":"shield","title":"Guardrails & Governance","description":"Policy engine with LLM risk classification. Per-agent, per-environment, per-phase scoping. Allow, deny, or escalate."},{"icon":"code","title":"17+ LLM Providers","description":"OpenAI, Anthropic, Google, Mistral, Groq, DeepSeek, Ollama, LM Studio. Per-agent, per-task model selection."},{"icon":"zap","title":"Built-in Review & Merge","description":"Agents review each other's work. Conflict detection. Pheromone coordination. No GitHub PR bottleneck."}]}
  />
  <CardGrid
    heading="The Progression"
    cards={[{"title":"Day 1 — Coding CLI","body":"Install Codebolt. Run it in your terminal. Use a built-in agent or bring your own. Like Claude Code but with any model, full SDK access, and room to grow.","visual":"$ npm i -g codebolt\n$ codebolt\n→ Start coding with AI\n"},{"title":"Week 2 — Custom Agents","body":"Write your first agent in 10 lines of JavaScript. Full access to 63+ SDK modules. Your logic, your tools, your rules. No other tool gives you this for free.","visual":"import { codebolt } from 'codeboltjs';\ncodebolt.onMessage(async (msg) => {\n  // your agent, your logic\n});\n"},{"title":"Month 2 — IDE + Plugins","body":"Switch to the desktop IDE. Install plugins that connect to GitHub, Jira, Slack. Build custom plugins. Multiple agents coordinating on your codebase.","visual":"IDE + Monaco Editor\nPlugins: CI/CD, review, deploy\n3+ agents coordinating\n"},{"title":"Month 6 — Personal Agent","body":"Your agent runs 24/7. Persistent memory. Proactive scheduling. Plugin integrations handle email, calendar, monitoring. Like OpenClaw but on a platform that scales.","visual":"Always-on agent\nMemory persists across sessions\nPlugins handle the world\n"},{"title":"Year 1 — Orchestration Engine","body":"50+ agents across Docker and cloud environments. Stigmergy coordination. Deliberation councils. Automatic review and merge. Drift tracking. Your infrastructure, not your bottleneck.","visual":"50+ agents → 5 environments\nAuto review & merge\nDrift tracking + guardrails\n"},{"title":"Year 2 — Autonomous Company","body":"Applications run as plugins inside the engine. Each handles a domain — engineering, testing, deployment, monitoring. Agents coordinate across all of them. You direct the vision.","visual":"Plugin: Engineering\nPlugin: QA & Testing\nPlugin: Deployment\nPlugin: Monitoring\nAll autonomous. You direct.\n"}]}
  />
  <PersonaGrid
    personas={[{"label":"Solo Developers","body":"Start with the CLI. Use one agent. Write custom agents when you're ready. More power than any free coding tool — because you control the agent, not just the prompt."},{"label":"Teams Scaling AI","body":"When two agents edit the same repo, the platform resolves conflicts. Coordination, drift tracking, and multi-environment management — so you focus on the product."},{"label":"AI Startup Founders","body":"Build your company on the engine. Applications run as plugins — no separate agent instances needed. Scale across environments as you grow."},{"label":"Enterprise & Production","body":"Governance, audit trails, deterministic replay, and guardrails. Every agent decision is traceable. Every change is attributable. Deploy agents in production with confidence."},{"label":"Platform Engineers","body":"Run headless in CI/CD. Spawn Docker environments. Transfer state between them. Monitor with real-time events. The engine was built for infrastructure people."},{"label":"AI Researchers","body":"Stigmergy-based coordination. Pheromone systems. Narrative versioning. Agent deliberation councils. Research-grounded architecture with published foundations."}]}
  />
  <CtaBlock
    heading="One engine. Start simple. Scale without limits."
    buttons={[{"label":"Get Started","href":"/pricing","variant":"primary"},{"label":"Explore the Engine","href":"/engine","variant":"secondary"}]}
  />
</BaseLayout>
