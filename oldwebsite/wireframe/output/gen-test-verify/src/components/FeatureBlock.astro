---
import { cn } from '../lib/utils';

const { heading, body, diagram, reverse = false } = Astro.props;
---

<section class="py-24 lg:py-32 px-6 lg:px-10 border-b border-border dark:border-zinc-800/60 bg-background dark:bg-[#050505]">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
    
    {/* Text Content */}
    <div class={cn('col-span-1 lg:col-span-5 flex flex-col', reverse && 'lg:order-last')}>
      <h3 class="text-3xl md:text-5xl font-medium text-foreground tracking-tight leading-[1.1] mb-6 dark:text-zinc-100">
        {heading}
      </h3>
      <div class="space-y-4 text-muted-foreground font-light leading-relaxed dark:text-zinc-400">
        <p>{body}</p>
      </div>
    </div>

    {/* Diagram Content */}
    <div class={cn('col-span-1 lg:col-span-7', reverse && 'lg:order-first')}>
      <div class="relative w-full min-h-[400px] flex items-center justify-center bg-card border border-border rounded-sm overflow-hidden dark:bg-[#050505] dark:border-zinc-800/60 p-8">
        {/* Grid background */}
        <div
          class="absolute inset-0 opacity-20 dark:opacity-100 pointer-events-none bg-grid"
        />
        
        {/* Render diagram string as preformatted text */}
        <pre class="relative z-10 text-xs md:text-sm leading-relaxed font-mono text-muted-foreground whitespace-pre overflow-auto max-w-full">
          {diagram}
        </pre>
      </div>
    </div>

  </div>
</section>
