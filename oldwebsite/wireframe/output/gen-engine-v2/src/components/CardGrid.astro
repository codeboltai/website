---
import { cn } from '../lib/utils';

const { heading, cards = [], columns = 3 } = Astro.props;

const gridCols = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
};
---

<section class="py-24 px-6 bg-background dark:bg-[#050505] text-foreground font-sans antialiased border-b border-border dark:border-zinc-900">
  <div class="max-w-6xl mx-auto">
    {/* Section Header */}
    <div class="mb-20 max-w-3xl">
      <h2 class="text-4xl md:text-6xl font-medium tracking-tighter text-foreground dark:text-white mb-8 leading-[0.95]">
        {heading}
      </h2>
    </div>

    {/* Feature Cards Grid */}
    <div class={cn('grid gap-6', gridCols[columns] || gridCols[3])}>
      {cards.map((card, idx) => {
        const Tag = card.href ? 'a' : 'div';
        const linkProps = card.href ? { href: card.href } : {};
        return (
          <Tag {...linkProps} class={cn(
            "group relative border border-border dark:border-zinc-800 p-6 transition-all duration-500 hover:border-muted-foreground/50 dark:hover:border-zinc-700 bg-card dark:bg-card/50",
            card.href && "block no-underline cursor-pointer"
          )}>
            {/* Corner brackets */}
            <div class="absolute -top-px -left-px w-3 h-3 border-t border-l border-muted-foreground/40 dark:border-zinc-600" />
            <div class="absolute -top-px -right-px w-3 h-3 border-t border-r border-muted-foreground/40 dark:border-zinc-600" />
            <div class="absolute -bottom-px -left-px w-3 h-3 border-b border-l border-muted-foreground/40 dark:border-zinc-600" />
            <div class="absolute -bottom-px -right-px w-3 h-3 border-b border-r border-muted-foreground/40 dark:border-zinc-600" />

            {/* Diagram area (if visual exists) */}
            {card.visual && (
              <div class="aspect-[4/3] w-full bg-muted/20 dark:bg-[#080808] border border-border dark:border-zinc-800 flex items-center justify-center mb-6 overflow-hidden p-4">
                <pre class="text-[10px] leading-tight font-mono text-muted-foreground whitespace-pre overflow-auto max-w-full max-h-full">
                  {card.visual}
                </pre>
              </div>
            )}

            {/* Title */}
            <h3 class="text-lg font-medium text-foreground dark:text-white mb-3 tracking-tight group-hover:text-primary dark:group-hover:text-cyan-400 transition-colors">
              {card.title}
            </h3>

            {/* Description */}
            <p class="text-sm text-muted-foreground dark:text-zinc-400 font-light leading-relaxed">
              {card.body}
            </p>

            {/* Link arrow indicator */}
            {card.href && (
              <div class="mt-4 text-xs font-mono text-primary/60 dark:text-cyan-500/60 group-hover:text-primary dark:group-hover:text-cyan-400 transition-colors">
                Learn more &rarr;
              </div>
            )}
          </Tag>
        );
      })}
    </div>
  </div>
</section>
