---
import { cn } from '../lib/utils';

const { label, value = 0, showMarker = false, variant = 'default', className } = Astro.props;

const barColors = {
  default: 'bg-muted',
  primary: 'bg-primary',
  emerald: 'bg-emerald-500',
  amber: 'bg-amber-500',
  red: 'bg-red-500',
};

const pct = Math.max(0, Math.min(100, Number(value) || 0));
---

<div class={cn('w-full', className)}>
  <div class="flex items-center justify-between mb-2">
    <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground dark:text-zinc-500">
      {label}
    </span>
    <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground dark:text-zinc-500">
      {pct}%
    </span>
  </div>
  <div class="relative h-2 w-full bg-muted/30 dark:bg-zinc-900/30 border border-border dark:border-zinc-800 overflow-hidden">
    <div class={cn('h-full', barColors[variant] ?? barColors.default)} style={`width: ${pct}%`} />
    {showMarker && (
      <div class="absolute top-1/2 -translate-y-1/2 w-0.5 h-4 bg-foreground/50" style={`left: ${pct}%`} />
    )}
  </div>
</div>
