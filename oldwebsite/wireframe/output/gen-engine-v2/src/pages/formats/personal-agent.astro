---
// Auto-generated from site.yaml — edit site.yaml and regenerate
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, navigation } from '../../data/site-data.js';
import PageHeader from '../../components/PageHeader.astro';
import CenteredText from '../../components/CenteredText.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import CtaBlock from '../../components/CtaBlock.astro';
---
<BaseLayout title="Codebolt Personal Agent — 24/7 AI That Grows With You" navbarVariant="solid" site={site} navigation={navigation}>
  <PageHeader
    title="Codebolt as Personal Agent"
    subtitle="A 24/7 agent with persistent memory, plugin integrations, and proactive capabilities. Like OpenClaw — on a scalable engine."
  />
  <CenteredText
    variant="thesis"
    text="Run the engine always-on. Three-tier persistent memory means your agent remembers everything — across sessions, across tasks, across days. Plugins connect it to email, calendar, monitoring, messaging apps, and anything with an API. The engine grows with you."
  />
  <FeatureBlock
    heading="Persistent memory that compounds"
    body="Episodic memory for time-based recall of past interactions. Persistent memory with chunking, embedding, and retrieval pipelines. The Context Assembly Engine assembles optimal context using rules, pipelines, and token budgets. Your agent doesn't just remember — it knows what to remember and when to use it. The longer it runs, the smarter it gets."
    diagram="┌─────────────────────────┐
│ Context Assembly Engine │
├─────────────────────────┤
│ Episodic → time-based   │
│ Persistent → structured │
│ Rules → what to include │
│ Token budget → limits   │
├─────────────────────────┤
│ Compounds over time     │
└─────────────────────────┘
"
  />
  <FeatureBlock
    heading="Plugins connect it to your world"
    body="Plugins connect through three communication channels — WebSocket, multiplexed events, and HTTP REST. Build or install plugins for email, calendar, GitHub, Jira, Slack, monitoring, home automation, and anything with an API. Plugins run inside the engine — they don't need separate agent instances."
    reverse={true}
    diagram="Engine
  │
┌─┼─────────────────────┐
│ Plugin: Email         │
│ Plugin: Calendar      │
│ Plugin: GitHub        │
│ Plugin: Monitoring    │
│ Plugin: Custom        │
└───────────────────────┘
All running inside the engine
"
  />
  <FeatureBlock
    heading="What OpenClaw and Hermes can't do"
    body="OpenClaw is a great personal agent. Hermes has an impressive learning loop. But neither can scale to multi-agent orchestration, multi-environment coordination, or autonomous company infrastructure. Codebolt can. Start as a personal agent — scale to running your entire business when you're ready. Same engine, same memory, same plugins."
    diagram="OpenClaw / Hermes:
✓ Personal agent
✓ Persistent memory
✓ Skills/plugins
✗ Multi-agent coordination
✗ Multi-environment
✗ Enterprise governance

Codebolt Personal Agent:
✓ All of the above
+ Scales to orchestration
+ Same engine as IDE/CLI
"
  />
  <CtaBlock
    heading="Your personal agent. On an engine that scales."
    buttons={[{"label":"Get Started","href":"/pricing","variant":"primary"},{"label":"See All Formats","href":"/formats","variant":"secondary"}]}
  />
</BaseLayout>
