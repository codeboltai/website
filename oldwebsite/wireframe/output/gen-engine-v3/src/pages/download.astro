---
// Auto-generated from site.yaml — edit site.yaml and regenerate
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, navigation } from '../data/site-data.js';
import PageHeader from '../components/PageHeader.astro';
import CardGrid from '../components/CardGrid.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import CtaBlock from '../components/CtaBlock.astro';
---
<BaseLayout title="Download Codebolt" navbarVariant="solid" site={site} navigation={navigation}>
  <PageHeader
    title="Download Codebolt"
    subtitle="Pick a surface. Same engine inside all of them."
  />
  <CardGrid
    heading="Codebolt Editor — Desktop"
    columns={3}
    cards={[{"title":"macOS","body":"Apple Silicon and Intel. Universal binary. Requires macOS 12 or later.","href":"#download-macos","visual":"codebolt.dmg\n├─ Apple Silicon\n└─ Intel x64\n"},{"title":"Windows","body":"x64 installer. Windows 10 and later. Auto-updates included.","href":"#download-windows","visual":"codebolt-setup.exe\n└─ Windows x64\n"},{"title":"Linux","body":".deb, .rpm, and AppImage. x64 and arm64. Includes desktop integration.","href":"#download-linux","visual":"codebolt.deb\ncodebolt.rpm\ncodebolt.AppImage\n"}]}
  />
  <FeatureBlock
    heading="Codebolt CLI — Terminal"
    body="Install globally with npm and run the engine in your terminal. Headless server mode for CI/CD. Works inside the Editor or standalone — same SDK, same plugins."
    diagram={`\$ npm i -g codebolt
\$ codebolt                    # interactive TUI
\$ codebolt --prompt "..."     # one-shot
\$ codebolt --server --port 3100
`}
    reverse={false}
  />
  <FeatureBlock
    heading="Codebolt Cloud — Browser"
    body="No install. Open a workspace in your browser, drop in agents and plugins, and run them on managed sandboxes. Same engine as the desktop Editor — just running on our infrastructure."
    diagram="→ cloud.codebolt.ai
├─ Browser portal
├─ Managed sandboxes
└─ Shared workspaces
"
    reverse={true}
  />
  <FeatureBlock
    heading="Codebolt SDK — Embed"
    body="Building your own product on top of the engine? The SDK lets you embed the runtime in your app or self-host it on your own infrastructure. Three SDKs (Agent, Plugin, Client) cover every layer."
    diagram="# Self-host the engine
$ docker run codebolt/engine:latest

# Or install the SDK package
$ npm i codeboltjs
"
  />
  <CtaBlock
    heading="Need help getting started?"
    buttons={[{"label":"Read the Docs","href":"https://docs.codebolt.ai","variant":"primary","external":true},{"label":"Explore the Engine","href":"/engine","variant":"secondary"}]}
  />
</BaseLayout>
