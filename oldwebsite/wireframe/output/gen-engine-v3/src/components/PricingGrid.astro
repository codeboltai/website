---
import { cn } from '../lib/utils';

const { cards = [], tabs = [] } = Astro.props;
const pricingTabs = tabs.length ? tabs : [{ label: '', cards }];
const hasWaitlist = pricingTabs.some((tab) =>
  (tab.cards || []).some((plan) => plan.cta?.waitlist)
);

function gridClass(count) {
  if (count <= 2) return 'grid-cols-1 lg:grid-cols-2';
  if (count === 3) return 'grid-cols-1 lg:grid-cols-3';
  return 'grid-cols-1 md:grid-cols-2 xl:grid-cols-4';
}
---

<section class="bg-card text-foreground py-20 px-6 border-y border-border">
  <div class="max-w-[1200px] mx-auto">
    {pricingTabs.length > 1 && (
      <div class="mb-8 flex justify-center">
        <div class="inline-flex rounded-none border border-border bg-muted/20 p-1" data-pricing-tabs>
          {pricingTabs.map((tab, idx) => (
            <button
              type="button"
              data-pricing-tab={idx}
              aria-selected={idx === 0 ? 'true' : 'false'}
              class={cn(
                'px-5 py-2 text-xs font-sans font-semibold uppercase tracking-wider transition-colors',
                idx === 0
                  ? 'bg-foreground text-background'
                  : 'text-muted-foreground hover:text-foreground'
              )}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>
    )}

    {pricingTabs.map((tab, tabIdx) => {
      const tabCards = tab.cards || [];
      return (
        <div data-pricing-panel={tabIdx} class={cn(tabIdx !== 0 && 'hidden')}>
          <div class={cn('grid border border-border overflow-hidden', gridClass(tabCards.length))}>
            {tabCards.map((plan, idx) => (
              <div class={cn(
                'relative min-w-0 flex flex-col border-r border-b lg:border-b-0 border-border p-6 lg:p-8 transition-colors duration-300',
                plan.featured ? 'bg-primary/5 border-primary/30' : 'bg-card/50',
                idx === tabCards.length - 1 && 'border-r-0'
              )}>
                {/* Label badge */}
                {plan.badge && (
                  <div class={cn(
                    'absolute top-0 right-0 border-l border-b border-border px-3 py-1.5',
                    plan.featured ? 'bg-primary text-primary-foreground' : 'bg-muted text-foreground'
                  )}>
                    <span class="text-[9px] font-sans uppercase tracking-widest font-bold">
                      {plan.badge}
                    </span>
                  </div>
                )}

                {/* Plan info */}
                <div class="mb-10 pr-10">
                  <h3 class="text-xl font-medium text-foreground mb-2">{plan.tier}</h3>
                  <p class="text-sm text-muted-foreground font-sans min-h-[48px] leading-relaxed max-w-xs">
                    {plan.for}
                  </p>
                </div>

                {/* Price */}
                <div class="mb-8">
                  <div class="flex flex-wrap items-baseline gap-x-1 gap-y-1">
                    <span class="text-4xl lg:text-5xl font-light text-foreground tracking-tighter break-words">
                      {plan.price}
                    </span>
                    {plan.price_sub && (
                      <span class="text-lg text-muted-foreground font-light">{plan.price_sub}</span>
                    )}
                  </div>
                </div>

                {plan.options && (
                  <div class="mb-8 grid gap-2">
                    {plan.options.map((option) => (
                      <div class="border border-border bg-muted/20 px-4 py-3">
                        <div class="flex items-baseline justify-between gap-3">
                          <span class="text-sm font-semibold text-foreground">{option.label}</span>
                          <span class="text-sm font-mono text-primary">{option.price}</span>
                        </div>
                        {option.description && (
                          <p class="mt-1 text-xs leading-relaxed text-muted-foreground">{option.description}</p>
                        )}
                      </div>
                    ))}
                  </div>
                )}

                {/* Features */}
                <div class="flex-1 mb-10">
                  <ul class="space-y-3">
                    {(plan.features || []).map((feature) => (
                      <li class="flex items-start gap-3 group/item">
                        <div class="mt-1.5 w-1 h-1 shrink-0 transition-colors bg-primary" />
                        <span class="text-sm text-muted-foreground font-sans leading-relaxed group-hover/item:text-foreground transition-colors">
                          {feature}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>

                {/* CTA */}
                <div class="mt-auto">
                  {plan.cta.waitlist ? (
                    <button
                      type="button"
                      data-waitlist-open
                      data-waitlist-plan={plan.cta.plan || plan.tier}
                      data-waitlist-audience={plan.cta.audience || tab.label || 'unknown'}
                      class={cn(
                        'w-full py-4 text-sm uppercase font-semibold font-sans border transition-all duration-200 flex items-center justify-center',
                        plan.featured
                          ? 'bg-primary text-primary-foreground border-primary hover:bg-cyan-400'
                          : 'bg-foreground text-background border-foreground hover:bg-foreground/90'
                      )}
                    >
                      {plan.cta.label}
                    </button>
                  ) : (
                    <a
                      href={plan.cta.href}
                      class={cn(
                        'w-full py-4 text-sm uppercase font-semibold font-sans border transition-all duration-200 flex items-center justify-center',
                        plan.featured
                          ? 'bg-primary text-primary-foreground border-primary hover:bg-cyan-400'
                          : 'bg-foreground text-background border-foreground hover:bg-foreground/90'
                      )}
                    >
                      {plan.cta.label}
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>

  {hasWaitlist && (
    <div
      class="fixed inset-0 z-50 hidden items-center justify-center bg-background/80 px-4 backdrop-blur-sm"
      data-waitlist-modal
      aria-hidden="true"
    >
      <div class="w-full max-w-xl border border-border bg-card shadow-2xl">
        <div class="flex items-start justify-between gap-6 border-b border-border p-6">
          <div>
            <div class="mb-3 font-mono text-[10px] uppercase tracking-widest text-primary">
              Request Access
            </div>
            <h2 class="text-2xl font-medium tracking-tight text-foreground">
              Join the Codebolt early access list
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Tell us what you want to use Codebolt for and we will follow up.
            </p>
          </div>
          <button
            type="button"
            class="border border-border px-3 py-2 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground"
            data-waitlist-close
            aria-label="Close request access form"
          >
            ESC
          </button>
        </div>

        <form class="grid gap-4 p-6" data-waitlist-form>
          <input type="hidden" name="plan" data-waitlist-plan-input />
          <input type="hidden" name="audience" data-waitlist-audience-input />
          <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

          <div class="grid gap-4 md:grid-cols-2">
            <label class="grid gap-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
              Name
              <input
                name="name"
                required
                class="border border-border bg-background px-3 py-3 text-sm font-normal normal-case tracking-normal text-foreground outline-none focus:border-primary"
                autocomplete="name"
              />
            </label>
            <label class="grid gap-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
              Work email
              <input
                name="email"
                type="email"
                required
                class="border border-border bg-background px-3 py-3 text-sm font-normal normal-case tracking-normal text-foreground outline-none focus:border-primary"
                autocomplete="email"
              />
            </label>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="grid gap-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
              Company
              <input
                name="company"
                class="border border-border bg-background px-3 py-3 text-sm font-normal normal-case tracking-normal text-foreground outline-none focus:border-primary"
                autocomplete="organization"
              />
            </label>
            <label class="grid gap-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
              Role
              <input
                name="role"
                class="border border-border bg-background px-3 py-3 text-sm font-normal normal-case tracking-normal text-foreground outline-none focus:border-primary"
                autocomplete="organization-title"
              />
            </label>
          </div>

          <label class="grid gap-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
            What are you trying to build?
            <textarea
              name="message"
              rows="4"
              class="resize-none border border-border bg-background px-3 py-3 text-sm font-normal normal-case tracking-normal text-foreground outline-none focus:border-primary"
            ></textarea>
          </label>

          <div class="flex flex-col gap-3 border-t border-border pt-5 sm:flex-row sm:items-center sm:justify-between">
            <p class="min-h-5 text-sm text-muted-foreground" data-waitlist-status></p>
            <button
              type="submit"
              class="border border-primary bg-primary px-5 py-3 text-sm font-semibold uppercase tracking-wider text-primary-foreground transition-colors hover:bg-cyan-400"
              data-waitlist-submit
            >
              Submit request
            </button>
          </div>
        </form>
      </div>
    </div>
  )}
</section>

<script>
  document.querySelectorAll('[data-pricing-tabs]').forEach((tabList) => {
    const section = tabList.closest('section');
    const buttons = Array.from(tabList.querySelectorAll('[data-pricing-tab]'));
    const panels = Array.from(section?.querySelectorAll('[data-pricing-panel]') || []);

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const activeIndex = button.getAttribute('data-pricing-tab');

        buttons.forEach((candidate) => {
          const isActive = candidate === button;
          candidate.setAttribute('aria-selected', String(isActive));
          candidate.classList.toggle('bg-foreground', isActive);
          candidate.classList.toggle('text-background', isActive);
          candidate.classList.toggle('text-muted-foreground', !isActive);
          candidate.classList.toggle('hover:text-foreground', !isActive);
        });

        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.getAttribute('data-pricing-panel') !== activeIndex);
        });
      });
    });
  });
</script>

<script>
  (() => {
    const modal = document.querySelector('[data-waitlist-modal]');
    if (!modal) return;

    const form = modal.querySelector('[data-waitlist-form]');
    const status = modal.querySelector('[data-waitlist-status]');
    const submit = modal.querySelector('[data-waitlist-submit]');
    const planInput = modal.querySelector('[data-waitlist-plan-input]');
    const audienceInput = modal.querySelector('[data-waitlist-audience-input]');
    let lastFocused = null;

    const getEndpoint = () => {
      if (window.CODEBOLT_WAITLIST_ENDPOINT) {
        return window.CODEBOLT_WAITLIST_ENDPOINT;
      }

      return 'https://api.codebolt.ai/api/waitlist';
    };

    const setStatus = (message, isError = false) => {
      if (!status) return;
      status.textContent = message;
      status.classList.toggle('text-red-400', isError);
      status.classList.toggle('text-muted-foreground', !isError);
    };

    const openModal = (trigger) => {
      lastFocused = document.activeElement;
      planInput.value = trigger.getAttribute('data-waitlist-plan') || 'unknown';
      audienceInput.value = trigger.getAttribute('data-waitlist-audience') || 'unknown';
      setStatus('');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modal.setAttribute('aria-hidden', 'false');
      modal.querySelector('input[name="name"]')?.focus();
    };

    const closeModal = () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.setAttribute('aria-hidden', 'true');
      form?.reset();
      setStatus('');
      lastFocused?.focus?.();
    };

    document.querySelectorAll('[data-waitlist-open]').forEach((trigger) => {
      trigger.addEventListener('click', () => openModal(trigger));
    });

    modal.querySelectorAll('[data-waitlist-close]').forEach((button) => {
      button.addEventListener('click', closeModal);
    });

    modal.addEventListener('click', (event) => {
      if (event.target === modal) closeModal();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
        closeModal();
      }
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      setStatus('Submitting...');
      submit.disabled = true;

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());
      payload.sourcePath = window.location.pathname;

      try {
        const response = await fetch(getEndpoint(), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => ({}));
        if (!response.ok || result.ok === false) {
          throw new Error(result.error || 'Unable to submit request');
        }

        setStatus('Request received. We will follow up.');
        form.reset();
      } catch (error) {
        setStatus(error instanceof Error ? error.message : 'Unable to submit request', true);
      } finally {
        submit.disabled = false;
      }
    });
  })();
</script>
