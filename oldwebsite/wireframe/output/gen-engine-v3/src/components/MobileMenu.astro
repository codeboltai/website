---
const { links = [] } = Astro.props;
---
<div class="mobile-menu fixed inset-0 top-16 bg-background z-40 overflow-y-auto hidden md:hidden">
  <div class="px-6 py-8 flex flex-col h-full">
    <nav class="flex flex-col">
      {links.map((link) => (
        <>
          <a
            href={link.href}
            class="block text-lg font-medium transition-colors border-b border-border py-4 text-muted-foreground hover:text-foreground"
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}
          </a>
          {link.children && (
            <div class="border-b border-border">
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class="block text-sm transition-colors py-3 pl-6 text-muted-foreground/70 hover:text-foreground"
                  {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </>
      ))}
    </nav>
  </div>
</div>

<style>
  .mobile-menu.open { display: block; }
</style>
