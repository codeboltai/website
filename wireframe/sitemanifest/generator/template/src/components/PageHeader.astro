---
const { title, subtitle } = Astro.props;
---
<section class="pt-32 pb-20 px-6 bg-background dark:bg-[#050505] border-b border-border dark:border-zinc-900">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-5xl md:text-6xl font-medium tracking-tight text-foreground dark:text-white leading-[1.05]">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-6 text-lg text-muted-foreground dark:text-zinc-400 max-w-2xl leading-relaxed">
        {subtitle}
      </p>
    )}
  </div>
</section>
