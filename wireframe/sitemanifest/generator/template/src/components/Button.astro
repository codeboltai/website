---
const { label, href, variant = 'primary', external = false } = Astro.props;

const variants = {
  primary: 'bg-primary text-primary-foreground hover:bg-cyan-400',
  secondary: 'border border-input bg-background hover:bg-accent hover:text-accent-foreground',
  ghost: 'text-muted-foreground hover:text-foreground hover:bg-accent/50',
};
---
<a
  href={href}
  class={`inline-flex items-center justify-center h-12 px-6 rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring ${variants[variant] ?? variants.primary}`}
  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  {label}
</a>
