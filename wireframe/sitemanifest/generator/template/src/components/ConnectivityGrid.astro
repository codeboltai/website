---
interface Item {
  label: string;
  category?: string;
}

interface Props {
  heading?: string;
  description?: string;
  kicker?: string;
  items: Item[];
  columns?: 3 | 4 | 6;
  tone?: 'default' | 'muted';
}

const {
  heading,
  description,
  kicker,
  items = [],
  columns = 4,
  tone = 'default',
} = Astro.props;

const bgClass = tone === 'muted' ? 'bg-muted/10 dark:bg-zinc-900/20' : 'bg-background dark:bg-[#050505]';

const columnStyles: Record<number, string> = {
  3: 'grid-cols-1 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-4',
  6: 'grid-cols-2 md:grid-cols-3 lg:grid-cols-6',
};

const gridClass = columnStyles[columns] || columnStyles[4];
---

<section class={`py-24 px-6 border-b border-border dark:border-zinc-900 ${bgClass}`}>
  <div class="max-w-[1200px] mx-auto">
    {(kicker || heading) && (
      <div class="mb-16">
        {kicker && (
          <div class="flex items-center gap-3 mb-6">
            <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
            <span class="font-mono text-[10px] text-muted-foreground uppercase tracking-widest">{kicker}</span>
          </div>
        )}
        {heading && <h2 class="text-3xl font-medium text-foreground tracking-tight mb-4">{heading}</h2>}
        {description && <p class="text-lg text-muted-foreground font-light max-w-2xl">{description}</p>}
      </div>
    )}

    <div class={`grid gap-4 ${gridClass}`}>
      {items.map((item: Item) => (
        <div class="group relative border border-border dark:border-zinc-800 p-5 bg-card/30 dark:bg-[#050505] hover:border-primary/50 dark:hover:border-cyan-800/50 transition-colors flex items-center gap-3">
          <div class="relative flex h-2 w-2 flex-shrink-0">
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary dark:bg-cyan-500"></span>
          </div>
          <div>
            <span class="text-sm font-medium text-foreground dark:text-white">{item.label}</span>
            {item.category && (
              <span class="block font-mono text-[10px] text-muted-foreground/70 dark:text-zinc-600 uppercase tracking-widest mt-0.5">
                {item.category}
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
