---
const { text } = Astro.props;
---
<section class="py-24 px-6 bg-background dark:bg-[#050505] border-b border-border dark:border-zinc-900">
  <div class="max-w-5xl mx-auto">
    <div class="border border-border dark:border-zinc-800 bg-card/30 p-10 md:p-12">
      <p class="text-lg md:text-xl text-muted-foreground dark:text-zinc-400 font-light leading-relaxed">
        {text}
      </p>
    </div>
  </div>
</section>
