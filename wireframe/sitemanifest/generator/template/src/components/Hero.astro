---
import { cn } from '../lib/utils';

const { heading, subheading, buttons = [], media } = Astro.props;

const primaryBtn = buttons.find(b => b.variant === 'primary') || buttons[0];
const secondaryBtn = buttons.find(b => b.variant === 'secondary') || buttons[1];
const hasMedia = Boolean(media);
---

<section class={cn(
  "relative bg-background text-foreground min-h-[80vh] border-b border-border font-sans antialiased overflow-hidden flex items-center",
  "dark:bg-[#050505] dark:border-neutral-900"
)}>
  <div class="absolute inset-0 bg-grid opacity-20 dark:opacity-10 pointer-events-none"></div>

  <div class="w-full pt-32 pb-16 md:pb-24 px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-medium text-foreground dark:text-white tracking-tight mb-8 leading-[1.1] animate-fade-in-up">
        {heading}
      </h1>

      {subheading && (
        <p class="text-xl text-muted-foreground leading-relaxed max-w-2xl mx-auto mb-12 font-light animate-fade-in-up" style="animation-delay: 0.1s">
          {subheading}
        </p>
      )}

      {(primaryBtn || secondaryBtn) && (
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 animate-fade-in-up" style="animation-delay: 0.2s">
          {primaryBtn && (
            <a href={primaryBtn.href} class={cn(
              "h-12 px-8 rounded-md flex items-center justify-center text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50",
              "bg-primary text-primary-foreground hover:bg-primary/90 shadow-lg shadow-primary/20"
            )}>
              {primaryBtn.label}
              <svg class="ml-2 h-4 w-4" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M 0 6 H 12 M 9 3 L 12 6 L 9 9" />
              </svg>
            </a>
          )}
          {secondaryBtn && (
            <a href={secondaryBtn.href} class={cn(
              "h-12 px-8 rounded-md flex items-center justify-center text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50",
              "border border-input bg-background hover:bg-accent hover:text-accent-foreground"
            )}>
              {secondaryBtn.label}
            </a>
          )}
        </div>
      )}
    </div>

    {hasMedia && (
      <div class="max-w-6xl mx-auto mt-14 md:mt-18 animate-fade-in-up" style="animation-delay: 0.3s">
        <div class="relative overflow-hidden border border-border bg-card/40 shadow-2xl shadow-black/10 dark:border-zinc-800 dark:bg-[#080808]/90 dark:shadow-black/50">
          <div class="flex h-9 items-center gap-2 border-b border-border bg-muted/20 px-4 dark:border-zinc-800 dark:bg-zinc-950/70">
            <span class="h-2.5 w-2.5 rounded-full bg-red-500/70"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/70"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-green-500/70"></span>
            {media.label && (
              <span class="ml-3 truncate font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                {media.label}
              </span>
            )}
          </div>

          <div class="relative aspect-[16/9] bg-background dark:bg-[#030303]">
            {media.src ? (
              <img
                src={media.src}
                alt={media.alt || 'Product demo'}
                class="h-full w-full object-cover"
                loading="eager"
              />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                  <div class="mb-3 font-mono text-xs uppercase tracking-widest text-primary">
                    {media.placeholder || 'Product GIF'}
                  </div>
                  <div class="mx-auto h-2 w-48 overflow-hidden rounded-full bg-muted dark:bg-zinc-900">
                    <div class="h-full w-1/2 bg-primary/70"></div>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    )}
  </div>
</section>
