---
import { cn } from '../lib/utils';

const {
  content,
  tone = 'default',
  padding = 'md',
  borderTop = false,
  borderBottom = true,
  className,
} = Astro.props;

const toneStyles = {
  default: 'bg-background dark:bg-[#050505]',
  accent: 'bg-primary/5 dark:bg-cyan-500/5',
  muted: 'bg-muted/10 dark:bg-zinc-900/20',
};

const paddingStyles = {
  sm: 'py-10',
  md: 'py-12 md:py-14',
  lg: 'py-16 md:py-20',
};
---

<section
  class={cn(
    'px-6',
    toneStyles[tone] ?? toneStyles.default,
    paddingStyles[padding] ?? paddingStyles.md,
    borderTop && 'border-t border-border dark:border-zinc-900',
    borderBottom && 'border-b border-border dark:border-zinc-900',
    className
  )}
>
  <div class="max-w-4xl mx-auto text-center px-0 md:px-8">
    <p class="text-2xl md:text-3xl text-foreground font-light leading-relaxed" set:html={content} />
  </div>
</section>
