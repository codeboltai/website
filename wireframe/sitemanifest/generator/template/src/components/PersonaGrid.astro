---
const { personas = [] } = Astro.props;
---
<section class="py-24 px-6 bg-background dark:bg-[#050505] border-b border-border dark:border-zinc-900">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {personas.map((persona) => (
        <div class="border border-border dark:border-zinc-800 bg-card/30 p-8">
          <div class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground dark:text-zinc-500 mb-4">
            {persona.label}
          </div>
          <p class="text-sm text-muted-foreground dark:text-zinc-400 leading-relaxed">
            {persona.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
