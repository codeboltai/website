---
const { variant = 'solid', links = [], cta = [], logo = {} } = Astro.props;
const ctaList = Array.isArray(cta) ? cta : (cta && cta.label ? [cta] : []);
---
<header class="fixed top-0 left-0 w-full z-50">
  <nav
    class={`navbar ${variant} border-b border-border ${variant === 'transparent' ? 'bg-transparent' : 'bg-background/80 backdrop-blur-xl'} dark:border-neutral-900`}
  >
    <div class="max-w-[1400px] mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 z-50 relative group">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-foreground">
          <path d="M12 2L3 7V17L12 22L21 17V7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none" />
          <path d="M12 2V12" stroke="currentColor" stroke-width="1.5" />
          <path d="M3 7L12 12" stroke="currentColor" stroke-width="1.5" />
          <path d="M21 7L12 12" stroke="currentColor" stroke-width="1.5" />
          <path d="M12 12V22" stroke="currentColor" stroke-width="1.5" />
        </svg>
        <span class="font-medium text-foreground text-sm tracking-tight group-hover:text-primary transition-colors">
          {logo.text}<span class="text-primary">{logo.highlight}</span>
        </span>
      </a>

      <nav class="hidden md:flex absolute left-1/2 -translate-x-1/2">
        <ul class="flex items-center gap-8">
          {links.map((link) => (
            <li class={link.children ? 'relative group' : ''}>
              {link.children ? (
                <>
                  <a
                    href={link.href}
                    class="text-sm transition-colors duration-200 text-muted-foreground hover:text-foreground inline-flex items-center gap-1"
                  >
                    {link.label}
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="mt-px opacity-50 group-hover:opacity-100 transition-opacity">
                      <path d="M2.5 4L5 6.5L7.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                  <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                    <div class="bg-background/95 dark:bg-[#0a0a0a]/95 backdrop-blur-xl border border-border dark:border-zinc-800 shadow-xl min-w-[220px]">
                      {link.children.map((child) => (
                        <a
                          href={child.href}
                          class="block px-4 py-2.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted/30 dark:hover:bg-zinc-800/50 transition-colors border-b border-border/50 dark:border-zinc-800/50 last:border-b-0"
                          {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                        >
                          {child.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </>
              ) : (
                <a
                  href={link.href}
                  class="text-sm transition-colors duration-200 text-muted-foreground hover:text-foreground"
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <div class="hidden md:flex items-center gap-3 z-50">
        {ctaList.map((c) => {
          const isPrimary = c.variant !== 'secondary';
          const cls = isPrimary
            ? "text-sm bg-primary text-primary-foreground px-5 py-2 rounded-full font-medium hover:bg-cyan-400 transition-all duration-300"
            : "text-sm text-foreground border border-border px-5 py-2 rounded-full font-medium hover:border-muted-foreground/60 transition-colors";
          const extra = c.external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
          return <a href={c.href} class={cls} {...extra}>{c.label}</a>;
        })}
      </div>

      <button class="hamburger md:hidden z-50 flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class="w-5 h-[1.5px] bg-foreground transition-transform duration-200" />
        <span class="w-5 h-[1.5px] bg-foreground transition-opacity duration-200" />
        <span class="w-5 h-[1.5px] bg-foreground transition-transform duration-200" />
      </button>
    </div>
  </nav>
</header>

<style>
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translateY(6px); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translateY(-6px); }
</style>
