---
const { posts = [] } = Astro.props;
---
<section>
  <div class="container">
    <div class="blog-grid">
      {posts.map(post => (
        <a href={post.href || '#'} class="blog-card">
          <div class="date">{post.date}</div>
          <h3>{post.title}</h3>
          <p class="excerpt">{post.excerpt}</p>
          <span class="tag">{post.tag}</span>
        </a>
      ))}
    </div>
  </div>
</section>
