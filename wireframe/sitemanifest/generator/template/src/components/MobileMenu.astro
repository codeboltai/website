---
const { links = [] } = Astro.props;
---
<div class="mobile-menu fixed inset-0 top-16 bg-background z-40 overflow-y-auto hidden md:hidden">
  <div class="px-6 py-8 flex flex-col h-full">
    <nav class="flex flex-col">
      {links.map((link) => (
        <>
          <a
            href={link.href}
            class="block text-lg font-medium transition-colors border-b border-border py-4 text-muted-foreground hover:text-foreground"
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}
          </a>
          {link.children && (
            <div class="border-b border-border">
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class="block text-sm transition-colors py-3 pl-6 text-muted-foreground/70 hover:text-foreground"
                  {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </>
      ))}
    </nav>

    {/* Theme toggle */}
    <button
      type="button"
      class="theme-toggle mt-6 self-start flex items-center gap-3 px-4 py-3 border border-border rounded-full text-sm text-muted-foreground hover:text-foreground hover:border-muted-foreground/60 transition-colors"
      aria-label="Toggle theme"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2" />
        <path d="M12 20v2" />
        <path d="m4.93 4.93 1.41 1.41" />
        <path d="m17.66 17.66 1.41 1.41" />
        <path d="M2 12h2" />
        <path d="M20 12h2" />
        <path d="m6.34 17.66-1.41 1.41" />
        <path d="m19.07 4.93-1.41 1.41" />
      </svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="block dark:hidden">
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
      </svg>
      <span class="dark:hidden">Switch to dark</span>
      <span class="hidden dark:inline">Switch to light</span>
    </button>
  </div>
</div>

<style>
  .mobile-menu.open { display: block; }
</style>
