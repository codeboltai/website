import BaseLayout from '../layouts/BaseLayout.astro';
import { site, navigation } from '../data/site-data.js';
import CenteredText from '../components/CenteredText.astro';
import TwoColumnText from '../components/TwoColumnText.astro';
import ValueList from '../components/ValueList.astro';
import CtaBlock from '../components/CtaBlock.astro';
---
<BaseLayout title="About — Codebolt" navbarVariant="solid" site={site} navigation={navigation}>
  <CenteredText
    variant="thesis"
    text="We saw the gap between what AI agents promise and what they can actually deliver. The bottleneck isn't intelligence. It's infrastructure. We built the infrastructure."
  />
  <TwoColumnText
    columns={[{"heading":"What everyone is building","body":"Smarter models. Better prompts. Faster autocomplete. More agents running in parallel."},{"heading":"What's actually missing","body":"An environment where agents can coordinate, resolve conflicts, track drift, and scale without collapsing into chaos."}]}
    conclusion="Codebolt is the environment."
  />
  <ValueList
    heading="What We Believe"
    values={["The environment is the multiplier, not the model.","Depth over breadth. Solve the hard problem well.","Honesty over hype. Show benchmarks, not adjectives.","Earned complexity. The system grows with your ambition."]}
  />
  <CenteredText
    heading="The Engineering"
    text="Codebolt is built from scratch — not forked, not wrapped. The architecture is grounded in research on stigmergic coordination, narrative versioning, and drift tracking. Every layer exists because the problem demanded it."
  />
  <CtaBlock
    heading="We're building the infrastructure for the AI agent era."
    buttons={[{"label":"See Open Roles","href":"/careers","variant":"primary"},{"label":"Read the Architecture","href":"/architecture","variant":"secondary"}]}
  />
</BaseLayout>
