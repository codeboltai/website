---
const { problem = {}, solution = {} } = Astro.props;
---
<section>
  <div class="container">
    <div class="comparison">
      <div class="comparison-col problem">
        <h3>{problem.heading}</h3>
        <ul>
          {problem.items.map(item => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
      <div class="comparison-col solution">
        <h3>{solution.heading}</h3>
        <ul>
          {solution.items.map(item => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
