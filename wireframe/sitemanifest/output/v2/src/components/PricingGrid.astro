---
import Button from './Button.astro';
const { cards = [] } = Astro.props;
---
<section>
  <div class="container">
    <div class="pricing-grid">
      {cards.map(card => (
        <div class={`pricing-card ${card.featured ? 'featured' : ''}`}>
          {card.badge && <span class="pricing-badge">{card.badge}</span>}
          <h3>{card.tier}</h3>
          <div class="price">
            {card.price}
            {card.price_sub && <span class="price-sub">{card.price_sub}</span>}
          </div>
          <p class="for">{card.for}</p>
          <ul>
            {card.features.map(f => (
              <li>{f}</li>
            ))}
          </ul>
          <Button label={card.cta.label} href={card.cta.href} variant={card.cta.variant || 'secondary'} external={card.cta.external} />
        </div>
      ))}
    </div>
  </div>
</section>
