---
const { personas = [] } = Astro.props;
---
<section>
  <div class="container">
    <div class="persona-grid">
      {personas.map(persona => (
        <div class="persona-card">
          <div class="label">{persona.label}</div>
          <p>{persona.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
