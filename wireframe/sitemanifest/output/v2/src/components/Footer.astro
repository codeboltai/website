---
const { brand = {}, columns = [], bottom = {}, logo = {} } = Astro.props;
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">{logo.text}<span class="bolt">{logo.highlight}</span></div>
        <p>{brand.tagline}</p>
      </div>
      {columns.map(col => (
        <div class="footer-col">
          <h4>{col.heading}</h4>
          <ul>
            {col.links.map(link => (
              <li>
                <a href={link.href} {...(link.external ? { target: '_blank' } : {})}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <span>&copy; {bottom.copyright}</span>
      {bottom.links && bottom.links.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </div>
</footer>
