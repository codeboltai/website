---
const { variant = 'solid', links = [], cta = {}, logo = {} } = Astro.props;
---
<nav class={`navbar ${variant}`}>
  <div class="container">
    <a href="/" class="navbar-logo">{logo.text}<span class="bolt">{logo.highlight}</span></a>
    <ul class="navbar-links">
      {links.map(link => (
        <li>
          <a href={link.href} {...(link.external ? { target: '_blank' } : {})}>
            {link.label}
          </a>
        </li>
      ))}
      {cta.label && (
        <li>
          <a href={cta.href} class="btn-ghost">{cta.label}</a>
        </li>
      )}
    </ul>
    <button class="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
