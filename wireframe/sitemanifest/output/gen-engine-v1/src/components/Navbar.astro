---
const { variant = 'solid', links = [], cta = {}, logo = {} } = Astro.props;
---
<header class="fixed top-0 left-0 w-full z-50">
  <nav
    class={`navbar ${variant} border-b border-border ${variant === 'transparent' ? 'bg-transparent' : 'bg-background/80 backdrop-blur-xl'} dark:border-neutral-900`}
  >
    <div class="max-w-[1400px] mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 z-50 relative group">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-foreground">
          <path d="M12 2L3 7V17L12 22L21 17V7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none" />
          <path d="M12 2V12" stroke="currentColor" stroke-width="1.5" />
          <path d="M3 7L12 12" stroke="currentColor" stroke-width="1.5" />
          <path d="M21 7L12 12" stroke="currentColor" stroke-width="1.5" />
          <path d="M12 12V22" stroke="currentColor" stroke-width="1.5" />
        </svg>
        <span class="font-medium text-foreground text-sm tracking-tight group-hover:text-primary transition-colors">
          {logo.text}<span class="text-primary">{logo.highlight}</span>
        </span>
      </a>

      <nav class="hidden md:flex absolute left-1/2 -translate-x-1/2">
        <ul class="flex items-center gap-8">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-200 text-muted-foreground hover:text-foreground"
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="hidden md:flex items-center gap-4 z-50">
        {cta.label && (
          <a
            href={cta.href}
            class="text-sm bg-primary text-primary-foreground px-5 py-2 rounded-full font-medium hover:bg-cyan-400 transition-all duration-300"
          >
            {cta.label}
          </a>
        )}
      </div>

      <button class="hamburger md:hidden z-50 flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class="w-5 h-[1.5px] bg-foreground transition-transform duration-200" />
        <span class="w-5 h-[1.5px] bg-foreground transition-opacity duration-200" />
        <span class="w-5 h-[1.5px] bg-foreground transition-transform duration-200" />
      </button>
    </div>
  </nav>
</header>

<style>
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translateY(6px); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translateY(-6px); }
</style>
