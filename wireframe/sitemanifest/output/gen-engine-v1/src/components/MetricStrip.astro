---
import { cn } from '../lib/utils';

const { metrics = [], columns = 4, divider = false, className } = Astro.props;

const colStyles = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-4',
};
---

<div
  class={cn(
    'border border-border bg-card/30 dark:border-zinc-800 dark:bg-[#050505]',
    divider && 'divide-y md:divide-y-0 md:divide-x divide-border dark:divide-zinc-800',
    className
  )}
>
  <div class={cn('grid', colStyles[columns] ?? colStyles[4])}>
    {metrics.map((m) => (
      <div class="p-4">
        <span class="block text-[9px] font-mono text-muted-foreground uppercase tracking-widest mb-1 dark:text-zinc-500">
          {m.label}
        </span>
        <span class={cn('text-sm font-mono', m.highlight ? 'text-primary dark:text-cyan-500' : 'text-foreground dark:text-zinc-200')}>
          {m.value}
        </span>
        {m.meta && (
          <span class="block mt-2 text-[9px] font-mono text-muted-foreground/70 uppercase tracking-widest dark:text-zinc-600">
            {m.meta}
          </span>
        )}
      </div>
    ))}
  </div>
</div>
