---
const { heading, items = [] } = Astro.props;
---
<section class="py-24 px-6 bg-background dark:bg-[#050505] text-foreground border-b border-border dark:border-zinc-900">
  <div class="max-w-5xl mx-auto">
    {heading && (
      <h2 class="text-4xl md:text-5xl font-medium tracking-tight text-center mb-12">
        {heading}
      </h2>
    )}
    <div class="accordion space-y-4">
      {items.map((item) => (
        <div class="accordion-item border border-border dark:border-zinc-800 bg-card/30">
          <button type="button" class="accordion-trigger w-full px-6 py-4 text-left flex items-center justify-between hover:bg-accent/50 transition-colors">
            <span class="text-lg font-medium text-foreground">
              {item.question}
            </span>
            <svg class="accordion-chevron w-5 h-5 text-muted-foreground transition-transform duration-200" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 8l4 4 4-4" />
            </svg>
          </button>
          <div class="accordion-content overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out">
            <div class="px-6 pb-4">
              <p class="text-muted-foreground leading-relaxed">
                {item.answer}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .accordion-item.open .accordion-content { max-height: 320px; }
  .accordion-item.open .accordion-chevron { transform: rotate(180deg); }
</style>
