---
import { cn } from '../lib/utils';

const { label, dotColor = 'primary', dotShape = 'circle', pulse = false, className } = Astro.props;

const colors = {
  primary: 'bg-primary dark:bg-cyan-500',
  emerald: 'bg-emerald-500',
  amber: 'bg-amber-500',
  indigo: 'bg-indigo-500',
  purple: 'bg-purple-500',
  red: 'bg-red-500',
  muted: 'bg-muted-foreground dark:bg-zinc-500',
};

const shape = dotShape === 'square' ? 'rounded-[2px]' : 'rounded-full';
---

<div class={cn('flex items-center gap-3', className)}>
  <div class="relative flex h-2 w-2">
    {pulse && (
      <span class={cn('absolute inline-flex h-full w-full opacity-75 animate-ping', shape, colors[dotColor] ?? colors.primary)} />
    )}
    <span class={cn('relative inline-flex h-2 w-2', shape, colors[dotColor] ?? colors.primary)} />
  </div>
  <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-muted-foreground dark:text-zinc-500">
    {label}
  </span>
</div>
