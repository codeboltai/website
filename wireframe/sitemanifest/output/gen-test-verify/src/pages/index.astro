---
// Auto-generated from site.yaml — edit site.yaml and regenerate
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, navigation } from '../data/site-data.js';
import Hero from '../components/Hero.astro';
import HighlightBanner from '../components/HighlightBanner.astro';
import StatGrid from '../components/StatGrid.astro';
import CenteredText from '../components/CenteredText.astro';
import ComparisonColumns from '../components/ComparisonColumns.astro';
import CardGrid from '../components/CardGrid.astro';
import IconGrid from '../components/IconGrid.astro';
import DiagramSection from '../components/DiagramSection.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import PersonaGrid from '../components/PersonaGrid.astro';
import CtaBlock from '../components/CtaBlock.astro';
---
<BaseLayout title="Codebolt — The High-Performance IDE for AI Agents" navbarVariant="transparent" site={site} navigation={navigation}>
  <Hero
    heading="The High-Performance IDE for AI Agents."
    subheading="Precision-engineered so agents align better, conflict less, and scale further."
    buttons={[{"label":"Get Started","href":"/pricing","variant":"primary"}]}
  />
  <HighlightBanner
    tone="accent"
    content={`Scaling agents is an <span class="text-primary">engineering problem</span>, not a prompting problem.
`}
  />
  <StatGrid
    tone="muted"
    columns={4}
    stats={[{"label":"Concurrent Agents","value":"100+"},{"label":"Drift Signals","value":"4D"},{"label":"Environments","value":"Multi"},{"label":"Replay","value":"Deterministic"}]}
  />
  <CenteredText
    variant="thesis"
    text="Scaling agents is an engineering problem, not a prompting problem. Agents don't need better models — they need a better environment."
  />
  <ComparisonColumns
    problem={{"heading":"Without a proper environment","items":["Agents conflict over shared files","Changes drift from original intent","Multi-environment work creates merge chaos","Scaling past 2-3 agents breaks everything","You spend more time debugging agents than building"]}}
    solution={{"heading":"With Codebolt","items":["Conflicts resolve at the system level","Drift tracking catches misalignment early","Cross-environment coordination is built in","The architecture handles hundreds of agents","You direct the vision. Agents build the system."]}}
  />
  <CardGrid
    heading="Core Capabilities"
    cards={[{"title":"Multi-Agent Coordination","body":"Agents work as a coordinated team, not independent processes fighting over shared state. The environment manages communication, sequencing, and dependencies.","visual":"Agent A ──┐\nAgent B ──┤ Environment\nAgent C ──┘ (coordinated)\n"},{"title":"Drift Tracking","body":"The system evaluates structural, scope, and coverage drift continuously. When agents deviate from intent, you know before the damage compounds.","visual":"Intent → Plan → Code\n      ↑ drift detected\n"},{"title":"Cross-Environment Execution","body":"Agents operate across branches, staging, local, and production environments simultaneously. The system reconciles their work automatically.","visual":"local ──┐\nstaging ┤→ reconciled\nprod ───┘\n"},{"title":"Conflict Resolution","body":"When agents make incompatible changes, the environment resolves it. Not the user. Conflicts are handled as a system-level primitive.","visual":"conflict → arbitration → resolved"},{"title":"Ground-Up Architecture","body":"Not a VS Code fork. Not a wrapper. Built from scratch with agent coordination as the foundation, not a feature bolted on later.","visual":"┌─ Governance ─┐\n│ Drift Engine │\n│ Agent Runtime│\n└─ Editor ─────┘\n"},{"title":"Model-Agnostic","body":"The environment amplifies whatever model you put in it. As models improve, your agents improve automatically. No vendor lock-in.","visual":"GPT ──┐\nClaude┤→ Codebolt\nGemini┘  Environment\n"}]}
  />
  <IconGrid
    tone="muted"
    kicker="SYSTEM MODULES"
    title="Designed for scale
Built for governance
"
    description="The primitives you need when agents become infrastructure."
    columns={3}
    features={[{"icon":"layers","title":"Five-Layer Stack","description":"Layered architecture that keeps coordination and governance out of your prompt."},{"icon":"git-branch","title":"Narrative Versioning","description":"Track what changed, why it changed, and who changed it across environments."},{"icon":"shield","title":"Governance First","description":"Constraints, auditability, and deterministic replay are built into the system."},{"icon":"cpu","title":"Runtime Coordination","description":"Agents coordinate through structured shared state, not fragile message passing."},{"icon":"code","title":"Model-Agnostic","description":"Swap models without rewriting workflows. The environment does the heavy lifting."},{"icon":"zap","title":"Conflict Arbitration","description":"Conflicts get resolved as a system primitive, not a manual merge task."}]}
  />
  <DiagramSection
    heading="The Architecture"
    layers={[{"label":"Layer 1 — Editor Interface","tag":"surface","style":"surface"},{"label":"Layer 2 — Agent Runtime","tag":"runtime","style":"runtime"},{"label":"Layer 3 — Drift Engine","tag":"Rust","style":"drift"},{"label":"Layer 4 — Narrative Versioning","tag":"git-tree","style":"versioning"},{"label":"Layer 5 — Governance & Coordination","tag":"core","style":"governance"}]}
    annotation="Most tools stop at Layer 2. Codebolt is Layers 3–5."
    buttons={[{"label":"Explore the full architecture","href":"/architecture","variant":"secondary"}]}
  />
  <QuoteBlock
    variant="muted"
    align="center"
    quote="A brilliant engineer in a company with no version control, no CI/CD, and no communication tools would be ineffective. Not because they lack skill — because the environment doesn't support good work. The same is true for AI agents today."
    attribution="Codebolt Research"
  />
  <PersonaGrid
    personas={[{"label":"Infrastructure Engineers","body":"You've hit the coordination wall. You know the problem isn't the model — it's the environment. This is what you've been looking for."},{"label":"Teams Scaling AI","body":"Moving from 2 agents to 50. You need a system that handles the complexity so you can focus on the product."},{"label":"Enterprise & Production","body":"You won't put agents in production without governance, traceability, and deterministic replay. Neither would we."}]}
  />
  <CenteredText
    variant="identity"
    text="Designed for engineers who treat AI as infrastructure — not just assistance."
  />
  <CtaBlock
    heading="Ready to scale your agents."
    buttons={[{"label":"Get Started","href":"/pricing","variant":"primary"},{"label":"Read the Docs","href":"https://docs.codebolt.ai","variant":"secondary","external":true}]}
  />
</BaseLayout>
