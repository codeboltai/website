---
import { cn } from '../lib/utils';

const { problem, solution } = Astro.props;
---

<section class="py-0 px-6 border-b border-border dark:border-zinc-900 bg-background dark:bg-[#050505]">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 border-x border-border dark:border-zinc-800">
      {/* Left: Problem */}
      <div class="p-8 md:p-12 flex flex-col justify-between relative overflow-hidden border-b md:border-b-0 md:border-r border-border dark:border-zinc-800 bg-muted/10 dark:bg-zinc-900/10">
        <div class="relative z-10">
          <div class="font-mono text-xs uppercase text-muted-foreground dark:text-zinc-500 mb-8 flex justify-between items-center gap-4">
            <span class="flex items-center gap-2">
              {problem.heading}
            </span>
            <span class="shrink-0 px-2 py-1 border text-[10px] tracking-wider border-red-900/30 bg-red-900/10 text-red-500">
              RISK: HIGH
            </span>
          </div>

          <div class="space-y-4">
            {problem.items && problem.items.map((item) => (
              <div class="flex items-start gap-3">
                <span class="text-red-500 font-mono">x</span>
                <p class="text-sm text-muted-foreground dark:text-zinc-400 leading-relaxed">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Right: Solution */}
      <div class="p-8 md:p-12 flex flex-col justify-between relative overflow-hidden bg-muted/5 dark:bg-[#080808]">
        {/* Highlight Grid */}
        <div class="absolute inset-0 bg-grid-subtle opacity-50 pointer-events-none" />

        <div class="relative z-10">
          <div class="font-mono text-xs uppercase text-muted-foreground dark:text-zinc-500 mb-8 flex justify-between items-center gap-4">
            <span class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-foreground dark:bg-white rounded-full" />
              {solution.heading}
            </span>
            <span class="shrink-0 px-2 py-1 border text-[10px] tracking-wider border-green-900/30 bg-green-900/10 text-green-500">
              RISK: MITIGATED
            </span>
          </div>

          <div class="space-y-4">
            {solution.items && solution.items.map((item) => (
              <div class="flex items-start gap-3">
                <span class="text-green-500 font-mono">✓</span>
                <p class="text-sm text-foreground dark:text-zinc-200 leading-relaxed">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
