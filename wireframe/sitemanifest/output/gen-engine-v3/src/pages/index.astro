import BaseLayout from '../layouts/BaseLayout.astro';
import { site, navigation } from '../data/site-data.js';
import Hero from '../components/Hero.astro';
import StartTabs from '../components/StartTabs.astro';
import HighlightBanner from '../components/HighlightBanner.astro';
import StatGrid from '../components/StatGrid.astro';
import CenteredText from '../components/CenteredText.astro';
import IconGrid from '../components/IconGrid.astro';
import ProgressionStrip from '../components/ProgressionStrip.astro';
import ShowcaseStrip from '../components/ShowcaseStrip.astro';
import SdkCallout from '../components/SdkCallout.astro';
import FeatureShowcase from '../components/FeatureShowcase.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import BentoGrid from '../components/BentoGrid.astro';
