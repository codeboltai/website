---
// Auto-generated from site.yaml — edit site.yaml and regenerate
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, navigation } from '../../data/site-data.js';
import ProductHeroStack from '../../components/ProductHeroStack.astro';
import CenteredText from '../../components/CenteredText.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import AccordionShowcase from '../../components/AccordionShowcase.astro';
import TabsShowcase from '../../components/TabsShowcase.astro';
import CtaBlock from '../../components/CtaBlock.astro';
---
<BaseLayout title="Self Evolving Memory - Codebolt" navbarVariant="solid" site={site} navigation={navigation}>
  <ProductHeroStack
    eyebrow="SELF EVOLVING MEMORY"
    title="Memory that improves the agent system, not just the next prompt"
    subtitle="Codebolt externalizes memory into the engine runtime. Agents can stop, restart, multiply, and move across environments while the application layer preserves context, assembles the right knowledge, and evolves the rules that decide what future agents should know."
    buttons={[{"label":"Explore Architecture","href":"/architecture","variant":"primary"},{"label":"Back to Engine","href":"/engine","variant":"secondary"}]}
    stackTitle="Memory control plane"
    stackItems={[{"label":"Agent role","value":"stateless intellectual processor"},{"label":"Context owner","value":"Context Assembly Engine"},{"label":"Write path","value":"event-driven ingestion pipelines"},{"label":"Storage","value":"episodic logs, persistent memory, vector, graph, KV"},{"label":"Evolution","value":"agents mutate rules, pipelines, and retrieval logic"}]}
    footer="The engine remembers across sessions, agents, swarms, projects, and environments."
  />
  <CenteredText
    variant="thesis"
    text="Most agent memory is a bigger chat history. Codebolt memory is externalized infrastructure: events are captured, knowledge is structured, retrieval is pipelined, and the Context Assembly Engine builds each agent's context from state variables, rules, and token budgets."
  />
  <BentoGrid
    kicker="WHY IT IS DIFFERENT"
    heading="Externalized memory for ephemeral agents and swarms"
    description="The point is not to make one agent remember more. The point is to let every future agent inherit what the system learned."
    columns={3}
    items={[{"title":"Agents do not own the state","tag":"EXTERNALIZED","span":2,"description":"Traditional agents carry context inside a thread. Codebolt moves working context, facts, events, rules, and retrieval strategy into the durable engine layer. Agents can be paused, replaced, or spawned in parallel without losing the intelligence they produced.","visual":"agent run ends\n      |\n      v\nmemory survives in engine\n      |\n      v\nnext agent inherits context\n"},{"title":"Context is assembled, not hunted","tag":"CAE","description":"An agent supplies state variables such as task, role, thread, project, swarm, or phase. The Context Assembly Engine evaluates rules, calls memory pipelines, merges results, and returns budgeted context with traceability."},{"title":"Memory has a write path","tag":"INGESTION","description":"Application events such as conversation end, task start, task failure, task completion, actions, and errors can trigger ingestion pipelines. Raw events become summaries, records, embeddings, graph edges, or structured memories."},{"title":"Retrieval is programmable","tag":"PIPELINES","description":"Persistent memory definitions can use query derivation, vector search, graph expansion, KV reads, log search, filters, dedupe, ranking, transforms, and aggregation. Retrieval becomes an engine capability, not prompt glue."},{"title":"Swarm knowledge compounds","tag":"STIGMERGY","span":2,"description":"External memory gives swarms a shared environment. Agents coordinate through persistent signals, task ownership, past failures, learned workflows, and structured facts instead of fragile direct message chains.","visual":"Agent A -> shared memory <- Agent B\nAgent C -> pheromones    <- Agent D\n\nno direct coupling\ncoordination accumulates over time\n"}]}
  />
  <FeatureBlock
    kicker="01 · THREE LAYERS"
    heading="A three-layer memory architecture"
    body="Codebolt separates memory into storage, orchestration, and context assembly. The storage layer handles multi-modal persistence. The orchestration layer controls ingestion and retrieval pipelines. The Context Assembly layer decides which memories matter for the current agent state and enforces context budgets."
    diagram="LAYER 3: CONTEXT ASSEMBLY
├─ evaluate rules
├─ select memories
├─ merge + dedupe
├─ enforce token budget
└─ return traceable context

LAYER 2: ORCHESTRATION
├─ ingestion pipelines
├─ retrieval pipelines
├─ memory stitching
└─ ranking + transforms

LAYER 1: STORAGE
├─ episodic event logs
├─ persistent memory definitions
├─ vector database
├─ knowledge graph
└─ key-value state
"
  />
  <AccordionShowcase
    kicker="AUTONOMOUS EVOLUTION"
    heading="How memory evolves while agents work"
    description="Agents do not just store more notes. They can improve the rules and memory structures that future agents inherit."
    visual={{"label":"Memory evolution loop","code":"observe event\n      |\n      v\ningest + structure\n      |\n      v\nretrieve + assemble\n      |\n      v\nagent acts with context\n      |\n      v\nupdate memory rules\n"}}
    items={[{"question":"Observe real work","answer":"The server emits events for conversations, tasks, actions, failures, completions, tools, jobs, and agent activity. Memory ingestion subscribes to those events through a bridge, resolves domain data, and turns runtime behavior into memory inputs."},{"question":"Ingest into durable structures","answer":"Pipelines can store raw blobs, chunk text, create embeddings, extract entities with LLMs, parse structured data, normalize outputs, and route writes into logs, vectors, graphs, KV stores, or persistent memory instances."},{"question":"Retrieve across memory types","answer":"A memory can define a retrieval pipeline that derives a query, searches vectors, expands a graph, reads KV state, searches logs, filters, deduplicates, ranks, transforms, and aggregates results before they reach the agent."},{"question":"Assemble by state","answer":"The Context Assembly Engine receives scope variables for swarm, agent, project, orchestrator, thread, task, user, org, plus custom variables like execution phase. Rules map those variables to the memories that matter right now."},{"question":"Improve the rules","answer":"When an agent discovers a recurring failure, useful workflow, missing context, or better retrieval path, it can encode that learning into memory definitions, context rules, ingestion behavior, or custom agents and plugins."}]}
  />
  <TabsShowcase
    kicker="MEMORY SURFACES"
    heading="One memory system, multiple storage modes"
    description="Different kinds of agent intelligence need different persistence shapes. Codebolt keeps them under one runtime instead of forcing everything into chat history."
    tabs={[{"label":"Episodic","title":"Append-only event memory","body":"Capture what happened over time: conversations, observations, tool calls, agent activity, source metadata, and context. This is the flight recorder for agent work.","points":["Time-based recall for threads and agents","Useful for audits, replay, summaries, and failure analysis","Feeds higher-level persistent memory"],"visual":{"label":"episodic memory","code":"event log\n├─ timestamp\n├─ source\n├─ type\n├─ content\n└─ context\n"}},{"label":"Persistent","title":"Structured memory definitions","body":"Define named memories with scopes, schemas, persistence modes, ingestion triggers, retrieval pipelines, and contribution rules.","points":["Cross-session knowledge retention","Declarative memory types","Persistent, session, or ephemeral modes"],"visual":{"label":"persistent memory","code":"memory definition\n├─ scopes: project, agent, task\n├─ schema\n├─ ingestion\n└─ retrieval pipeline\n"}},{"label":"Vector","title":"Semantic retrieval","body":"Chunk and embed large text so agents can retrieve relevant documents, codebase knowledge, conversations, and historical observations by meaning.","points":["Powered by embedding services","Backed by sqlite-vec in the server","Used by code search and RAG"],"visual":{"label":"vector retrieval","code":"query -> embed\n      -> top_k semantic matches\n      -> rerank\n      -> context item\n"}},{"label":"Graph","title":"Relationship memory","body":"Store entities, records, and edges for project concepts, agents, tasks, dependencies, decisions, failures, and learned relationships.","points":["Graph expansion for related context","Kuzu-backed knowledge graph service","Useful for multi-agent and long-lived systems"],"visual":{"label":"knowledge graph","code":"Task -> touches -> File\nAgent -> learned -> Pattern\nFailure -> caused_by -> Constraint\n"}},{"label":"Rules","title":"Context selection logic","body":"Context rules decide what to include based on runtime variables. This is where self-improvement becomes infrastructure: better rules mean better context for every future agent.","points":["Rules evaluate against scope variables","Assemblies include traces for debugging","Token budgets keep context focused"],"visual":{"label":"context rule","code":"if task_type = refactor\nand phase = debugging\ninclude:\n  - past_failures\n  - related_files\n  - review_notes\n"}}]}
  />
  <FeatureBlock
    kicker="02 · WHY IT SCALES"
    heading="Thread history independence is a scaling feature"
    body="When memory lives outside the agent instance, parallel agents do not need to carry every previous message. They can load the right slice on demand. That matters for swarm-scale work: hundreds of agents can share durable knowledge without copying full thread histories into every context window."
    reverse={true}
    diagram="without externalized memory:
agent = thread history + current task
scale breaks as history grows

with Codebolt:
agent = current task + assembled context
memory = shared engine layer

1 agent  -> same memory substrate
10 agents -> same memory substrate
300+ agents -> same memory substrate
"
  />
  <CtaBlock
    heading="Give your agents a memory system that gets better with use."
    buttons={[{"label":"Explore Architecture","href":"/architecture","variant":"primary"},{"label":"Back to Features","href":"/engine","variant":"secondary"}]}
  />
</BaseLayout>
