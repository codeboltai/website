  <CenteredText
    variant="thesis"
    text="Codebolt Editor is the desktop command center for the engine. Open projects, edit code, run terminals, talk to agents, inspect their work, manage plans, coordinate environments, install plugins, and launch application interfaces that run directly on the Codebolt runtime."
  />
  <BentoGrid
    kicker="EDITOR CAPABILITIES"
    heading="A full editor built around agent work"
    description="The editor is not only chat next to files. It is a complete workspace where code, context, agents, planning artifacts, runtime panels, and observability live together."
    columns={3}
    gap="none"
    items={[{"title":"Project workspace","tag":"Workspace","description":"Open <a href='https://docs.codebolt.ai/docs/02_using-codebolt/02_surfaces/02_desktop-app/01_workspace-and-projects'>workspaces</a> with file tree, editor state, chat threads, project-local config, checkpoints, indexes, codemap, and memory. Tune the <a href='https://docs.codebolt.ai/docs/02_using-codebolt/02_surfaces/02_desktop-app/02_panels-and-layout'>panel layout</a> and <a href='https://docs.codebolt.ai/docs/02_using-codebolt/02_surfaces/02_desktop-app/03_settings-and-profiles'>settings profiles</a> per project.","span":2,"visual":"workspace\n├─ project tabs\n├─ file tree + editor state\n├─ chat threads + agent runs\n├─ .codebolt/ config\n└─ checkpoints + memory\n"},{"title":"AI coding surface","tag":"Editor","description":"Code editing, terminals, file explorer, project context, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/03_chat/01_overview'>chat</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/03_chat/04_checkpoints-and-rollback'>checkpoints and rollback</a>, and <a href='https://docs.codebolt.ai/docs/02_using-codebolt/03_chat/06_model-selection'>model selection</a> in one desktop surface."},{"title":"Agent workspace","tag":"Agents","description":"<a href='https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/03_running-agents'>Run agents</a> from the project, including <a href='https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/02_built-in-agents'>built-in agents</a>, remixes, custom agents, third-party agents, and remote agents. Use <a href='https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/06_agent-portfolios'>agent portfolios</a> and the <a href='https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/08_thread-panel'>thread panel</a> to manage work."},{"title":"Debug and observability","tag":"Observe","description":"Inspect <a href='https://docs.codebolt.ai/docs/02_using-codebolt/05c_agent-observability/02_agent-debug'>agent logs</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/05c_agent-observability/03_ai-debug-and-console'>LLM calls, token budgets, and console output</a>, plus <a href='https://docs.codebolt.ai/docs/02_using-codebolt/09b_code-observability/03_narrative-graph'>narrative graphs</a> and run history without leaving the workspace."},{"title":"Planning tools","tag":"Plan","description":"<a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/02_roadmap'>Roadmaps</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/03_specs'>specs</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/04_ui-flow'>UI flows</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/05_requirement-plan'>requirement plans</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/06_action-plan'>action plans</a>, and <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/07_tasks'>tasks</a> live beside the code so humans and agents share the same source of truth."},{"title":"Runtime UI panels","tag":"Apps","description":"Agents and plugins can open <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/04_custom-uis/05_dynamic-panels'>dynamic panels</a>, stream data into them, and receive user actions back. Build a <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/04_custom-uis/07_build-your-first-dynamic-panel'>first panel</a>, package <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/05_plugins/05_dynamic-panel-plugins'>plugin-backed panels</a>, or create <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/04b_custom-agentic-applications/01_overview'>custom agentic apps</a>."}]}
