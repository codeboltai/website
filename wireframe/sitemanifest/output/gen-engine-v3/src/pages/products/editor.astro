---
// Auto-generated from site.yaml — edit site.yaml and regenerate
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, navigation } from '../../data/site-data.js';
import PageHeader from '../../components/PageHeader.astro';
import CenteredText from '../../components/CenteredText.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import CtaBlock from '../../components/CtaBlock.astro';
---
<BaseLayout title="Codebolt Editor — Desktop Agent Environment" navbarVariant="solid" site={site} navigation={navigation}>
  <PageHeader
    title="Codebolt Editor"
    subtitle="A full desktop editor built for agent coordination. Not a VS Code fork — built from scratch."
  />
  <CenteredText
    variant="thesis"
    text="Monaco editor (the engine behind VS Code). Integrated terminal. File explorer. Agent workspace showing real-time activity. Plugin panel. Excalidraw canvas. Dockview panels. Cross-platform. 40+ file type associations. And the same agent engine that powers CLI and orchestration."
  />
  <FeatureBlock
    heading="A proper IDE with agents at the center"
    body="The agent workspace shows real-time agent activity — what they're doing, what files they're touching, what decisions they're making. Multiple agents visible simultaneously. Plugin panel for extensions. Not an afterthought sidebar — agents are the primary interface."
    diagram="┌─────────────────────────────────┐
│ Monaco Editor    │ Agent Panel  │
│ (VS Code engine) │ (real-time)  │
├─────────────────────────────────┤
│ Terminal  │ File Explorer       │
│ (xterm)   │ Plugins │ Excalidraw│
└─────────────────────────────────┘
macOS (arm64/x64) + Windows + Linux
"
  />
  <FeatureBlock
    heading="What Cursor can't do"
    body="Write custom agents that run inside the IDE. Install plugins with three communication channels. Coordinate multiple agents on the same codebase with pheromone-based ownership. Scale to multi-environment. Switch to CLI or headless without losing anything."
    reverse={true}
    diagram="Cursor:
✗ Custom agents
✗ Plugin SDK (3 channels)
✗ Multi-agent coordination
✗ Multi-environment
✗ CLI/headless mode

Codebolt Editor:
✓ All of the above
+ Same engine as CLI/orchestration
"
  />
  <FeatureBlock
    heading="Built from scratch, not forked"
    body="Codebolt isn't a VS Code fork with agents bolted on. The architecture starts with the agent engine — 73 controllers, 134 services, the HostBridge abstraction. The IDE is one interface to that engine. The same codebase powers the CLI, TUI, web interface, and headless server with identical capabilities."
    diagram="┌── Interface (Electron) ──────┐
│ Monaco + xterm + dockview    │
├── HostBridge ────────────────┤
│ Same engine as CLI/headless  │
├── Core Engine ───────────────┤
│ 73 controllers               │
│ 134 services                 │
│ 3 communication channels     │
└──────────────────────────────┘
"
  />
  <CtaBlock
    heading="An IDE built for the agent era."
    buttons={[{"label":"Download","href":"/pricing","variant":"primary"},{"label":"Explore the Engine","href":"/engine","variant":"secondary"}]}
  />
</BaseLayout>
