{
  "name": "codebolt-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run --prefix ./newsite build",
    "dev": "npm run --prefix ./newsite dev --",
    "deploy": "npm run --prefix ./newsite deploy",
    "test": "npm run build && node scripts/validate-newsite.mjs",
    "lint": "node scripts/validate-newsite.mjs",
    "typecheck": "node --check newsite/build.mjs && node --check scripts/validate-newsite.mjs",
    "seo:check": "node scripts/validate-newsite.mjs",
    "sitegen:generate": "sitegen generate --template ./template --content ./content/site.yaml --output ./site",
    "sitegen:validate": "sitegen validate --template ./template --content ./content/site.yaml",
    "sitegen:build": "npm run sitegen:generate && npm install --prefix ./site --loglevel error && npm run --prefix ./site build",
    "sitegen:dev": "npm run sitegen:generate && npm install --prefix ./site --loglevel error && npm run --prefix ./site dev --",
    "export-diagrams": "node scripts/export-diagrams.mjs",
    "generate-code-image": "node scripts/generate-code-image.mjs"
  },
  "devDependencies": {
    "@codebolt/agent-sitegen": "^0.1.1",
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "wrangler": "^4.103.0"
  }
}
