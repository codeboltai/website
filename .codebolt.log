      [32m'pages:\n'[39m +
      [32m'\n'[39m +
      [32m'  # ── Homepage ────────────────────────────────\n'[39m +
      [32m'  - slug: ""\n'[39m +
      [32m'    title: "Codebolt — AI Engine for Agent-Native Software"\n'[39m +
      [32m'    navbar_variant: "transparent"\n'[39m +
      [32m'    sections:\n'[39m +
      [32m'\n'[39m +
      [32m'      - type: hero\n'[39m +
      [32m'        eyebrow: "AGENT-NATIVE SOFTWARE"\n'[39m +
      [32m'        heading: "The self-evolving, swarm-scale AI agent engine"\n'[39m +
      [32m'        headingAccent:\n'[39m +
      [32m'          - "self-evolving"\n'[39m +
      [32m'          - "swarm-scale"\n'[39m +
      [32m'        subheading: "Build software with Codebolt. Run and coordinate hundreds of autonomous agents across laptops, cloud, and fleets. Ship Codebolt-native applications that run directly on the engine runtime."\n'[39m +
      [32m'        buttons:\n'[39m +
      [32m'          - { label: "Download", href: "/download", variant: "primary" }\n'[39m +
      [32m'          - { label: "Read the Docs", href: "/docs", variant: "secondary" }\n'[39m +
      [32m'      - type: start-tabs\n'[39m +
      [32m'        eyebrow: "Use Codebolt where you work"\n'[39m +
      [32m'        tabs:\n'[39m +
      [32m'          - label: "CLI"\n'[39m +
      [32m'            body: "Install globally with npm. Run in your terminal. Use a built-in agent or write your own — full SDK access, any LLM provider."\n'[39m +
      [32m'            code: "npm i -g codebolt"\n'[39m +
      [32m'            primary: { label: "Install Guide", href: "/products/cli" }\n'[39m +
      [32m'            more: { label: "View CLI", href: "/products/cli" }\n'[39m +
      [32m'            media:\n'[39m +
      [32m'              label: "~ codebolt"\n'[39m +
      [32m'              src: "/images/cli-1.png"\n'[39m +
      [32m'              alt: "Codebolt CLI terminal interface"\n'[39m +
      [32m'              placeholder: "CLI Terminal"\n'[39m +
      [32m'          - label: "Editor"\n'[39m +
      [32m'            body: "Polished desktop IDE with the engine running locally. Monaco editor, agent workspace, plugin panel. Available for macOS, Windows, and Linux."\n'[39m +
      [32m'            primary: { label: "Download Editor", href: "/download" }\n'[39m +
      [32m'            more: { label: "View Editor", href: "/products/editor" }\n'[39m +
      [32m'            media:\n'[39m +
      [32m'              label: "Codebolt Editor"\n'[39m +
      [32m'              src: "/images/desktop-1.png"\n'[39m +
      [32m'              alt: "Codebolt desktop editor interface"\n'[39m +
      [32m'              placeholder: "Desktop IDE"\n'[39m +
      [32m'          - label: "Cloud"\n'[39m +
      [32m'            body: "Hosted engine in your browser. No install. Spawn workspaces, run agents on managed sandboxes, share state with your team."\n'[39m +
      [32m'            primary: { label: "Open Cloud", href: "https://cloud.codebolt.ai" }\n'[39m +
      [32m'            more: { label: "View Cloud", href: "/products/cloud" }\n'[39m +
      [32m'            media:\n'[39m +
      [32m'              label: "Remote Chat"\n'[39m +
      [32m'              src: "/images/cloud.png"\n'[39m +
      [32m'              alt: "Codebolt remote chat workspace showing a live autonomous agent completing build and server tasks"\n'[39m +
      [32m'              placeholder: "Browser Workspace"\n'[39m +
      [32m'          - label: "SDK"\n'[39m +
      [32m'            body: "Embed the engine in your own product. Agent SDK (63+ modules), Plugin SDK (3 channels), Client SDK (72 REST + 33 WS). Self-host the engine or call it as a service."\n'[39m +
      [32m'            code: "npm i codeboltjs"\n'[39m +
      [32m'            primary: { label: "Get the SDK", href: "/products/sdk" }\n'[39m +
      [32m'            more: { label: "View SDK", href: "/products/sdk" }\n'[39m +
      [32m'            media:\n'[39m +
      [32m'              label: "codeboltjs"\n'[39m +
      [32m'              src: "/images/sdk-editor.png"\n'[39m +
      [32m'              alt: "Codebolt Agent SDK TypeScript editor example"\n'[39m +
      [32m'              placeholder: "Engine, embedded"\n'[39m +
      [32m'\n'[39m +
      [32m'      - type: highlight-banner\n'[39m +
      [32m'        tone: "accent"\n'[39m +
      [32m'        content: |\n'[39m +
      [32m'          Start like Claude Code. Scale like nothing else exists. <span class="text-primary">One engine. Every scale.</span>\n'[39m +
      [32m'\n'[39m +
      [32m'      - type: stat-grid\n'[39m +
      [32m'        tone: "muted"\n'[39m +
      [32m'        columns: 3\n'[39m +
      [32m'        stats:\n'[39m +
      [32m'          - { label: "SDK Modules", value: "63+" }\n'[39m +
      [32m'          - { label: "LLM Providers", value: "17+" }\n'[39m +
      [32m'          - { label: "Communication Channels", value: "3" }\n'[39m +
      [32m'          - { label: "Environments", value: "Unlimited" }\n'[39m +
      [32m'\n'[39m +
      [32m'      - type: centered-text\n'[39m +
      [32m'        variant: "thesis"\n'[39m +
      [32m'        text: "Claude Code is an agent. OpenClaw is an assistant. Cursor is an editor. Codebolt is the engine that can become any of them — and scale beyond all of them."\n'[39m +
      [32m'\n'[39m +
      [32m'      # ── What is Agent-Native Software? ──\n'[39m +
      [32m'      - type: icon-grid\n'[39m +
      [32m'        tone: "muted"\n'[39m +
      [32m'        kicker: "WHAT IS AGENT-NATIVE SOFTWARE"\n'[39m +
      [32m'        title: |\n'[39m +
      [32m'          Software that runs itself, improves itself,\n'[39m +
      [32m'          distributes itself, and composes with other software like it.\n'[39m +
      [32m`        description: "Agent-native software has properties traditional software doesn't. Codebolt is the engine that makes them possible."\n`[39m +
      [32m'        columns: 5\n'[39m +
      [32m'        features:\n'[39m +
      [32m'          - icon: "zap"\n'[39m +
      [32m'            title: "Runs itself"\n'[39m +
      [32m`            description: "Autonomous loops, hooks, schedules, webhooks. The agent stays in motion without you driving it. You don't have to be in the loop for work to happen."\n`[39m +
      [32m'          - icon: "git-branch"\n'[39m +
      [32m'            title: "Improves itself"\n'[39m +
      [32m'            description: "Define what good looks like with eval tasks. The optimizer iterates on prompts, tools, and configs across runs. Your agents get measurably better with use, not worse."\n'[39m +
      [32m'          - icon: "layers"\n'[39m +
      [32m'            title: "Distributes itself"\n'[39m +
      [32m'            description: "Lives where customers already are — Slack, Telegram, Discord, email, web. The Routing Gateway carries the same agent to every surface, no glue code."\n'[39m +
      [32m'          - icon: "cpu"\n'[39m +
      [32m'            title: "Composes"\n'[39m +
      [32m'            description: "Agents call agents. Multi-agent by default. Stigmergy, deliberation councils, review-merge — coordination is built in, not bolted on."\n'[39m +
      [32m'\n'[39m +
      [32m'      # ── What you can build / run ─────────────────\n'[39m +
      [32m'      - type: section-header\n'[39m +
      [32m'        kicker: "WHAT YOU CAN BUILD"\n'[39m +
      [32m'        kickerDot: "primary"\n'[39m +
      [32m'        align: "center"\n'[39m +
      [32m'        title: "Four things you do on the engine"\n'[39m +
      [32m'        description: "Build software. Build a custom harness. Run autonomous. Build on top — the same engine covers the full arc, from your first agent to applications that run on top of Codebolt."\n'[39m +
      [32m'\n'[39m +
      [32m'      - type: feature-block\n'[39m +
      [32m'        kicker: "01 · BUILD WITH CODEBOLT"'[39m... 276655 more characters
