{
  "name": "codebolt-site",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "node ./node_modules/astro/astro.js dev --host",
    "build": "node ./node_modules/astro/astro.js build",
    "preview": "node ./node_modules/astro/astro.js preview",
    "cf:dev": "npm run build && wrangler pages dev dist",
    "cf:deploy": "npm run build && wrangler pages deploy",
    "deploy": "npm run cf:deploy",
    "dev:bin": "astro dev",
    "build:bin": "astro build",
    "preview:bin": "astro preview"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.0.0",
    "clsx": "^2.1.1",
    "motion": "^12.38.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
