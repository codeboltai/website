---
import { cn } from '../lib/utils';

const {
  tone = 'default',
  padding = 'lg',
  maxWidth = 'xl',
  borderTop = false,
  borderBottom = false,
  className,
} = Astro.props;

const toneStyles = {
  default: 'bg-background dark:bg-[#050505]',
  card: 'bg-card/30 dark:bg-[#050505]',
  deep: 'bg-background dark:bg-[#030303]',
  muted: 'bg-muted/10 dark:bg-zinc-900/10',
};

const paddingStyles = {
  none: 'py-0',
  sm: 'py-10',
  md: 'py-14',
  lg: 'py-16 md:py-20',
  xl: 'py-20 md:py-24',
};

const maxWidthStyles = {
  sm: 'max-w-xl',
  md: 'max-w-3xl',
  lg: 'max-w-5xl',
  xl: 'max-w-[1200px]',
  '2xl': 'max-w-7xl',
  full: 'max-w-none',
};
---

<section
  class={cn(
    'px-6',
    toneStyles[tone] ?? toneStyles.default,
    paddingStyles[padding] ?? paddingStyles.lg,
    borderTop && 'border-t border-border dark:border-zinc-800/60',
    borderBottom && 'border-b border-border dark:border-zinc-800/60',
    className
  )}
>
  <div class={cn('mx-auto', maxWidthStyles[maxWidth] ?? maxWidthStyles.xl)}>
    <slot />
  </div>
</section>
