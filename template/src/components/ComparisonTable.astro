---
interface Row {
  label: string;
  values: string[];
}

interface Props {
  heading?: string;
  description?: string;
  kicker?: string;
  columns: string[];
  rows: Row[];
  highlightColumn?: number;
  tone?: 'default' | 'muted';
}

const {
  heading,
  description,
  kicker,
  columns = [],
  rows = [],
  highlightColumn = -1,
  tone = 'default',
} = Astro.props;

const bgClass = tone === 'muted' ? 'bg-muted/10 dark:bg-zinc-900/20' : 'bg-background dark:bg-[#050505]';
---

<section class={`py-24 px-6 border-b border-border dark:border-zinc-900 ${bgClass}`}>
  <div class="max-w-[1200px] mx-auto">
    {(kicker || heading) && (
      <div class="mb-16">
        {kicker && (
          <div class="flex items-center gap-3 mb-6">
            <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
            <span class="font-mono text-[10px] text-muted-foreground uppercase tracking-widest">{kicker}</span>
          </div>
        )}
        {heading && <h2 class="text-3xl font-medium text-foreground tracking-tight mb-4">{heading}</h2>}
        {description && <p class="text-lg text-muted-foreground font-light max-w-2xl">{description}</p>}
      </div>
    )}

    <div class="overflow-x-auto border border-border dark:border-zinc-800">
      <table class="w-full text-left text-sm min-w-[800px]">
        <thead>
          <tr class="border-b border-border dark:border-zinc-800 bg-muted/10 dark:bg-zinc-900/30">
            {columns.map((col: string, i: number) => (
              <th
                class={`px-4 py-3 font-mono text-[10px] uppercase tracking-widest whitespace-nowrap ${
                  i === highlightColumn
                    ? 'text-primary dark:text-cyan-400 bg-primary/5 dark:bg-cyan-900/10'
                    : 'text-muted-foreground dark:text-zinc-500'
                }`}
              >
                {col}
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-border dark:divide-zinc-800/50">
          {rows.map((row: Row) => (
            <tr class="hover:bg-muted/5 dark:hover:bg-zinc-900/10 transition-colors">
              <td class="px-4 py-3 font-medium text-foreground dark:text-white whitespace-nowrap">
                {row.label}
              </td>
              {row.values.map((val: string, i: number) => (
                <td
                  class={`px-4 py-3 ${
                    (i + 1) === highlightColumn
                      ? 'text-foreground dark:text-zinc-200 bg-primary/5 dark:bg-cyan-900/10 font-medium'
                      : 'text-muted-foreground dark:text-zinc-400'
                  }`}
                >
                  {val}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
