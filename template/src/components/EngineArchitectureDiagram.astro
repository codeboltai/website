---
/**
 * @sitegen
 * type: engine-architecture-diagram
 * description: Codebolt engine architecture diagram with export support.
 * group: Architecture Sections
 */
/**
 * EngineArchitectureDiagram — Animated SVG diagram of the Codebolt Engine.
 *
 * Layout:
 *   ┌───────────── INTERFACES (top) ─────────────┐
 *   │  IDE  TUI  CUSTOM_UI  HEADLESS  WEB        │
 *   └────────────────┬───────────────────────────┘
 *                ┌───┴────┐
 *                │ CLIENT │
 *                │  SDK   │
 *                └───┬────┘
 *   ┌──────┐    ┌────┴────┐    ┌────────┐    ┌──────┐
 *   │PLUGIN│    │         │    │ AGENT  │    │AGENT_│
 *   │ SDK  │────│ ENGINE  │────│  SDK   │────│  01  │
 *   │      │    │         │    └────────┘    └──────┘
 *   └──┬───┘    │         │    ┌────────┐    ┌──────┐
 *      │        │         │────│PROVIDER│────│REMOTE│
 *   ┌──┴───┐    └─────────┘    │   S    │    │ ENV  │
 *   │PLUG_*│                    └────────┘    └──────┘
 *   └──────┘
 *
 * Uses motion (Motion One) for vanilla JS animations — no React.
 */
interface Props {
  heading?: string;
  description?: string;
  kicker?: string;
  exportId?: string;
}

const { heading, description, kicker, exportId } = Astro.props;

const slugify = (s: string) =>
  (s || '')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
const _exportId = exportId || slugify(heading || 'engine-architecture');
---

<section
  class="py-24 px-6 bg-background dark:bg-[#050505] border-b border-border dark:border-zinc-900"
  data-export-id={_exportId}
  data-export-title={heading || 'Engine Architecture'}
  data-export-kind="engine-architecture"
>
  <div class="max-w-[1200px] mx-auto" data-export-inner>
    {(kicker || heading) && (
      <div class="mb-16 max-w-3xl">
        {kicker && (
          <div class="flex items-center gap-3 mb-6">
            <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
            <span class="font-mono text-[10px] text-muted-foreground uppercase tracking-widest">{kicker}</span>
          </div>
        )}
        {heading && <h2 class="text-3xl md:text-4xl font-medium text-foreground tracking-tight mb-4">{heading}</h2>}
        {description && <p class="text-lg text-muted-foreground font-light">{description}</p>}
      </div>
    )}

    <div class="relative border border-border dark:border-zinc-800 bg-card/30 dark:bg-[#080808]/60 p-6 md:p-10 overflow-hidden">
      <svg
        id="engine-arch-svg"
        viewBox="0 0 900 640"
        class="w-full h-auto"
        xmlns="http://www.w3.org/2000/svg"
      >
        {/* ─────────── Section labels ─────────── */}
        <text x="450" y="28" text-anchor="middle" class="diagram-section-label" fill="hsl(var(--muted-foreground))">INTERFACES</text>
        <text x="115" y="218" text-anchor="middle" class="diagram-section-label" fill="hsl(var(--muted-foreground))">PLUGINS</text>
        <text x="770" y="158" text-anchor="middle" class="diagram-section-label" fill="hsl(var(--muted-foreground))">REMOTE ENVIRONMENTS</text>
        <text x="770" y="408" text-anchor="middle" class="diagram-section-label" fill="hsl(var(--muted-foreground))">AGENTS</text>

        {/* ═══════════════════════════════════════════════════════════
            CONNECTION LINES — orthogonal (horizontal + vertical only)
           ═══════════════════════════════════════════════════════════ */}

        {/* Interfaces → busline at y=160 → Client SDK */}
        <line class="conn" x1="180" y1="92" x2="180" y2="160" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="290" y1="92" x2="290" y2="160" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="450" y1="92" x2="450" y2="160" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="610" y1="92" x2="610" y2="160" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="720" y1="92" x2="720" y2="160" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="180" y1="160" x2="720" y2="160" stroke="currentColor" stroke-width="1" />
        <line class="conn-bright" x1="450" y1="160" x2="450" y2="190" stroke="currentColor" stroke-width="1.5" />

        {/* Client SDK → Engine top */}
        <line class="conn-bright" x1="450" y1="230" x2="450" y2="265" stroke="currentColor" stroke-width="1.5" />

        {/* Plugins → busline at x=210 → Plugin SDK */}
        <line class="conn" x1="155" y1="270" x2="210" y2="270" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="155" y1="320" x2="210" y2="320" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="155" y1="370" x2="210" y2="370" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="155" y1="420" x2="210" y2="420" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="210" y1="270" x2="210" y2="420" stroke="currentColor" stroke-width="1" />
        <line class="conn-bright" x1="210" y1="350" x2="270" y2="350" stroke="currentColor" stroke-width="1.5" />

        {/* Plugin SDK → Engine left */}
        <line class="conn-bright" x1="345" y1="350" x2="380" y2="350" stroke="currentColor" stroke-width="1.5" />

        {/* Engine right → Providers */}
        <line class="conn-bright" x1="580" y1="305" x2="615" y2="305" stroke="currentColor" stroke-width="1.5" />

        {/* Providers → busline at x=745 → Remote Environments */}
        <line class="conn-bright" x1="690" y1="305" x2="745" y2="305" stroke="currentColor" stroke-width="1.5" />
        <line class="conn" x1="745" y1="197" x2="745" y2="327" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="745" y1="197" x2="800" y2="197" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="745" y1="262" x2="800" y2="262" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="745" y1="327" x2="800" y2="327" stroke="currentColor" stroke-width="1" />

        {/* Engine right → Agent SDK */}
        <line class="conn-bright" x1="580" y1="395" x2="615" y2="395" stroke="currentColor" stroke-width="1.5" />

        {/* Agent SDK → busline at x=745 → Agents */}
        <line class="conn-bright" x1="690" y1="395" x2="745" y2="395" stroke="currentColor" stroke-width="1.5" />
        <line class="conn" x1="745" y1="395" x2="745" y2="577" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="745" y1="447" x2="800" y2="447" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="745" y1="512" x2="800" y2="512" stroke="currentColor" stroke-width="1" />
        <line class="conn" x1="745" y1="577" x2="800" y2="577" stroke="currentColor" stroke-width="1" />

        {/* ═══════════════════════════════════════════════════════════
            ANIMATED PACKETS
           ═══════════════════════════════════════════════════════════ */}
        {/* Interface → Engine (inbound) */}
        <circle class="packet packet-interface" r="3.5" fill="hsl(var(--primary))" cx="180" cy="92" />
        {/* Plugin → Engine (inbound) */}
        <circle class="packet packet-plugin" r="3.5" fill="hsl(var(--primary))" cx="155" cy="270" />
        {/* Engine → Provider/Remote Env (outbound, top right) */}
        <circle class="packet packet-provider" r="3.5" fill="hsl(var(--primary))" cx="480" cy="305" />
        {/* Engine → Agent (outbound, bottom right) */}
        <circle class="packet packet-agent" r="3.5" fill="hsl(var(--primary))" cx="480" cy="395" />

        {/* ═══════════════════════════════════════════════════════════
            ENGINE CORE (center)
           ═══════════════════════════════════════════════════════════ */}
        <g class="node node-core">
          <rect
            x="380"
            y="265"
            width="200"
            height="170"
            fill="hsl(var(--primary) / 0.05)"
            stroke="hsl(var(--primary))"
            stroke-width="1.5"
          />
          {/* Corner brackets */}
          <path d="M 380 265 L 380 275 M 380 265 L 390 265" stroke="hsl(var(--primary))" stroke-width="2" fill="none" />
          <path d="M 580 265 L 580 275 M 580 265 L 570 265" stroke="hsl(var(--primary))" stroke-width="2" fill="none" />
          <path d="M 380 435 L 380 425 M 380 435 L 390 435" stroke="hsl(var(--primary))" stroke-width="2" fill="none" />
          <path d="M 580 435 L 580 425 M 580 435 L 570 435" stroke="hsl(var(--primary))" stroke-width="2" fill="none" />

          <text x="480" y="310" text-anchor="middle" class="diagram-label-core" fill="currentColor">CODEBOLT</text>
          <text x="480" y="332" text-anchor="middle" class="diagram-label-core" fill="currentColor">ENGINE</text>

          {/* Inner divider line */}
          <line x1="400" y1="350" x2="560" y2="350" stroke="hsl(var(--primary) / 0.3)" stroke-width="1" stroke-dasharray="2 2" />

          <text x="480" y="370" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">73 controllers · 134 services</text>
          <text x="480" y="386" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">stigmergy · drift · narrative</text>
          <text x="480" y="402" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">deliberation · governance</text>
          <text x="480" y="418" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">three-tier memory · hostbridge</text>
        </g>

        {/* ═══════════════════════════════════════════════════════════
            SDK BOXES (sit on engine edges)
           ═══════════════════════════════════════════════════════════ */}

        {/* Client SDK (top) */}
        <g class="node">
          <rect x="405" y="190" width="90" height="40" fill="hsl(var(--card))" stroke="hsl(var(--primary) / 0.7)" stroke-width="1.2" />
          <text x="450" y="208" text-anchor="middle" class="diagram-label" fill="currentColor">CLIENT</text>
          <text x="450" y="222" text-anchor="middle" class="diagram-label" fill="currentColor">SDK</text>
        </g>

        {/* Plugin SDK (left) */}
        <g class="node">
          <rect x="270" y="330" width="75" height="40" fill="hsl(var(--card))" stroke="hsl(var(--primary) / 0.7)" stroke-width="1.2" />
          <text x="307" y="348" text-anchor="middle" class="diagram-label" fill="currentColor">PLUGIN</text>
          <text x="307" y="362" text-anchor="middle" class="diagram-label" fill="currentColor">SDK</text>
        </g>

        {/* Providers (right upper) */}
        <g class="node">
          <rect x="615" y="285" width="75" height="40" fill="hsl(var(--card))" stroke="hsl(var(--primary) / 0.7)" stroke-width="1.2" />
          <text x="652" y="303" text-anchor="middle" class="diagram-label" fill="currentColor">PROVIDERS</text>
          <text x="652" y="317" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">env bridge</text>
        </g>

        {/* Agent SDK (right lower) */}
        <g class="node">
          <rect x="615" y="375" width="75" height="40" fill="hsl(var(--card))" stroke="hsl(var(--primary) / 0.7)" stroke-width="1.2" />
          <text x="652" y="393" text-anchor="middle" class="diagram-label" fill="currentColor">AGENT</text>
          <text x="652" y="407" text-anchor="middle" class="diagram-label" fill="currentColor">SDK</text>
        </g>

        {/* ═══════════════════════════════════════════════════════════
            INTERFACES (top row)
           ═══════════════════════════════════════════════════════════ */}
        <g class="node">
          <rect x="150" y="50" width="60" height="42" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="180" y="70" text-anchor="middle" class="diagram-label" fill="currentColor">IDE</text>
          <text x="180" y="84" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">electron</text>
        </g>
        <g class="node">
          <rect x="260" y="50" width="60" height="42" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="290" y="70" text-anchor="middle" class="diagram-label" fill="currentColor">TUI</text>
          <text x="290" y="84" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">go / charm</text>
        </g>
        <g class="node">
          <rect x="415" y="50" width="70" height="42" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="450" y="70" text-anchor="middle" class="diagram-label" fill="currentColor">CUSTOM UI</text>
          <text x="450" y="84" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">your build</text>
        </g>
        <g class="node">
          <rect x="580" y="50" width="60" height="42" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="610" y="70" text-anchor="middle" class="diagram-label" fill="currentColor">HEADLESS</text>
          <text x="610" y="84" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">cli / ci</text>
        </g>
        <g class="node">
          <rect x="690" y="50" width="60" height="42" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="720" y="70" text-anchor="middle" class="diagram-label" fill="currentColor">WEB</text>
          <text x="720" y="84" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">browser</text>
        </g>

        {/* ═══════════════════════════════════════════════════════════
            PLUGINS (left column)
           ═══════════════════════════════════════════════════════════ */}
        <g class="node">
          <rect x="60" y="252" width="95" height="36" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="107" y="270" text-anchor="middle" class="diagram-label" fill="currentColor">PLUGIN_CI</text>
          <text x="107" y="282" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">build / deploy</text>
        </g>
        <g class="node">
          <rect x="60" y="302" width="95" height="36" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="107" y="320" text-anchor="middle" class="diagram-label" fill="currentColor">PLUGIN_SLACK</text>
          <text x="107" y="332" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">messaging</text>
        </g>
        <g class="node">
          <rect x="60" y="352" width="95" height="36" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="107" y="370" text-anchor="middle" class="diagram-label" fill="currentColor">PLUGIN_GIT</text>
          <text x="107" y="382" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">scm / pr</text>
        </g>
        <g class="node">
          <rect x="60" y="402" width="95" height="36" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="107" y="420" text-anchor="middle" class="diagram-label" fill="currentColor">PLUGIN_CLOUD</text>
          <text x="107" y="432" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">storage / fn</text>
        </g>

        {/* ═══════════════════════════════════════════════════════════
            REMOTE ENVIRONMENTS (right upper column)
           ═══════════════════════════════════════════════════════════ */}
        <g class="node">
          <rect x="800" y="178" width="95" height="38" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" stroke-dasharray="3 2" />
          <text x="847" y="197" text-anchor="middle" class="diagram-label" fill="currentColor">DOCKER_ENV</text>
          <text x="847" y="209" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">sandboxed</text>
        </g>
        <g class="node">
          <rect x="800" y="243" width="95" height="38" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" stroke-dasharray="3 2" />
          <text x="847" y="262" text-anchor="middle" class="diagram-label" fill="currentColor">CLOUD_VM</text>
          <text x="847" y="274" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">gpu · scale</text>
        </g>
        <g class="node">
          <rect x="800" y="308" width="95" height="38" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" stroke-dasharray="3 2" />
          <text x="847" y="327" text-anchor="middle" class="diagram-label" fill="currentColor">REMOTE_HOST</text>
          <text x="847" y="339" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">ssh · proxy</text>
        </g>

        {/* ═══════════════════════════════════════════════════════════
            AGENTS (right lower column)
           ═══════════════════════════════════════════════════════════ */}
        <g class="node">
          <rect x="800" y="428" width="95" height="38" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="847" y="447" text-anchor="middle" class="diagram-label" fill="currentColor">AGENT_01</text>
          <text x="847" y="459" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">custom · code</text>
        </g>
        <g class="node">
          <rect x="800" y="493" width="95" height="38" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="847" y="512" text-anchor="middle" class="diagram-label" fill="currentColor">AGENT_02</text>
          <text x="847" y="524" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">remix · yaml</text>
        </g>
        <g class="node">
          <rect x="800" y="558" width="95" height="38" fill="hsl(var(--card))" stroke="hsl(var(--border))" stroke-width="1" />
          <text x="847" y="577" text-anchor="middle" class="diagram-label" fill="currentColor">AGENT_03</text>
          <text x="847" y="589" text-anchor="middle" class="diagram-meta" fill="hsl(var(--muted-foreground))">flow · visual</text>
        </g>
      </svg>

      {/* Legend */}
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mt-8 text-[10px] font-mono text-muted-foreground uppercase tracking-[0.15em]">
        <div class="flex items-center gap-2">
          <div class="w-4 h-[1px] bg-border"></div>
          <span>CONNECTION</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-primary"></div>
          <span>PACKET</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 border border-primary"></div>
          <span>ENGINE CORE</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 border border-border" style="border-style: dashed;"></div>
          <span>REMOTE</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  #engine-arch-svg .conn {
    color: hsl(var(--border));
    opacity: 1;
  }
  #engine-arch-svg .conn-bright {
    color: hsl(var(--primary) / 0.5);
    opacity: 1;
  }
  #engine-arch-svg .node {
    color: hsl(var(--foreground));
    opacity: 1;
    transform-origin: center;
    transform-box: fill-box;
  }
  #engine-arch-svg .packet {
    opacity: 0;
  }
  /* Initial fade-in via CSS animation as a fallback if JS doesn't run */
  @keyframes diagramFadeIn { from { opacity: 0; } to { opacity: 1; } }
  #engine-arch-svg .conn,
  #engine-arch-svg .conn-bright {
    animation: diagramFadeIn 0.6s ease-out both;
  }
  #engine-arch-svg .node {
    animation: diagramFadeIn 0.6s ease-out both;
    animation-delay: 0.3s;
  }
  #engine-arch-svg .diagram-label {
    font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  #engine-arch-svg .diagram-label-core {
    font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  #engine-arch-svg .diagram-meta {
    font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.05em;
  }
  #engine-arch-svg .diagram-section-label {
    font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
</style>

<script>
  import { animate } from 'motion';

  function initDiagram() {
    const svg = document.getElementById('engine-arch-svg');
    if (!svg) return;

    const packetInterface = svg.querySelector('.packet-interface');
    const packetPlugin = svg.querySelector('.packet-plugin');
    const packetAgent = svg.querySelector('.packet-agent');
    const packetProvider = svg.querySelector('.packet-provider');

    // INBOUND: Interface (IDE) -> down -> right -> Client SDK -> Engine
    if (packetInterface) {
      animate(
        packetInterface,
        {
          cx: [180, 180, 450, 450],
          cy: [92, 160, 160, 320],
          opacity: [0, 1, 1, 0]
        },
        { duration: 2.8, delay: 0.5, repeat: Infinity, ease: 'linear', repeatDelay: 0.8 }
      );
    }

    // INBOUND: Plugin (CI) -> right -> down -> right -> Engine
    if (packetPlugin) {
      animate(
        packetPlugin,
        {
          cx: [155, 210, 210, 480],
          cy: [270, 270, 350, 350],
          opacity: [0, 1, 1, 0]
        },
        { duration: 2.8, delay: 0.9, repeat: Infinity, ease: 'linear', repeatDelay: 0.8 }
      );
    }

    // OUTBOUND: Engine -> Providers -> right -> up -> CLOUD_VM (top right)
    if (packetProvider) {
      animate(
        packetProvider,
        {
          cx: [480, 745, 745, 847],
          cy: [305, 305, 262, 262],
          opacity: [0, 1, 1, 0]
        },
        { duration: 2.8, delay: 1.3, repeat: Infinity, ease: 'linear', repeatDelay: 0.8 }
      );
    }

    // OUTBOUND: Engine -> Agent SDK -> right -> down -> AGENT_01 (bottom right)
    if (packetAgent) {
      animate(
        packetAgent,
        {
          cx: [480, 745, 745, 847],
          cy: [395, 395, 447, 447],
          opacity: [0, 1, 1, 0]
        },
        { duration: 2.8, delay: 1.7, repeat: Infinity, ease: 'linear', repeatDelay: 0.8 }
      );
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDiagram);
  } else {
    initDiagram();
  }
  document.addEventListener('astro:page-load', initDiagram);
</script>
