---
const { text, variant = '', heading } = Astro.props;

const variantStyles = {
  thesis: 'text-2xl md:text-3xl text-foreground font-light leading-relaxed',
  identity: 'text-xl md:text-2xl text-foreground font-light leading-relaxed',
};
---
<section class="py-14 md:py-16 px-6 bg-background dark:bg-[#050505] border-b border-border dark:border-zinc-900">
  <div class="max-w-4xl mx-auto text-center px-0 md:px-8">
    {heading && (
      <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-foreground dark:text-white mb-8 leading-[1.12]">
        {heading}
      </h2>
    )}
    <p class={variantStyles[variant] ?? variantStyles.thesis}>
      {text}
    </p>
  </div>
</section>
