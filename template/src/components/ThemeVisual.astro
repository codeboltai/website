  '#090A17': 'hsl(var(--card))',
  '#090B12': 'hsl(var(--card))',
  '#090C13': 'hsl(var(--card))',
  '#090D13': 'hsl(var(--card))',
  '#091D26': 'hsl(var(--card))',
  '#0A0F1E': 'hsl(var(--card))',
  '#0A1A23': 'hsl(var(--card))',
  '#0B1220': 'hsl(var(--card))',
  '#0B1320': 'hsl(var(--card))',
  '#0B1A24': 'hsl(var(--card))',
  '#0D1B2A': 'hsl(var(--card))',
  '#0F172A': 'hsl(var(--secondary))',
  '#0F1B27': 'hsl(var(--secondary))',
  '#100A12': 'hsl(var(--card))',
  '#101006': 'hsl(var(--card))',
  '#101825': 'hsl(var(--secondary))',
  '#101827': 'hsl(var(--secondary))',
  '#111827': 'hsl(var(--secondary))',
  '#120A12': 'hsl(var(--card))',
  '#12121A': 'hsl(var(--secondary))',
  '#121725': 'hsl(var(--secondary))',
  '#121827': 'hsl(var(--secondary))',
  '#17142A': 'hsl(var(--primary) / 0.12)',
  '#1B3148': 'hsl(var(--muted))',
  '#1D3345': 'hsl(var(--muted))',
  '#1D3348': 'hsl(var(--muted))',
  '#1E293B': 'hsl(var(--muted))',
  '#1E3146': 'hsl(var(--muted))',
  '#1F1300': 'hsl(var(--primary) / 0.08)',
  '#1F2937': 'hsl(var(--border))',
