---
import { existsSync, readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { join, normalize, sep } from 'node:path';
import { randomUUID } from 'node:crypto';

interface Props {
  src: string;
  alt?: string;
  class?: string;
  loading?: 'eager' | 'lazy';
}

const {
  src,
  alt = '',
  class: className = '',
  loading = 'lazy',
} = Astro.props;

const cleanSrc = typeof src === 'string' ? src.split(/[?#]/)[0] : '';
const isLocalSvg = cleanSrc.startsWith('/images/') && cleanSrc.endsWith('.svg');
const publicImagesDir = fileURLToPath(new URL('../../public/images/', import.meta.url));

let svgMarkup = '';
const svgIdPrefix = `theme-visual-${randomUUID().replace(/-/g, '')}`;

const colorTokenMap: Record<string, string> = {
  '#00D8FF': 'hsl(var(--primary))',
  '#020617': 'hsl(var(--background))',
  '#030508': 'hsl(var(--background))',
  '#03130A': 'hsl(var(--card))',
  '#04131C': 'hsl(var(--card))',
  '#050816': 'hsl(var(--background))',
  '#050B14': 'hsl(var(--background))',
  '#060E17': 'hsl(var(--card))',
  '#061018': 'hsl(var(--card))',
  '#06101C': 'hsl(var(--card))',
  '#06111F': 'hsl(var(--card))',
  '#061A22': 'hsl(var(--card))',
  '#070D16': 'hsl(var(--card))',
  '#070E18': 'hsl(var(--card))',
  '#07111A': 'hsl(var(--card))',
  '#07111F': 'hsl(var(--card))',
