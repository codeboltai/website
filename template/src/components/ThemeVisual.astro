  '#334155': 'hsl(var(--border))',
  '#34475E': 'hsl(var(--border))',
  '#38BDF8': 'hsl(var(--primary))',
  '#475569': 'hsl(var(--muted-foreground) / 0.65)',
  '#5EEAD4': 'hsl(var(--primary))',
  '#5FF5D0': 'hsl(var(--primary))',
  '#64748B': 'hsl(var(--muted-foreground))',
  '#7B8BA0': 'hsl(var(--muted-foreground))',
  '#94A3B8': 'hsl(var(--muted-foreground))',
  '#99F6E4': 'hsl(var(--primary) / 0.78)',
  '#9EF7FF': 'hsl(var(--primary) / 0.82)',
  '#A78BFA': 'hsl(var(--primary))',
  '#AFC2D4': 'hsl(var(--muted-foreground))',
