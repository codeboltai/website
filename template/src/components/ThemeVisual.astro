  '#EDE9FE': 'hsl(var(--foreground))',
  '#FB7185': 'hsl(var(--primary))',
  '#FBBF24': 'hsl(var(--primary))',
  '#FCA5A5': 'hsl(var(--primary) / 0.72)',
  '#FDA4AF': 'hsl(var(--primary) / 0.72)',
  '#FDE68A': 'hsl(var(--primary) / 0.56)',
  '#FECDD3': 'hsl(var(--primary) / 0.35)',
  '#FEF3C7': 'hsl(var(--primary) / 0.28)',
  '#FFE4E6': 'hsl(var(--primary) / 0.25)',
};

function escapeRegExp(value: string) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function prefixSvgIds(markup: string, prefix: string) {
  const ids = Array.from(markup.matchAll(/\bid="([^"]+)"/g), (match) => match[1]);
  let nextMarkup = markup;

  for (const id of ids) {
    const nextId = `${prefix}-${id}`;
    const escapedId = escapeRegExp(id);
    nextMarkup = nextMarkup
      .replace(new RegExp(`\\bid="${escapedId}"`, 'g'), `id="${nextId}"`)
      .replace(new RegExp(`url\\(#${escapedId}\\)`, 'g'), `url(#${nextId})`)
      .replace(new RegExp(`href="#${escapedId}"`, 'g'), `href="#${nextId}"`)
      .replace(new RegExp(`xlink:href="#${escapedId}"`, 'g'), `xlink:href="#${nextId}"`)
      .replace(new RegExp(`aria-labelledby="([^"]*)\\b${escapedId}\\b([^"]*)"`, 'g'), (_match, before, after) => (
        `aria-labelledby="${before}${nextId}${after}"`
      ));
  }

  return nextMarkup;
}

function normalizeSvgTheme(markup: string, idPrefix: string) {
  return prefixSvgIds(markup, idPrefix)
    .replace(/<svg\b(?![^>]*\bclass=)/, '<svg class="theme-svg"')
    .replace(/<svg\b([^>]*?)\bclass="([^"]*)"/, '<svg$1class="theme-svg $2"')
    .replace(/#[0-9A-Fa-f]{6}\b/g, (match) => colorTokenMap[match.toUpperCase()] || match);
}

if (isLocalSvg) {
  const fileName = decodeURIComponent(cleanSrc.replace('/images/', ''));
  const filePath = normalize(join(publicImagesDir, fileName));
  const isInsideImagesDir = filePath.startsWith(normalize(publicImagesDir + sep));

  if (isInsideImagesDir && existsSync(filePath)) {
    svgMarkup = normalizeSvgTheme(readFileSync(filePath, 'utf8'), svgIdPrefix);
  }
}
---

{svgMarkup ? (
  <span
    class={`theme-aware-visual theme-svg-visual ${className}`}
    role={alt ? 'img' : undefined}
    aria-label={alt || undefined}
    aria-hidden={alt ? undefined : 'true'}
    set:html={svgMarkup}
  />
) : (
  <img src={src} alt={alt} class={`theme-aware-visual ${className}`} loading={loading} />
)}
