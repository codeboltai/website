---
/**
 * @sitegen
 * type: product-hero
 * description: Product page hero with media, metrics, and action buttons.
 * group: Hero Sections
 */
import { cn } from '../lib/utils';
import ThemeVisual from './ThemeVisual.astro';

interface Button {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary';
}

interface Media {
  src?: string;
  alt?: string;
  label?: string;
  placeholder?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  buttons?: Button[];
  installLabel?: string;
  installCommand?: string;
  media?: Media;
}

const {
  eyebrow,
  title,
  subtitle,
  buttons = [],
  installLabel = 'Install',
  installCommand,
  media,
} = Astro.props;

const primaryBtn = buttons.find((button: Button) => button.variant === 'primary') || buttons[0];
const secondaryBtn = buttons.find((button: Button) => button.variant === 'secondary') || buttons[1];
---

<section class="relative overflow-hidden border-b border-border bg-background text-foreground dark:border-neutral-900 dark:bg-[#050505]">
  <div class="absolute inset-x-0 top-0 h-px bg-primary/30"></div>
  <div class="relative mx-auto grid max-w-[1200px] grid-cols-1 items-stretch border-x border-border dark:border-zinc-900 lg:grid-cols-12">
    <div class="flex flex-col justify-center px-6 py-28 md:px-10 lg:col-span-5 lg:min-h-[680px] lg:border-r lg:border-border lg:py-32 dark:lg:border-zinc-900">
      {eyebrow && (
        <div class="mb-6 flex items-center gap-3">
          <span class="h-1.5 w-1.5 bg-primary"></span>
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted-foreground">{eyebrow}</span>
        </div>
      )}

      <h1 class="max-w-xl text-5xl font-medium leading-[1.03] tracking-tight text-foreground dark:text-white md:text-6xl">
        {title}
      </h1>

      {subtitle && (
        <p class="mt-6 max-w-xl text-base leading-relaxed text-muted-foreground md:text-lg dark:text-zinc-400">
          {subtitle}
        </p>
      )}

      {(primaryBtn || secondaryBtn) && (
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          {primaryBtn && (
            <a href={primaryBtn.href} class={cn(
              'inline-flex h-10 items-center justify-center border px-5 text-sm font-semibold transition-colors',
              'border-primary bg-primary text-primary-foreground hover:bg-primary/90'
            )}>
              {primaryBtn.label}
            </a>
          )}
          {secondaryBtn && (
            <a href={secondaryBtn.href} class={cn(
              'inline-flex h-10 items-center justify-center border px-5 text-sm font-semibold transition-colors',
              'border-border bg-background text-foreground hover:border-muted-foreground/70 dark:border-zinc-800 dark:bg-[#050505]'
            )}>
              {secondaryBtn.label}
            </a>
          )}
        </div>
      )}

      {installCommand && (
        <div class="mt-5 flex max-w-xl items-center overflow-hidden border border-border bg-card/50 dark:border-zinc-800 dark:bg-[#080808]">
          <div class="hidden shrink-0 border-r border-border px-3 py-3 font-mono text-[10px] uppercase tracking-widest text-muted-foreground dark:border-zinc-800 sm:block">
            {installLabel}
          </div>
          <code class="min-w-0 flex-1 overflow-x-auto whitespace-nowrap px-4 py-3 font-mono text-sm text-foreground dark:text-zinc-100">
            {installCommand}
          </code>
          <button
            type="button"
            class="product-hero-copy shrink-0 border-l border-border px-3 py-3 font-mono text-[10px] uppercase tracking-widest text-muted-foreground transition-colors hover:text-foreground dark:border-zinc-800"
            data-copy-text={installCommand}
          >
            Copy
          </button>
        </div>
      )}
    </div>

    <div class="relative min-h-[460px] overflow-hidden bg-[#020202] lg:col-span-7 lg:min-h-[680px]">
      <div class="absolute inset-0 bg-grid opacity-70"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_55%_25%,hsl(var(--primary)/0.18),transparent_34%)]"></div>
      <div class="relative flex h-full items-center justify-center p-6 md:p-10">
        <div class="w-full max-w-3xl border border-zinc-800 bg-[#050505] shadow-2xl shadow-black/60">
          <div class="flex h-9 items-center gap-2 border-b border-zinc-800 bg-[#090909] px-4">
            <span class="h-2 w-2 bg-zinc-700"></span>
            <span class="h-2 w-2 bg-zinc-700"></span>
            <span class="h-2 w-2 bg-zinc-700"></span>
            {media?.label && (
              <span class="ml-3 truncate font-mono text-[10px] uppercase tracking-widest text-zinc-500">
                {media.label}
              </span>
            )}
          </div>
          <div class="aspect-[16/10] bg-black">
            {media?.src ? (
              <ThemeVisual src={media.src} alt={media.alt || 'Product demo'} class="h-full w-full object-cover" loading="eager" />
            ) : (
              <div class="flex h-full flex-col justify-between p-6 font-mono text-[11px] leading-relaxed text-zinc-400 md:p-8">
                <div class="text-primary">{media?.placeholder || 'Codebolt CLI product visual'}</div>
                <pre class="overflow-hidden whitespace-pre-wrap text-zinc-300">{`codebolt
  threads
    refactor auth        running
    write tests          queued
    review diff          ready

  panels
    chat | files | git | logs | settings

  runtime
    local -> docker -> remote -> cloud`}</pre>
                <div class="text-zinc-600">same engine across CLI, editor, cloud, and SDK</div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.product-hero-copy').forEach((button) => {
    button.addEventListener('click', async () => {
      const text = button instanceof HTMLElement ? button.dataset.copyText : '';
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const previous = button.textContent || 'Copy';
        button.textContent = 'Copied';
        window.setTimeout(() => {
          button.textContent = previous;
        }, 1400);
      } catch {
        button.textContent = 'Copy';
      }
    });
  });
</script>
