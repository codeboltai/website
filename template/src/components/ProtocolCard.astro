---
import { cn } from '../lib/utils';

const {
  code,
  title,
  description,
  leftLabel,
  leftValue,
  rightLabel,
  rightValue,
  rightValueClassName,
  className,
} = Astro.props;
---

<div class={cn('group p-8 md:p-12 hover:bg-muted/20 dark:hover:bg-zinc-900/30 transition-colors duration-500 flex flex-col h-full relative', className)}>
  <div class="mb-8 flex justify-between items-start">
    <span class="font-mono text-[10px] text-muted-foreground dark:text-zinc-500 uppercase tracking-[0.2em] border border-border dark:border-zinc-800 px-2 py-1 rounded-sm group-hover:border-primary/50 group-hover:text-primary dark:group-hover:border-cyan-500/50 dark:group-hover:text-cyan-400 transition-colors">
      {code}
    </span>
    <div class="w-1.5 h-1.5 bg-border dark:bg-zinc-800 rounded-full group-hover:bg-primary dark:group-hover:bg-cyan-500 transition-colors shadow-[0_0_10px_hsl(var(--primary))] dark:shadow-[0_0_10px_#06b6d4]" />
  </div>

  <h3 class="text-xl font-medium text-foreground dark:text-white mb-4 tracking-tight">
    {title}
  </h3>

  <p class="text-sm text-muted-foreground dark:text-zinc-500 font-light leading-relaxed mb-10 flex-grow">
    {description}
  </p>

  <div class="pt-6 border-t border-border/50 dark:border-zinc-800/50 flex items-center justify-between font-mono text-[9px] text-muted-foreground dark:text-zinc-600 uppercase tracking-widest">
    <div class="flex flex-col gap-1">
      <span class="text-[8px] text-muted-foreground/70 dark:text-zinc-700">{leftLabel}</span>
      <span class="text-foreground dark:text-zinc-300">{leftValue}</span>
    </div>
    <div class="flex flex-col gap-1 text-right">
      <span class="text-[8px] text-muted-foreground/70 dark:text-zinc-700">{rightLabel}</span>
      <span class={rightValueClassName ?? 'text-primary/80 dark:text-cyan-500/70'}>{rightValue}</span>
    </div>
  </div>
</div>
