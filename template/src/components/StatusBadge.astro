---
import { cn } from '../lib/utils';

const { variant = 'default', showDot = false, pulse = false, label, className } = Astro.props;

const variants = {
  default: 'border-border bg-muted/20 text-muted-foreground',
  emerald: 'border-green-900/30 bg-green-900/10 text-green-500',
  amber: 'border-amber-900/30 bg-amber-900/10 text-amber-500',
  red: 'border-red-900/30 bg-red-900/10 text-red-500',
  primary: 'border-primary/30 bg-primary/10 text-primary dark:text-cyan-400',
};

const dotColors = {
  default: 'bg-muted-foreground',
  emerald: 'bg-green-500',
  amber: 'bg-amber-500',
  red: 'bg-red-500',
  primary: 'bg-primary',
};
---

<span class={cn('inline-flex items-center gap-2 px-2 py-1 border text-[10px] tracking-wider uppercase font-mono', variants[variant] ?? variants.default, className)}>
  {showDot && (
    <span class="relative flex h-1.5 w-1.5">
      {pulse && <span class={cn('absolute inline-flex h-full w-full rounded-full opacity-75 animate-ping', dotColors[variant] ?? dotColors.default)} />}
      <span class={cn('relative inline-flex h-1.5 w-1.5 rounded-full', dotColors[variant] ?? dotColors.default)} />
    </span>
  )}
  {label ? label : <slot />}
</span>
