---
import { cn } from '../lib/utils';

const { index, title, description, indexVariant = 'default', bgVariant = 'default', className } = Astro.props;

const indexVariants = {
  default: 'text-muted-foreground/70 dark:text-zinc-600',
  primary: 'text-primary dark:text-cyan-500',
  amber: 'text-amber-600 dark:text-amber-500',
  emerald: 'text-emerald-600 dark:text-emerald-500',
  red: 'text-red-600 dark:text-red-500',
};
---

<div class={cn('p-8', bgVariant === 'muted' && 'bg-muted/10 dark:bg-zinc-900/10', className)}>
  <span class={cn('font-mono text-[10px] block mb-2 uppercase tracking-wider', indexVariants[indexVariant] ?? indexVariants.default)}>
    {index}
  </span>
  <h4 class="text-foreground dark:text-white text-sm font-medium mb-2">
    {title}
  </h4>
  <p class="text-xs text-muted-foreground dark:text-zinc-400 leading-relaxed">
    {description}
  </p>
</div>
