---
import { cn } from '../lib/utils';

const {
  title,
  subtitle,
  figureLabel,
  showGrid = false,
  aspectRatio = '4/3',
  diagramHtml,
  className,
} = Astro.props;

const ratio = String(aspectRatio).split('/').map((n) => Number(n));
const aspectStyle = ratio.length === 2 && ratio[0] > 0 && ratio[1] > 0 ? `aspect-ratio: ${ratio[0]} / ${ratio[1]};` : '';
---

<div class={cn('w-full', className)}>
  <div class="flex items-start justify-between gap-6 mb-4">
    <div class="flex flex-col gap-1">
      {title && (
        <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground dark:text-zinc-500">
          {title}
        </span>
      )}
      {subtitle && (
        <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/70 dark:text-zinc-600">
          {subtitle}
        </span>
      )}
    </div>
  </div>

  <div class="relative w-full border border-border dark:border-zinc-800 bg-card dark:bg-[#050505] overflow-hidden" style={aspectStyle}>
    {showGrid && <div class="absolute inset-0 bg-grid opacity-20 pointer-events-none" />}
    {diagramHtml ? <div class="relative z-10 w-full h-full" set:html={diagramHtml} /> : <div class="relative z-10 w-full h-full"><slot /></div>}
  </div>

  {figureLabel && (
    <p class="mt-3 text-[10px] text-muted-foreground font-mono dark:text-zinc-500 px-1">
      {figureLabel}
    </p>
  )}
</div>
