---
/**
 * @sitegen
 * type: tool-registry
 * description: Interactive master-detail tool registry diagram with export support.
 * group: Architecture Sections
 */
/**
 * ToolRegistry — Interactive master-detail tool browser.
 *
 * Layout:
 *   LEFT (40%): all super-categories listed vertically. Each super-category
 *               has its label as a colored heading, followed by a row of
 *               bubble/pill buttons — one per module (Filesystem, Git, LLM,
 *               VectorDB, etc.). Everything is visible at once.
 *   RIGHT (60%): detail panel for the active bubble showing module title,
 *                subtitle, and all tool methods grouped by sub-heading.
 *
 * Interaction: single click on any bubble swaps the right panel. No tabs.
 * Accepts the same YAML shape as StructureDiagram `sections`, so existing
 * tool-registry data can be reused under the `groups` prop.
 */

import { cn } from '../lib/utils';

type Accent = 'cyan' | 'emerald' | 'amber' | 'red' | 'purple' | 'default';

interface Item {
  type?: 'ref' | 'bullet' | 'numbered' | 'arrow' | 'badge';
  text: string;
  suffix?: string;
  badge?: string;
}

interface CardBodySection {
  heading?: string;
  items: Array<string | Item>;
}

interface Card {
  title: string;
  subtitle?: string;
  accent?: Accent;
  body: CardBodySection[];
}

interface Group {
  number?: string;
  label: string;
  meta?: string;
  columns?: number; // ignored — kept for YAML compatibility
  cards: Card[];
}

interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  groups: Group[];
  exportId?: string;
}

const { kicker, title, subtitle, groups = [], exportId } = Astro.props;

const slugify = (s: string) =>
  (s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const _exportId = exportId || slugify(title);

function normalize(item: string | Item): Item {
  if (typeof item === 'string') return { type: 'bullet', text: item };
  return { type: item.type || 'bullet', text: item.text, suffix: item.suffix, badge: item.badge };
}

function cardCount(card: Card): number {
  return card.body.reduce((sum, s) => sum + (s.items?.length || 0), 0);
}

const accentTextClass: Record<Accent, string> = {
  cyan: 'text-cyan-400 dark:text-cyan-300',
  emerald: 'text-emerald-400 dark:text-emerald-300',
  amber: 'text-amber-400 dark:text-amber-300',
  red: 'text-red-400 dark:text-red-300',
  purple: 'text-purple-400 dark:text-purple-300',
  default: 'text-primary dark:text-cyan-300',
};

// Initial active item: first group, first card
const initialGroup = 0;
const initialCard = 0;
---

<section
  class="py-24 px-6 bg-background dark:bg-[#050505] border-b border-border dark:border-zinc-900"
  data-export-id={_exportId}
  data-export-title={title}
  data-export-kind="tool-registry"
>
  <div class="max-w-[1200px] mx-auto" data-tool-registry>
    {/* Header */}
    <div class="mb-10 text-center">
      {kicker && (
        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
          <span class="font-mono text-[10px] text-muted-foreground uppercase tracking-[0.2em]">{kicker}</span>
        </div>
      )}
      <h2 class="font-mono text-sm md:text-base font-semibold uppercase tracking-[0.2em] text-foreground dark:text-white">
        {title}
      </h2>
      {subtitle && (
        <p class="mt-2 text-xs md:text-sm text-muted-foreground dark:text-zinc-500 font-light">
          {subtitle}
        </p>
      )}
    </div>

    {/* Master-detail layout — left takes ~58% so bubbles have room to breathe */}
    <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-4 lg:gap-6 items-start">
      {/* LEFT: all categories + bubbles — full natural height, no scroll */}
      <aside class="border border-border dark:border-zinc-800 bg-card/20 dark:bg-[#070707]/60 p-5 md:p-6 space-y-6">
        {groups.map((g, gi) => {
          const accent = (g.cards[0]?.accent as Accent) || 'default';
          return (
            <div class="tr-group">
              <div class="flex items-center gap-2 mb-3">
                <span class={cn('w-1 h-1 rounded-full', `tr-group-dot-${accent}`)}></span>
                <span class={cn(
                  'font-mono text-[10px] font-semibold uppercase tracking-[0.18em]',
                  accentTextClass[accent],
                )}>
                  {g.label}
                </span>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {g.cards.map((c, ci) => {
                  const cAccent = (c.accent as Accent) || accent;
                  return (
                    <button
                      type="button"
                      class={cn(
                        'tr-cat group/bubble flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[11px] font-medium',
                        'border-border dark:border-zinc-800 bg-card/30 dark:bg-[#050505]/60',
                        'text-muted-foreground dark:text-zinc-400',
                        'hover:border-muted-foreground/60 dark:hover:border-zinc-600 hover:text-foreground dark:hover:text-white',
                        'transition-all whitespace-nowrap',
                      )}
                      data-group={gi}
                      data-card={ci}
                      data-accent={cAccent}
                      data-active={gi === initialGroup && ci === initialCard ? 'true' : 'false'}
                    >
                      <span class="tr-cat-dot w-1 h-1 rounded-full bg-muted-foreground/40 flex-shrink-0"></span>
                      <span>{c.title}</span>
                      <span class="tr-cat-count font-mono text-[9px] text-muted-foreground/60">{cardCount(c)}</span>
                    </button>
                  );
                })}
              </div>
            </div>
          );
        })}
      </aside>

      {/* RIGHT: detail panels — sticky so it stays visible as the left scrolls */}
      <div class="border border-border dark:border-zinc-800 bg-card/20 dark:bg-[#070707]/60 overflow-hidden lg:sticky lg:top-4 lg:max-h-[calc(100vh-2rem)] lg:overflow-y-auto">
        {groups.map((g, gi) =>
          g.cards.map((c, ci) => {
            const accent = (c.accent as Accent) || 'default';
            return (
              <div
                class="tr-detail p-6 md:p-8"
                data-group={gi}
                data-card={ci}
                data-active={gi === initialGroup && ci === initialCard ? 'true' : 'false'}
              >
                {/* Detail header */}
                <div class="mb-6 pb-4 border-b border-border/40 dark:border-zinc-800/60">
                  <div class="flex items-center gap-2 mb-2">
                    <span class={cn('w-1 h-1 rounded-full', `tr-group-dot-${accent}`)}></span>
                    <span class="font-mono text-[9px] text-muted-foreground/70 uppercase tracking-[0.15em]">
                      {g.label}
                    </span>
                  </div>
                  <div class="flex items-baseline gap-3 flex-wrap">
                    <h3 class={cn('text-xl font-medium tracking-tight', accentTextClass[accent])}>
                      {c.title}
                    </h3>
                    {c.subtitle && (
                      <span class="font-mono text-[10px] text-muted-foreground dark:text-zinc-500 uppercase tracking-[0.1em]">
                        {c.subtitle}
                      </span>
                    )}
                  </div>
                </div>

                {/* Body sections */}
                <div class="space-y-6">
                  {c.body.map((bodySection) => (
                    <div>
                      {bodySection.heading && (
                        <div class="font-mono text-[9px] text-muted-foreground/80 dark:text-zinc-500 uppercase tracking-[0.15em] mb-3">
                          {bodySection.heading}
                        </div>
                      )}
                      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5">
                        {bodySection.items.map((raw) => {
                          const item = normalize(raw);
                          const t = item.type;
                          return (
                            <li class="flex items-start gap-2 text-[12px] text-muted-foreground dark:text-zinc-400 leading-relaxed font-light">
                              {t === 'ref' && (
                                <span class={cn('font-mono flex-shrink-0 mt-[1px]', accentTextClass[accent])}>&rarr;</span>
                              )}
                              {t === 'arrow' && (
                                <span class="text-muted-foreground/60 font-mono flex-shrink-0 mt-[1px]">&rarr;</span>
                              )}
                              {t === 'bullet' && (
                                <span class="text-muted-foreground/60 font-mono flex-shrink-0 mt-[1px]">&middot;</span>
                              )}
                              {t === 'numbered' && (
                                <span class="font-mono text-[10px] text-muted-foreground/60 flex-shrink-0 mt-[2px] w-3">*</span>
                              )}
                              <span class="flex-1 min-w-0">
                                {t === 'ref' ? (
                                  <code class={cn('font-mono text-[12px]', accentTextClass[accent])}>{item.text}</code>
                                ) : (
                                  <span>{item.text}</span>
                                )}
                                {item.suffix && (
                                  <span class="text-muted-foreground/60 dark:text-zinc-600"> {item.suffix}</span>
                                )}
                                {item.badge && (
                                  <span class="ml-1.5 inline-block font-mono text-[9px] px-1.5 py-[1px] border border-border dark:border-zinc-700 text-muted-foreground/80 dark:text-zinc-500 rounded-sm">
                                    {item.badge}
                                  </span>
                                )}
                              </span>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            );
          })
        )}
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Hide inactive detail panels */
  [data-tool-registry] .tr-detail[data-active="false"] { display: none; }

  /* Group label dots */
  [data-tool-registry] .tr-group-dot-cyan { background: rgb(34 211 238); }
  [data-tool-registry] .tr-group-dot-emerald { background: rgb(52 211 153); }
  [data-tool-registry] .tr-group-dot-amber { background: rgb(251 191 36); }
  [data-tool-registry] .tr-group-dot-red { background: rgb(248 113 113); }
  [data-tool-registry] .tr-group-dot-purple { background: rgb(192 132 252); }
  [data-tool-registry] .tr-group-dot-default { background: hsl(var(--primary)); }

  /* Active bubble: filled background matching accent */
  [data-tool-registry] .tr-cat[data-active="true"] {
    color: hsl(var(--foreground));
    border-color: transparent;
  }
  .dark [data-tool-registry] .tr-cat[data-active="true"] {
    color: rgb(255 255 255);
  }

  [data-tool-registry] .tr-cat[data-active="true"][data-accent="cyan"] {
    background: rgba(34, 211, 238, 0.15);
    border-color: rgba(34, 211, 238, 0.6);
  }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="emerald"] {
    background: rgba(52, 211, 153, 0.15);
    border-color: rgba(52, 211, 153, 0.6);
  }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="amber"] {
    background: rgba(251, 191, 36, 0.15);
    border-color: rgba(251, 191, 36, 0.6);
  }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="red"] {
    background: rgba(248, 113, 113, 0.15);
    border-color: rgba(248, 113, 113, 0.6);
  }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="purple"] {
    background: rgba(192, 132, 252, 0.15);
    border-color: rgba(192, 132, 252, 0.6);
  }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="default"] {
    background: hsl(var(--primary) / 0.15);
    border-color: hsl(var(--primary) / 0.6);
  }

  /* Active bubble dot color */
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="cyan"] .tr-cat-dot { background: rgb(34 211 238); }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="emerald"] .tr-cat-dot { background: rgb(52 211 153); }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="amber"] .tr-cat-dot { background: rgb(251 191 36); }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="red"] .tr-cat-dot { background: rgb(248 113 113); }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="purple"] .tr-cat-dot { background: rgb(192 132 252); }
  [data-tool-registry] .tr-cat[data-active="true"][data-accent="default"] .tr-cat-dot { background: hsl(var(--primary)); }
</style>

<script>
  function initToolRegistry() {
    const registries = document.querySelectorAll('[data-tool-registry]');
    registries.forEach((root) => {
      if ((root as HTMLElement).dataset.trInit === 'true') return;
      (root as HTMLElement).dataset.trInit = 'true';

      root.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const bubble = target.closest('.tr-cat') as HTMLElement | null;
        if (!bubble) return;

        const gi = bubble.dataset.group!;
        const ci = bubble.dataset.card!;

        // Deactivate all bubbles, activate this one
        root.querySelectorAll<HTMLElement>('.tr-cat').forEach((b) => {
          b.dataset.active = b.dataset.group === gi && b.dataset.card === ci ? 'true' : 'false';
        });

        // Swap detail panels
        root.querySelectorAll<HTMLElement>('.tr-detail').forEach((d) => {
          d.dataset.active = d.dataset.group === gi && d.dataset.card === ci ? 'true' : 'false';
        });

        // Scroll right panel to top when switching
        const rightPanel = root.querySelector<HTMLElement>('.lg\\:max-h-\\[760px\\]:last-child');
        if (rightPanel) rightPanel.scrollTop = 0;
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initToolRegistry);
  } else {
    initToolRegistry();
  }
  document.addEventListener('astro:page-load', initToolRegistry);
</script>
