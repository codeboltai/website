---
/**
 * @sitegen
 * type: timeline
 * description: Chronological timeline section.
 * group: Content Sections
 */
const { entries = [] } = Astro.props;
---
<section class="py-24 px-6 bg-background dark:bg-[#050505] border-b border-border dark:border-zinc-900">
  <div class="max-w-5xl mx-auto">
    <div class="border border-border dark:border-zinc-800 bg-card/30 divide-y divide-border dark:divide-zinc-800">
      {entries.map((entry) => (
        <div class="p-8">
          <div class="flex items-center justify-between gap-6 mb-4">
            <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground dark:text-zinc-500">
              {entry.date}
            </span>
            <span class="px-2 py-1 border text-[10px] tracking-wider border-border bg-muted/20 text-muted-foreground">
              {entry.version}
            </span>
          </div>
          <p class="text-sm text-muted-foreground dark:text-zinc-400 leading-relaxed">
            {entry.summary}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
