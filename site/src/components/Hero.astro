---
import { cn } from '../lib/utils';

const { heading, subheading, eyebrow, headingAccent = [], buttons = [], media, installCommand, installLabel = 'Install' } = Astro.props;

let primaryBtn = buttons.find(b => b.variant === 'primary');
let secondaryBtn = buttons.find(b => b.variant === 'secondary');
const hasExplicitVariants = buttons.some(b => b.variant);
if (!hasExplicitVariants) {
  primaryBtn = buttons[0];
  secondaryBtn = buttons[1];
}
const hasMedia = Boolean(media);

let headingParts = null;
if (heading && Array.isArray(headingAccent) && headingAccent.length > 0) {
  const escaped = headingAccent.map(a => a.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
  const regex = new RegExp(`(${escaped.join('|')})`, 'g');
  headingParts = heading.split(regex).filter(p => p.length > 0).map(part => ({
    isAccent: headingAccent.includes(part),
    value: part,
  }));
}
---

<section class={cn(
  "has-rule-fill relative bg-background text-foreground border-b border-border font-sans antialiased overflow-hidden",
  "dark:bg-[#050505] dark:border-neutral-900"
)}>
  <div
    class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[500px] pointer-events-none blur-3xl"
    style="background: radial-gradient(ellipse at center, hsl(var(--primary) / 0.22), transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="px-6 relative z-10">
    <div class="mx-auto max-w-[1200px] px-6 pt-28 pb-12 md:px-10 md:pt-32 md:pb-16">
      <div class="max-w-4xl mx-auto text-center">

        {eyebrow && (
          <div class="mb-7 inline-flex items-center gap-2 border border-border/80 bg-background/70 px-3 py-1.5 backdrop-blur-sm dark:border-zinc-800 dark:bg-black/50 animate-fade-in-up">
            <span class="h-1.5 w-1.5 bg-primary animate-pulse"></span>
            <span class="text-[11px] font-mono uppercase tracking-[0.18em] text-muted-foreground">
              {eyebrow}
            </span>
          </div>
        )}

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-medium text-foreground dark:text-white tracking-tight mb-7 leading-[1.08] animate-fade-in-up">
          {headingParts ? headingParts.map(p => (
            p.isAccent
              ? <span class="inline-block whitespace-nowrap heading-accent">{p.value}</span>
              : <span>{p.value}</span>
          )) : heading}
        </h1>

        {subheading && (
          <p class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-3xl mx-auto mb-10 font-light animate-fade-in-up" style="animation-delay: 0.1s">
            {subheading}
          </p>
        )}

        {(primaryBtn || secondaryBtn) && (
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3 animate-fade-in-up" style="animation-delay: 0.2s">
            {primaryBtn && (
              <a href={primaryBtn.href} class={cn(
                "h-11 px-6 rounded-md inline-flex items-center justify-center text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary",
                "bg-primary text-primary-foreground hover:bg-primary/90",
                "shadow-[0_4px_14px_0_hsl(var(--primary)/0.35)] hover:shadow-[0_6px_20px_0_hsl(var(--primary)/0.45)] hover:-translate-y-0.5"
              )}>
                {primaryBtn.label}
                <svg class="ml-2 h-4 w-4" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M 0 6 H 12 M 9 3 L 12 6 L 9 9" />
                </svg>
              </a>
            )}
            {secondaryBtn && (
              <a href={secondaryBtn.href} class={cn(
                "h-11 px-6 rounded-md inline-flex items-center justify-center text-sm font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary",
                "border border-foreground/70 bg-background/40 text-foreground hover:bg-foreground hover:text-background"
              )}>
                {secondaryBtn.label}
              </a>
            )}
          </div>
        )}

        {installCommand && (
          <div class="mx-auto mt-5 flex max-w-xl items-center overflow-hidden border border-border bg-background/80 text-left shadow-sm backdrop-blur-sm dark:border-zinc-800 dark:bg-black/60 animate-fade-in-up" style="animation-delay: 0.25s">
            <div class="hidden shrink-0 border-r border-border px-3 py-3 font-mono text-[10px] uppercase tracking-widest text-muted-foreground dark:border-zinc-800 sm:block">
              {installLabel}
            </div>
            <code class="min-w-0 flex-1 overflow-x-auto whitespace-nowrap px-4 py-3 font-mono text-sm text-foreground dark:text-zinc-100">
              {installCommand}
            </code>
            <button
              type="button"
              class="hero-copy shrink-0 border-l border-border px-3 py-3 font-mono text-[10px] uppercase tracking-widest text-muted-foreground transition-colors hover:text-foreground dark:border-zinc-800"
              data-copy-text={installCommand}
            >
              Copy
            </button>
          </div>
        )}
      </div>

      {hasMedia && (
        <div class="max-w-5xl mx-auto mt-12 animate-fade-in-up" style="animation-delay: 0.3s">
          <div class="relative overflow-hidden border border-border bg-card/40 shadow-2xl shadow-black/10 dark:border-zinc-800 dark:bg-[#080808]/90 dark:shadow-black/50">
            <div class="flex h-9 items-center gap-2 border-b border-border bg-muted/20 px-4 dark:border-zinc-800 dark:bg-zinc-950/70">
              <span class="h-2.5 w-2.5 bg-red-500/70"></span>
              <span class="h-2.5 w-2.5 bg-yellow-500/70"></span>
              <span class="h-2.5 w-2.5 bg-green-500/70"></span>
              {media.label && (
                <span class="ml-3 truncate font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                  {media.label}
                </span>
              )}
            </div>

            <div class="relative aspect-[16/9] bg-background dark:bg-[#030303]">
              {media.src ? (
                <img
                  src={media.src}
                  alt={media.alt || 'Product demo'}
                  class="theme-aware-visual h-full w-full object-cover"
                  loading="eager"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="text-center">
                    <div class="mb-3 font-mono text-xs uppercase tracking-widest text-primary">
                      {media.placeholder || 'Product GIF'}
                    </div>
                    <div class="mx-auto h-2 w-48 overflow-hidden bg-muted dark:bg-zinc-900">
                      <div class="h-full w-1/2 bg-primary/70"></div>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.hero-copy').forEach((button) => {
    button.addEventListener('click', async () => {
      const text = button instanceof HTMLElement ? button.dataset.copyText : '';
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const previous = button.textContent || 'Copy';
        button.textContent = 'Copied';
        window.setTimeout(() => {
          button.textContent = previous;
        }, 1400);
      } catch {
        button.textContent = 'Copy';
      }
    });
  });
</script>
