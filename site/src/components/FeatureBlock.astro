---
/**
 * @sitegen
 * type: feature-block
 * description: Two-column feature section with text, media, diagram, and optional CTA.
 * group: Content Sections
 */
import { cn } from '../lib/utils';

const { heading, kicker, body, diagram, image, imageAlt, reverse = false, cta } = Astro.props;

const kickerParts = typeof kicker === 'string' ? kicker.split(' · ') : [];
const kickerNumber = kickerParts.length > 1 && /^\d+$/.test(kickerParts[0]) ? kickerParts[0] : null;
const kickerLabel = kickerNumber ? kickerParts.slice(1).join(' · ') : kicker;
---

<section class="py-16 lg:py-20 px-6 lg:px-10 border-b border-border dark:border-zinc-800/60 bg-background dark:bg-[#050505]">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center px-0 md:px-8">

    {/* Text Content */}
    <div class={cn('col-span-1 lg:col-span-5 flex flex-col', reverse && 'lg:order-last')}>
      {kicker && kickerNumber && (
        <div class="flex items-center gap-3 mb-6 w-full">
          <div class="inline-flex h-8 min-w-[2rem] items-center justify-center px-2 border border-primary/50 bg-primary/10 font-mono text-sm font-semibold text-primary">
            {kickerNumber}
          </div>
          <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-primary whitespace-nowrap">
            {kickerLabel}
          </span>
          <div class="flex-1 h-px bg-primary/20"></div>
        </div>
      )}
      {kicker && !kickerNumber && (
        <div class="inline-flex items-center gap-2 mb-5 px-3 py-1 rounded-full border border-primary/30 bg-primary/5 w-fit">
          <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{kicker}</span>
        </div>
      )}
      <h3 class="text-3xl md:text-4xl font-medium text-foreground tracking-tight leading-[1.12] mb-5 dark:text-zinc-100">
        {heading}
      </h3>
      <div class="space-y-4 text-base text-muted-foreground leading-relaxed dark:text-zinc-400">
        <p set:html={body}></p>
      </div>
      {cta && cta.href && (
        <a
          href={cta.href}
          class="mt-8 inline-flex w-fit items-center gap-2 text-sm font-medium text-foreground hover:text-primary transition-colors dark:text-zinc-100"
        >
          {cta.label}
          <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M 0 6 H 12 M 9 3 L 12 6 L 9 9" />
          </svg>
        </a>
      )}
    </div>

    {/* Diagram / Image Content */}
    <div class={cn('col-span-1 lg:col-span-7', reverse && 'lg:order-first')}>
      {image ? (
        <div class="relative w-full overflow-hidden rounded-sm">
          <img
            src={image}
            alt={imageAlt || heading || ''}
            class="theme-aware-visual w-full h-auto"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="relative w-full min-h-[360px] flex items-center justify-center bg-card border border-border rounded-sm overflow-hidden dark:bg-[#050505] dark:border-zinc-800/60 p-8">
          {/* Grid background */}
          <div
            class="absolute inset-0 opacity-20 dark:opacity-100 pointer-events-none bg-grid"
          />
          
          {/* Render diagram string as preformatted text */}
          <pre class="relative z-10 text-xs md:text-sm leading-relaxed font-mono text-muted-foreground whitespace-pre overflow-auto max-w-full">
            {diagram}
          </pre>
        </div>
      )}
    </div>

  </div>
</section>
