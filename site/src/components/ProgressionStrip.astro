---
/**
 * @sitegen
 * type: progression-strip
 * description: Horizontal sequence showing progression through steps or stages.
 * group: Content Sections
 */
interface Step {
  label: string;
  description: string;
  reference?: string;
}

interface Props {
  heading?: string;
  description?: string;
  kicker?: string;
  steps: Step[];
  tone?: 'default' | 'muted';
}

const {
  heading,
  description,
  kicker,
  steps = [],
  tone = 'default',
} = Astro.props;

const bgClass = tone === 'muted' ? 'bg-muted/10 dark:bg-zinc-900/20' : 'bg-background dark:bg-[#050505]';
const stepCount = steps.length;
---

<section class={`py-24 px-6 border-b border-border dark:border-zinc-900 ${bgClass}`}>
  <div class="max-w-[1200px] mx-auto">
    {(kicker || heading) && (
      <div class="mb-16">
        {kicker && (
          <div class="flex items-center gap-3 mb-6">
            <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
            <span class="font-mono text-[10px] text-muted-foreground uppercase tracking-widest">{kicker}</span>
          </div>
        )}
        {heading && <h2 class="text-3xl font-medium text-foreground tracking-tight mb-4">{heading}</h2>}
        {description && <p class="text-lg text-muted-foreground font-light max-w-2xl">{description}</p>}
      </div>
    )}

    <div class="relative">
      <!-- Connecting line (desktop: horizontal, mobile: vertical) -->
      <div class="hidden md:block absolute top-6 left-6 right-6 h-px bg-border dark:bg-zinc-800 z-0"></div>
      <div class="md:hidden absolute top-0 bottom-0 left-6 w-px bg-border dark:bg-zinc-800 z-0"></div>

      <div
        class="grid grid-cols-1 gap-10 md:gap-3 relative"
        style={`--step-count: ${stepCount}`}
      >
        <style>
          @media (min-width: 768px) {
            [style*="--step-count"] {
              grid-template-columns: repeat(var(--step-count), 1fr);
            }
          }
        </style>

        {steps.map((step: Step, i: number) => (
          <div class="relative flex md:flex-col items-start gap-4 md:items-center md:text-center">
            <!-- Node -->
            <div class="relative z-10 flex-shrink-0 w-12 h-12 border border-border dark:border-zinc-800 bg-card dark:bg-[#080808] flex items-center justify-center">
              <span class="font-mono text-xs text-primary dark:text-cyan-500">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>

            <!-- Content -->
            <div class="md:mt-4 flex-1">
              <h3 class="text-sm font-medium text-foreground dark:text-white mb-1">{step.label}</h3>
              <p class="text-xs text-muted-foreground dark:text-zinc-400 leading-relaxed">{step.description}</p>
              {step.reference && (
                <span class="inline-block mt-2 font-mono text-[10px] text-primary/80 dark:text-cyan-500/80 border border-primary/20 dark:border-cyan-800/30 px-2 py-0.5">
                  {step.reference}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
