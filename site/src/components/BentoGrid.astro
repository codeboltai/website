---
/**
 * BentoGrid — Asymmetric feature grid with mixed cell sizes.
 * Each item can span 1 or 2 columns, and optionally 2 rows.
 * Supports: title, description, href, links, image, visual (ASCII), visualHtml (rich HTML), tag badge.
 */
import { cn } from '../lib/utils';

interface BentoItem {
  title: string;
  description?: string;
  href?: string;
  links?: { label: string; href: string }[];
  image?: { src: string; alt?: string };
  visual?: string;       // ASCII/code diagram
  visualHtml?: string;   // Rich HTML content
  tag?: string;          // Small badge label
  span?: 1 | 2;         // Column span (default: 1)
  rowSpan?: 1 | 2;      // Row span (default: 1)
}

interface Props {
  heading?: string;
  description?: string;
  kicker?: string;
  items: BentoItem[];
  columns?: 2 | 3 | 4;
  tone?: 'default' | 'muted';
  gap?: 'none' | 'sm' | 'md';
}

const {
  heading,
  description,
  kicker,
  items = [],
  columns = 3,
  tone = 'default',
  gap = 'md',
} = Astro.props;

const gapClass: Record<string, string> = {
  none: 'gap-0',
  sm: 'gap-2',
  md: 'gap-4',
};

const bgClass = tone === 'muted' ? 'bg-muted/10 dark:bg-zinc-900/20' : 'bg-background dark:bg-[#050505]';

const gridClass: Record<number, string> = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
};

const spanClass = (span?: number) => {
  if (span === 2) return 'md:col-span-2';
  return '';
};

const rowSpanClass = (rowSpan?: number) => {
  if (rowSpan === 2) return 'md:row-span-2';
  return '';
};
---

<section class={cn('py-16 md:py-20 px-6 border-b border-border dark:border-zinc-900', bgClass)}>
  <div class="max-w-[1200px] mx-auto px-0 md:px-8">
    {(kicker || heading) && (
      <div class="mb-10 md:mb-12">
        {kicker && (
          <div class="flex items-center gap-3 mb-6">
            <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
            <span class="font-mono text-[10px] text-muted-foreground uppercase tracking-widest">{kicker}</span>
          </div>
        )}
        {heading && <h2 class="text-3xl md:text-4xl font-medium text-foreground tracking-tight mb-4">{heading}</h2>}
        {description && <p class="text-lg text-muted-foreground font-light max-w-2xl">{description}</p>}
      </div>
    )}

    <div class={cn('grid auto-rows-auto', gapClass[gap] || gapClass.md, gridClass[columns] || gridClass[3])}>
      {items.map((item: BentoItem) => {
        const hasInlineLinks = Array.isArray(item.links) && item.links.length > 0;
        const Tag = item.href && !hasInlineLinks ? 'a' : 'div';
        const linkProps = item.href && !hasInlineLinks ? { href: item.href } : {};
        return (
          <Tag
            {...linkProps}
            class={cn(
              'group relative border border-border bg-card',
              'transition-all duration-300 hover:border-primary/60 hover:shadow-[0_0_0_1px_hsl(var(--primary)/0.4)]',
              'flex flex-col overflow-hidden',
              item.href && !hasInlineLinks && 'cursor-pointer no-underline',
              spanClass(item.span),
              rowSpanClass(item.rowSpan),
            )}
          >
            {/* Text content */}
            <div class="p-6 flex-shrink-0">
              {item.tag && (
                <span class="inline-block font-mono text-[10px] text-primary uppercase tracking-widest mb-3">
                  {item.tag}
                </span>
              )}
              <h3 class="text-base font-medium text-foreground mb-2 tracking-tight">
                {item.title}
              </h3>
              {item.description && (
                <p
                  class="text-sm text-muted-foreground leading-relaxed [&_a]:inline-flex [&_a]:items-center [&_a]:rounded-sm [&_a]:border [&_a]:border-primary/30 [&_a]:bg-primary/10 [&_a]:px-1.5 [&_a]:py-0.5 [&_a]:font-medium [&_a]:text-primary [&_a]:no-underline [&_a]:transition-colors hover:[&_a]:border-primary/60 hover:[&_a]:bg-primary/15 hover:[&_a]:text-primary"
                  set:html={item.description}
                ></p>
              )}
              {item.href && (
                <span class="inline-block mt-3 text-xs font-mono text-primary group-hover:underline">
                  Learn more &rarr;
                </span>
              )}
              {hasInlineLinks && (
                <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2">
                  {item.links?.map((link) => (
                    <a
                      href={link.href}
                      class="inline-flex items-center gap-1 text-xs font-mono text-primary hover:underline"
                    >
                      {link.label}
                      <span aria-hidden="true">&rarr;</span>
                    </a>
                  ))}
                </div>
              )}
            </div>

            {/* Visual area */}
            {(item.image || item.visual || item.visualHtml) && (
              <div class="flex-1 min-h-[140px] bg-muted/40 border-t border-border flex items-center justify-center p-4 overflow-hidden">
                {item.image ? (
                  <img src={item.image.src} alt={item.image.alt || item.title} class="theme-aware-visual h-full max-h-[220px] w-full object-contain" loading="lazy" />
                ) : item.visualHtml ? (
                  <div class="w-full h-full" set:html={item.visualHtml} />
                ) : (
                  <pre class="text-[10px] leading-tight font-mono text-muted-foreground/80 whitespace-pre overflow-auto max-w-full max-h-full">
                    {item.visual}
                  </pre>
                )}
              </div>
            )}
          </Tag>
        );
      })}
    </div>
  </div>
</section>
