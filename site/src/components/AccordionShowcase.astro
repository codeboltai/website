---
const { kicker, heading, subtitle, items = [], visual, visualLabel } = Astro.props;
---

<section class="py-16 md:py-20 px-6 bg-background dark:bg-[#050505] text-foreground border-b border-border dark:border-zinc-900">
  <div class="max-w-[1200px] mx-auto px-0 md:px-8">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-5">
        {(kicker || heading || subtitle) && (
          <div class="mb-8">
            {kicker && (
              <div class="flex items-center gap-3 mb-6">
                <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
                <span class="font-mono text-[10px] text-muted-foreground uppercase tracking-widest">{kicker}</span>
              </div>
            )}
            {heading && (
              <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-4 leading-[1.12]">
                {heading}
              </h2>
            )}
            {subtitle && (
              <p class="text-base md:text-lg text-muted-foreground font-light leading-relaxed">
                {subtitle}
              </p>
            )}
          </div>
        )}

        <div class="accordion-showcase border-x border-t border-border dark:border-zinc-800">
          {items.map((item, index) => (
            <div class={`accordion-showcase-item border-b border-border dark:border-zinc-800 bg-card/30 ${index === 0 ? 'open' : ''}`}>
              <button type="button" class="accordion-showcase-trigger w-full px-5 py-5 text-left flex items-center justify-between gap-5 hover:bg-accent/50 transition-colors">
                <span>
                  <span class="text-base font-medium text-foreground">
                    {item.question}
                  </span>
                </span>
                <svg class="accordion-showcase-chevron w-5 h-5 shrink-0 text-muted-foreground transition-transform duration-200" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 8l4 4 4-4" />
                </svg>
              </button>
              <div class="accordion-showcase-content overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out">
                <div class="px-5 pb-5">
                  <p class="text-sm text-muted-foreground leading-relaxed">
                    {item.answer}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="lg:sticky lg:top-24 border border-border bg-card/40 dark:border-zinc-800 dark:bg-[#080808] overflow-hidden">
          <div class="flex h-10 items-center gap-2 border-b border-border bg-muted/20 px-4 dark:border-zinc-800 dark:bg-zinc-950/70">
            <span class="h-2 w-2 bg-zinc-700"></span>
            <span class="h-2 w-2 bg-zinc-700"></span>
            <span class="h-2 w-2 bg-zinc-700"></span>
            {visualLabel && (
              <span class="ml-3 truncate font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                {visualLabel}
              </span>
            )}
          </div>
          <div class="relative min-h-[420px] bg-[#030303] p-6 md:p-8 flex items-center justify-center">
            <div class="absolute inset-0 bg-grid opacity-70"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_65%_25%,hsl(var(--primary)/0.18),transparent_35%)]"></div>
            <pre class="relative z-10 w-full overflow-auto whitespace-pre text-[11px] md:text-xs leading-relaxed font-mono text-zinc-300">{visual}</pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .accordion-showcase-item.open .accordion-showcase-content { max-height: 220px; }
  .accordion-showcase-item.open .accordion-showcase-chevron { transform: rotate(180deg); }
</style>

<script>
  document.querySelectorAll('.accordion-showcase').forEach((accordion) => {
    accordion.querySelectorAll('.accordion-showcase-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.accordion-showcase-item');
        if (!item) return;
        const wasOpen = item.classList.contains('open');
        accordion.querySelectorAll('.accordion-showcase-item').forEach((otherItem) => {
          otherItem.classList.remove('open');
        });
        if (!wasOpen) {
          item.classList.add('open');
        }
      });
    });
  });
</script>
