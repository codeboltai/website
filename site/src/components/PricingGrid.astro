---
/**
 * @sitegen
 * type: pricing-grid
 * description: Pricing cards with plan details and actions.
 * group: Conversion Sections
 */
import { cn } from '../lib/utils';

const { cards = [] } = Astro.props;
---

<section class="bg-card text-foreground py-24 px-4 md:px-8 border-t border-border">
  <div class="max-w-7xl mx-auto">
    <div class={cn(
      'grid border border-border',
      cards.length === 3 ? 'grid-cols-1 lg:grid-cols-3' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4'
    )}>
      {cards.map((plan, idx) => (
        <div class={cn(
          'relative flex flex-col border-r border-b lg:border-b-0 border-border p-8 lg:p-12 transition-colors duration-300',
          plan.featured ? 'bg-primary/5 border-primary/30' : 'bg-card/50',
          idx === cards.length - 1 && 'border-r-0'
        )}>
          {/* Label badge */}
          {plan.badge && (
            <div class={cn(
              'absolute top-0 right-0 border-l border-b border-border px-3 py-1.5',
              plan.featured ? 'bg-primary text-primary-foreground' : 'bg-muted text-foreground'
            )}>
              <span class="text-[9px] font-sans uppercase tracking-widest font-bold">
                {plan.badge}
              </span>
            </div>
          )}

          {/* Plan info */}
          <div class="mb-16">
            <h3 class="text-xl font-medium text-foreground mb-2">{plan.tier}</h3>
            <p class="text-sm text-muted-foreground font-sans min-h-[40px] leading-relaxed max-w-xs">
              {plan.for}
            </p>
          </div>

          {/* Price */}
          <div class="mb-12">
            <div class="flex items-baseline gap-1">
              <span class="text-5xl lg:text-6xl font-light text-foreground tracking-tighter">
                {plan.price}
              </span>
              {plan.price_sub && (
                <span class="text-lg text-muted-foreground font-light">{plan.price_sub}</span>
              )}
            </div>
          </div>

          {/* Features */}
          <div class="flex-1 mb-16">
            <ul class="space-y-3">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3 group/item">
                  <div class="mt-1.5 w-1 h-1 shrink-0 transition-colors bg-primary" />
                  <span class="text-sm text-muted-foreground font-sans leading-relaxed group-hover/item:text-foreground transition-colors">
                    {feature}
                  </span>
                </li>
              ))}
            </ul>
          </div>

          {/* CTA */}
          <div class="mt-auto">
            <a
              href={plan.cta.href}
              class={cn(
                'w-full py-4 text-sm uppercase font-semibold font-sans border transition-all duration-200 flex items-center justify-center',
                plan.featured
                  ? 'bg-primary text-primary-foreground border-primary hover:bg-cyan-400'
                  : 'bg-foreground text-background border-foreground hover:bg-foreground/90'
              )}
            >
              {plan.cta.label}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
