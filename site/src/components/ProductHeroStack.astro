---
/**
 * @sitegen
 * type: product-hero-stack
 * description: Product hero with stacked feature cards and optional media.
 * group: Hero Sections
 */
import { cn } from '../lib/utils';

interface Button {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary';
}

interface StackItem {
  label: string;
  value?: string;
  text?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  buttons?: Button[];
  stackTitle?: string;
  stackItems?: StackItem[];
  footer?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  buttons = [],
  stackTitle,
  stackItems = [],
  footer,
} = Astro.props;

const primaryBtn = buttons.find((button: Button) => button.variant === 'primary') || buttons[0];
const secondaryBtn = buttons.find((button: Button) => button.variant === 'secondary') || buttons[1];
---

<section class="relative overflow-hidden border-b border-border bg-background text-foreground dark:border-neutral-900 dark:bg-[#050505]">
  <div class="mx-auto max-w-[1200px] border-x border-border px-6 py-28 dark:border-zinc-900 md:px-10 lg:py-32">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-7">
        {eyebrow && (
          <div class="mb-7 flex items-center gap-3">
            <span class="h-1.5 w-1.5 bg-primary"></span>
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted-foreground">{eyebrow}</span>
          </div>
        )}

        <h1 class="max-w-4xl text-5xl font-medium leading-[1.02] tracking-tight text-foreground dark:text-white md:text-6xl lg:text-7xl">
          {title}
        </h1>

        {subtitle && (
          <p class="mt-7 max-w-2xl text-base leading-relaxed text-muted-foreground md:text-lg dark:text-zinc-400">
            {subtitle}
          </p>
        )}

        {(primaryBtn || secondaryBtn) && (
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            {primaryBtn && (
              <a href={primaryBtn.href} class={cn(
                'inline-flex h-10 items-center justify-center border px-5 text-sm font-semibold transition-colors',
                'border-primary bg-primary text-primary-foreground hover:bg-primary/90'
              )}>
                {primaryBtn.label}
              </a>
            )}
            {secondaryBtn && (
              <a href={secondaryBtn.href} class={cn(
                'inline-flex h-10 items-center justify-center border px-5 text-sm font-semibold transition-colors',
                'border-border bg-background text-foreground hover:border-muted-foreground/70 dark:border-zinc-800 dark:bg-[#050505]'
              )}>
                {secondaryBtn.label}
              </a>
            )}
          </div>
        )}
      </div>

      <div class="lg:col-span-5">
        <div class="relative border border-border bg-card/40 dark:border-zinc-800 dark:bg-[#080808]">
          <div class="absolute inset-0 bg-grid opacity-60"></div>
          <div class="relative z-10">
            {stackTitle && (
              <div class="border-b border-border px-5 py-4 font-mono text-[10px] uppercase tracking-widest text-muted-foreground dark:border-zinc-800">
                {stackTitle}
              </div>
            )}
            <div class="divide-y divide-border dark:divide-zinc-800">
              {stackItems.map((item: StackItem) => (
                <div class="grid grid-cols-12 gap-4 px-5 py-4">
                  <div class="col-span-5 font-mono text-[10px] uppercase tracking-widest text-primary">
                    {item.label}
                  </div>
                  <div class="col-span-7 text-sm leading-relaxed text-muted-foreground dark:text-zinc-300">
                    {item.value || item.text}
                  </div>
                </div>
              ))}
            </div>
            {footer && (
              <div class="border-t border-border px-5 py-4 text-xs leading-relaxed text-muted-foreground dark:border-zinc-800">
                {footer}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
