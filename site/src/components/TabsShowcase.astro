---
const { kicker, heading, subtitle, tabs = [] } = Astro.props;
const id = `tabs-${Math.random().toString(36).slice(2)}`;
---

<section class="py-16 md:py-20 px-6 bg-background dark:bg-[#050505] text-foreground border-b border-border dark:border-zinc-900">
  <div class="max-w-[1200px] mx-auto px-0 md:px-8">
    {(kicker || heading || subtitle) && (
      <div class="mb-10 max-w-3xl">
        {kicker && (
          <div class="flex items-center gap-3 mb-6">
            <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
            <span class="font-mono text-[10px] text-muted-foreground uppercase tracking-widest">{kicker}</span>
          </div>
        )}
        {heading && (
          <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-4 leading-[1.12]">
            {heading}
          </h2>
        )}
        {subtitle && (
          <p class="text-base md:text-lg text-muted-foreground font-light leading-relaxed">
            {subtitle}
          </p>
        )}
      </div>
    )}

    <div class="tabs-showcase border border-border bg-card/30 dark:border-zinc-800 dark:bg-[#080808]" data-tabs-id={id}>
      <div class="flex flex-wrap border-b border-border dark:border-zinc-800">
        {tabs.map((tab, index) => (
          <button
            type="button"
            class={`tabs-showcase-trigger border-r border-border px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest transition-colors dark:border-zinc-800 ${index === 0 ? 'active bg-primary/10 text-primary' : 'text-muted-foreground hover:text-foreground'}`}
            data-tab-index={index}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12">
        <div class="border-b border-border p-6 dark:border-zinc-800 lg:col-span-4 lg:border-b-0 lg:border-r">
          {tabs.map((tab, index) => (
            <div class={`tabs-showcase-copy ${index === 0 ? 'block' : 'hidden'}`} data-tab-panel={index}>
              {tab.tag && (
                <div class="mb-4 font-mono text-[10px] uppercase tracking-widest text-primary">{tab.tag}</div>
              )}
              <h3 class="text-2xl font-medium tracking-tight text-foreground dark:text-white">{tab.title}</h3>
              <p class="mt-4 text-sm leading-relaxed text-muted-foreground">{tab.description}</p>
              {tab.points && (
                <ul class="mt-6 space-y-3">
                  {tab.points.map((point) => (
                    <li class="flex gap-3 text-sm leading-relaxed text-muted-foreground">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 bg-primary"></span>
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>

        <div class="relative min-h-[380px] bg-[#030303] p-6 md:p-8 lg:col-span-8">
          <div class="absolute inset-0 bg-grid opacity-70"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_65%_25%,hsl(var(--primary)/0.16),transparent_36%)]"></div>
          {tabs.map((tab, index) => (
            <div class={`tabs-showcase-visual relative z-10 h-full ${index === 0 ? 'flex' : 'hidden'} items-center justify-center`} data-tab-visual={index}>
              {tab.image ? (
                <img src={tab.image.src} alt={tab.image.alt || tab.title} class="max-h-full w-full object-contain" loading="lazy" />
              ) : (
                <div class="w-full border border-zinc-800 bg-black/70">
                  <div class="flex h-9 items-center gap-2 border-b border-zinc-800 bg-[#090909] px-4">
                    <span class="h-2 w-2 bg-zinc-700"></span>
                    <span class="h-2 w-2 bg-zinc-700"></span>
                    <span class="h-2 w-2 bg-zinc-700"></span>
                    <span class="ml-3 font-mono text-[10px] uppercase tracking-widest text-zinc-500">{tab.label}</span>
                  </div>
                  <pre class="min-h-[280px] overflow-auto whitespace-pre p-6 font-mono text-[11px] leading-relaxed text-zinc-300">{tab.visual}</pre>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.tabs-showcase').forEach((root) => {
    const triggers = root.querySelectorAll('.tabs-showcase-trigger');
    const copies = root.querySelectorAll('.tabs-showcase-copy');
    const visuals = root.querySelectorAll('.tabs-showcase-visual');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const index = trigger instanceof HTMLElement ? trigger.dataset.tabIndex : '0';
        triggers.forEach((item) => {
          item.classList.remove('active', 'bg-primary/10', 'text-primary');
          item.classList.add('text-muted-foreground');
        });
        trigger.classList.add('active', 'bg-primary/10', 'text-primary');
        trigger.classList.remove('text-muted-foreground');

        copies.forEach((panel) => {
          panel.classList.toggle('hidden', panel.getAttribute('data-tab-panel') !== index);
          panel.classList.toggle('block', panel.getAttribute('data-tab-panel') === index);
        });
        visuals.forEach((panel) => {
          panel.classList.toggle('hidden', panel.getAttribute('data-tab-visual') !== index);
          panel.classList.toggle('flex', panel.getAttribute('data-tab-visual') === index);
        });
      });
    });
  });
</script>
