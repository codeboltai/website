---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, navigation } from '../data/site-data.js';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Terms of Service — Codebolt" navbarVariant="solid" site={site} navigation={navigation}>
  <PageHeader
    title="Terms of Service"
    subtitle="Please read these terms carefully before using Codebolt."
  />

  <section class="py-16 md:py-20 px-6 bg-background dark:bg-[#050505]">
    <div class="max-w-4xl mx-auto">

      <div class="mb-12 flex items-center gap-3 border border-border dark:border-zinc-800 bg-card dark:bg-[#0a0a0a] p-5">
        <svg class="w-5 h-5 text-warning flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <div>
          <p class="font-semibold text-foreground dark:text-white text-sm">Important Notice</p>
          <p class="text-sm text-muted-foreground dark:text-zinc-400 mt-1">
            By accessing and using Codebolt, you accept and agree to be bound by the terms and provisions of this agreement. If you do not agree to abide by these terms, you are not authorized to use or access Codebolt.
          </p>
        </div>
      </div>

      <p class="text-sm text-muted-foreground dark:text-zinc-500 mb-12 flex items-center gap-2">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Last updated: May 12, 2026
      </p>

      <div class="space-y-12">

        <!-- 1. Acceptance of Terms -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">01</span>
            Acceptance of Terms
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              Welcome to Codebolt. These Terms of Service ("Terms") govern your use of our AI-powered agent engine, code editor, and related services (the "Service") operated by CodeboltAI ("we", "us", or "our").
            </p>
            <p>
              By accessing or using our Service, you agree to be bound by these Terms. If you disagree with any part of these terms, then you may not access the Service.
            </p>
          </div>
        </article>

        <!-- 2. Description of Service -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">02</span>
            Description of Service
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              Codebolt provides an AI-powered agent engine and development platform that helps developers build, deploy, and orchestrate autonomous coding agents.
            </p>
            <p>Our Service includes but is not limited to:</p>
            <ul class="list-none space-y-2 pl-0">
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                AI-assisted code generation, completion, and debugging
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Multi-agent orchestration and coordination
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Autonomous agent deployment (CLI, desktop, and cloud)
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                SDK for building custom agents and extensions
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Integration with development tools, platforms, and MCP servers
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Dynamic, scalable, and evolving memory subsystems
              </li>
            </ul>
          </div>
        </article>

        <!-- 3. User Accounts -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">03</span>
            User Accounts
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              To access certain features of the Service, you may be required to create an account. You are responsible for:
            </p>
            <ul class="list-none space-y-2 pl-0">
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Maintaining the confidentiality of your account credentials
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                All activities that occur under your account
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Providing accurate and complete information during registration
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Promptly updating your account information when necessary
              </li>
            </ul>
          </div>
        </article>

        <!-- 4. Acceptable Use -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">04</span>
            Acceptable Use
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              You agree to use the Service only for lawful purposes and in accordance with these Terms. You agree not to:
            </p>
            <ul class="list-none space-y-2 pl-0">
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Use the Service for any illegal or unauthorized purpose
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Violate any applicable laws or regulations
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Infringe upon the intellectual property rights of others
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Transmit malicious code, viruses, or harmful content
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Attempt to gain unauthorized access to our systems or other users' accounts
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Reverse engineer, decompile, or attempt to extract source code of the Service
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Use the Service to generate code or content that violates applicable law or the rights of others
              </li>
            </ul>
          </div>
        </article>

        <!-- 5. Intellectual Property -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">05</span>
            Intellectual Property
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              The Service and its original content, features, and functionality are and will remain the exclusive property of CodeboltAI and its licensors. The Service is protected by copyright, trademark, and other laws of both the United States and foreign countries.
            </p>
            <p>
              <strong class="text-foreground dark:text-white">Your Code, Your Ownership.</strong> You retain full ownership of any code you create using our Service. Codebolt does not claim any ownership rights over your code.
            </p>
            <p>
              By using our AI features, you grant us a limited, non-exclusive license to process and analyze your code solely for the purpose of providing the Service. We do not use your code to train our models or for any other purpose beyond delivering the Service to you.
            </p>
          </div>
        </article>

        <!-- 6. Privacy and Data Protection -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">06</span>
            Privacy and Data Protection
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              Your privacy is important to us. Our <a href="/privacy" class="text-primary hover:underline">Privacy Policy</a> also governs your use of the Service and explains how we collect, use, and protect your information.
            </p>
            <p>
              We implement industry-standard security measures to protect your personal information and code against unauthorized access, alteration, disclosure, or destruction.
            </p>
          </div>
        </article>

        <!-- 7. Subscription and Payment -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">07</span>
            Subscription and Payment
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              Some features of the Service may require a paid subscription. By purchasing a subscription, you agree to pay all applicable fees and charges in accordance with the pricing terms applicable to your plan.
            </p>
            <p>
              Subscription fees are billed in advance and are non-refundable except as required by applicable law or as specifically stated in these Terms. We reserve the right to change our pricing at any time, with reasonable notice provided to existing subscribers.
            </p>
          </div>
        </article>

        <!-- 8. Open Source Components -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">08</span>
            Open Source Components
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              Codebolt's SDK and certain tools may include or be distributed as open source software. Such components are governed by their respective open source licenses, which are included in the applicable repositories. Your use of open source components is subject to the terms of those licenses.
            </p>
          </div>
        </article>

        <!-- 9. Limitation of Liability -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">09</span>
            Limitation of Liability
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              In no event shall CodeboltAI, nor its directors, employees, partners, agents, suppliers, or affiliates, be liable for any indirect, incidental, special, consequential, or punitive damages, including without limitation, loss of profits, data, use, goodwill, or other intangible losses, resulting from:
            </p>
            <ul class="list-none space-y-2 pl-0">
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Your access to or use of (or inability to access or use) the Service
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Any conduct or content of any third party on the Service
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Any content obtained from the Service
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 bg-primary flex-shrink-0"></span>
                Unauthorized access, use, or alteration of your transmissions or content
              </li>
            </ul>
          </div>
        </article>

        <!-- 10. Disclaimer of Warranties -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">10</span>
            Disclaimer of Warranties
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              The Service is provided on an "AS IS" and "AS AVAILABLE" basis. CodeboltAI makes no warranties, expressed or implied, and hereby disclaims all warranties, including without limitation, implied warranties of merchantability, fitness for a particular purpose, and non-infringement.
            </p>
            <p>
              CodeboltAI does not warrant that the Service will function uninterrupted, secure, or error-free, that defects will be corrected, or that the Service or the server that makes it available are free of viruses or other harmful components.
            </p>
          </div>
        </article>

        <!-- 11. Indemnification -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">11</span>
            Indemnification
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              You agree to defend, indemnify, and hold harmless CodeboltAI and its licensee and licensors, and their employees, contractors, agents, officers, and directors, from and against any and all claims, damages, obligations, losses, liabilities, costs, or debt arising from your use of the Service or your violation of these Terms.
            </p>
          </div>
        </article>

        <!-- 12. Termination -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">12</span>
            Termination
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              We may terminate or suspend your account and bar access to the Service immediately, without prior notice or liability, under our sole discretion, for any reason, including but not limited to a breach of these Terms.
            </p>
            <p>
              If you wish to terminate your account, you may discontinue using the Service and contact us to request account deletion. Upon termination, your right to use the Service will immediately cease.
            </p>
          </div>
        </article>

        <!-- 13. Governing Law -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">13</span>
            Governing Law
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              These Terms shall be governed by and construed in accordance with the laws of the United States, without regard to its conflict of law provisions. Any disputes arising under or in connection with these Terms shall be subject to the exclusive jurisdiction of the courts located in the applicable jurisdiction.
            </p>
          </div>
        </article>

        <!-- 14. Changes to Terms -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">14</span>
            Changes to Terms
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              We reserve the right, at our sole discretion, to modify or replace these Terms at any time. If a revision is material, we will provide at least 30 days' notice prior to any new terms taking effect. What constitutes a material change will be determined at our sole discretion.
            </p>
            <p>
              By continuing to access or use our Service after revisions become effective, you agree to be bound by the revised terms. If you do not agree to the new terms, you are no longer authorized to use the Service.
            </p>
          </div>
        </article>

        <!-- 15. Contact Information -->
        <article class="terms-section">
          <h2 class="text-xl font-semibold text-foreground dark:text-white mb-4 flex items-baseline gap-3">
            <span class="font-mono text-xs text-primary tracking-widest">15</span>
            Contact Information
          </h2>
          <div class="space-y-4 text-muted-foreground dark:text-zinc-400 leading-relaxed">
            <p>
              If you have any questions about these Terms of Service, please contact us:
            </p>
            <div class="border border-border dark:border-zinc-800 bg-card dark:bg-[#0a0a0a] p-5 space-y-2">
              <p class="text-foreground dark:text-white">
                <strong>Email:</strong> <a href="mailto:legal@codebolt.ai" class="text-primary hover:underline">legal@codebolt.ai</a>
              </p>
              <p class="text-foreground dark:text-white">
                <strong>Address:</strong> CodeboltAI Legal Department
              </p>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .terms-section {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }
  .terms-section:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
</style>
