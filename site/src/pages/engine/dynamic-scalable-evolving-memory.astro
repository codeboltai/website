---
// Auto-generated from site content. Edit source content and regenerate.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, navigation } from '../../data/site-data.js';
import ProductHeroStack from '../../components/ProductHeroStack.astro';
import CenteredText from '../../components/CenteredText.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import AccordionShowcase from '../../components/AccordionShowcase.astro';
import TabsShowcase from '../../components/TabsShowcase.astro';
import CtaBlock from '../../components/CtaBlock.astro';
---
<BaseLayout title="Dynamic Scalable Evolving Memory - Codebolt" navbarVariant="solid" site={site} navigation={navigation}>
  <ProductHeroStack
    eyebrow="DYNAMIC SCALABLE EVOLVING MEMORY"
    title="A memory substrate agents can grow, reshape, and inject at runtime"
    subtitle="Codebolt memory is not a fixed conversation summary. It is an active engine layer that can ingest chats, code, prompts, tasks, events, and relationships; create new memory structures; evolve context rules; and inject the right memory into each agent run under budget."
    buttons={[{"label":"Explore Architecture","href":"/architecture","variant":"primary"},{"label":"Back to Engine","href":"/engine","variant":"secondary"}]}
    stackTitle="Memory runtime"
    stackItems={[{"label":"Scalable","value":"memory grows as the system is used"},{"label":"Dynamic","value":"memory structures are primitives, not fixed schemas"},{"label":"Evolving","value":"agents can change structures and context rules"},{"label":"Injectable","value":"CAE injects memory by rules and budgets"},{"label":"Active","value":"background memory processes keep working"},{"label":"Reactive","value":"hooks and events trigger memory updates"}]}
    footer="The memory layer is part of the engine runtime, not a prompt appendix."
  />
  <CenteredText
    variant="thesis"
    text="Most agent memory products start with a fixed shape: summaries, preferences, key points, maybe mistakes. Codebolt ships memory primitives. You can decide what memory means for a project: unfinished tasks, negative patterns, positive patterns, object relationships, code facts, prompt behavior, agent habits, customer context, or a structure no one anticipated when the agent started."
  />
  <BentoGrid
    kicker="SIX MEMORY PROPERTIES"
    heading="Dynamic, scalable, evolving memory"
    description="The important part is not only that agents remember. It is that the memory substrate can grow, restructure, react, and decide what should enter context."
    columns={3}
    items={[{"title":"Scalable memory","tag":"SCALABLE","span":2,"description":"Memory grows as Codebolt is used. Agent chats, code changes, prompts, tool traces, tasks, decisions, failures, and relationships can be ingested into durable stores and converted into useful structures such as positive patterns, negative patterns, object relationships, unresolved work, and project facts.","visual":"usage keeps producing signal\n├─ chats\n├─ code\n├─ prompts\n├─ tools\n├─ tasks\n└─ events\n      ↓\nmemory keeps compounding\n"},{"title":"Dynamic structures","tag":"DYNAMIC","description":"The memory shape is not predefined by Codebolt. If you do not want conversation summaries, skip them. If you only want unfinished tasks, create that memory. If you need object graphs, failure patterns, or domain-specific state, define those instead."},{"title":"Evolving schemas and rules","tag":"EVOLVING","description":"Agents can change memory structures at runtime. They can create new memory definitions, adjust ingestion, improve retrieval pipelines, and add Context Assembly rules that control what future agents receive."},{"title":"Injectable context","tag":"INJECTABLE","description":"Memory does not blindly flood the prompt. The Context Assembly Engine injects memory by scope variables, rules, retrieval pipelines, contribution rules, and token budgets."},{"title":"Active and reactive memory","tag":"ACTIVE","span":2,"description":"Memory work can run in the background and react to the system. Hooks, events, schedules, task outcomes, conversation lifecycle events, and custom plugins can trigger ingestion, updates, consolidation, and new derived memory.","visual":"event happens\n      ↓\nhook / ingestion pipeline\n      ↓\nupdate memory\n      ↓\nCAE changes future context\n\nmemory is not passive storage\n"}]}
  />
  <FeatureBlock
    kicker="01 · MEMORY PRIMITIVES"
    heading="Not one memory format. A system for creating memory formats."
    body="Codebolt separates memory into primitives: storage types, ingestion pipelines, retrieval pipelines, context rules, contribution rules, and budgets. Together they let a project define the memory it actually needs instead of accepting a fixed vendor schema."
    diagram={`YOU CAN DEFINE:
├─ unfinished tasks memory
├─ negative pattern memory
├─ positive pattern memory
├─ object relationship memory
├─ codebase fact memory
├─ prompt behavior memory
└─ domain-specific memory

USING PRIMITIVES:
├─ episodic logs
├─ persistent memory definitions
├─ vector search
├─ knowledge graph
├─ key-value state
├─ ingestion pipelines
├─ retrieval pipelines
└─ context assembly rules
`}
  />
  <AccordionShowcase
    kicker="RUNTIME EVOLUTION"
    heading="How memory changes while the system runs"
    description="The memory layer can collect signal, derive structures, modify schemas, and change injection behavior without waiting for a new product release."
    visual={{"label":"Dynamic memory loop","code":"observe work\n      |\n      v\ncreate / update structures\n      |\n      v\nadd rules + pipelines\n      |\n      v\ninject under budget\n      |\n      v\nfuture agents inherit\n"}}
    items={[{"question":"Scale from raw usage","answer":"The memory system can consume agent chat, code, prompts, tool results, task state, project files, application events, and plugin events. Over time that raw usage becomes structured project intelligence."},{"question":"Create new structures","answer":"A project can add new persistent memory definitions for the exact shape it needs: unfinished tasks, issue clusters, component relationships, repeated user corrections, agent mistakes, winning strategies, or business-specific entities."},{"question":"Change structures at runtime","answer":"Because memory structures are engine primitives, agents and plugins can update schemas, ingestion behavior, and retrieval pipelines while work is happening. The structure of memory can evolve with the problem."},{"question":"Control injection","answer":"Context Assembly rules determine which memories are injected for a given agent, task, phase, thread, project, user, or swarm. Memory is selected and budgeted before it enters the prompt."},{"question":"React in the background","answer":"Hooks, events, schedules, and lifecycle triggers can run memory work without a user prompt. Memory can consolidate, update relationships, record failures, and prepare future context while agents continue working."}]}
  />
  <TabsShowcase
    kicker="WHAT CAN MEMORY BECOME"
    heading="The memory shape is programmable"
    description="Codebolt can support normal chat memory, but the stronger idea is that memory can become whatever durable intelligence the agent system needs."
    tabs={[{"label":"Patterns","title":"Positive and negative pattern memory","body":"Track what works and what fails. Agents can record repeated mistakes, constraints that were missed, review feedback, successful approaches, and patterns that should influence future work.","points":["Negative patterns: failed assumptions, repeated bugs, bad plans","Positive patterns: validated approaches, successful workflows","Useful for self-correction and agent evaluation"],"visual":{"label":"pattern memory","code":"mistake_pattern\n├─ trigger\n├─ evidence\n├─ correction\n└─ inject_when\n"}},{"label":"Tasks","title":"Unfinished work memory","body":"Instead of summarizing every conversation, a project can keep memory focused on open loops: unfinished tasks, blocked decisions, abandoned branches, stale todos, skipped tests, and follow-up actions.","points":["Created from chats, plans, TODOs, jobs, commits, and events","Injected only when relevant to the current task or file","Useful for long-running autonomous work"],"visual":{"label":"unfinished tasks","code":"open_loop\n├─ task\n├─ blocker\n├─ owner\n└─ next_action\n"}},{"label":"Objects","title":"Object relationship memory","body":"Memory can become a relationship graph for code, product, people, tasks, agents, files, APIs, prompts, business objects, or any domain-specific entity.","points":["Relationships can be discovered from code and runtime events","Graph expansion adds related context","Useful for multi-agent coordination and architecture work"],"visual":{"label":"object graph","code":"Component -> uses -> API\nAgent -> owns -> Task\nPrompt -> caused -> Failure\nFile -> implements -> Feature\n"}},{"label":"Signals","title":"Active and reactive signal memory","body":"Memory can keep working after the chat turn ends. Background processors, hooks, schedules, task events, action events, and plugin events can update memory continuously.","points":["Runs from event triggers, not only user prompts","Can consolidate and update derived memories","Fits monitoring and long-term autonomous agents"],"visual":{"label":"reactive memory","code":"onTaskFailure -> store pattern\nonAction     -> update object\nonSchedule   -> consolidate\nonWebhook    -> ingest event\n"}},{"label":"Injection","title":"Rule-based context injection","body":"The memory structure is only half the system. Context Assembly decides which memory should enter a given agent run, where it should be placed, and how much budget it gets.","points":["Rules evaluate scope variables and custom variables","Budgets prevent memory from flooding the prompt","Traces explain why memory was included"],"visual":{"label":"context injection","code":"if task_type = refactor\nand phase = debugging\ninclude:\n  - past_failures\n  - related_files\n  - review_notes\n"}}]}
  />
  <FeatureBlock
    kicker="02 · SCALABLE + INJECTABLE"
    heading="Memory can grow without flooding every agent"
    body="Scalable memory creates a second problem: the more the system learns, the less any single agent can read. Codebolt solves that through Context Assembly. Memory can grow in the background, but each agent receives only the slice selected by rules, retrieval pipelines, contribution logic, and token budgets."
    reverse={true}
    diagram={`memory keeps growing:
├─ conversations
├─ code facts
├─ object graph
├─ positive patterns
├─ negative patterns
└─ unfinished tasks

CAE decides:
├─ which memory applies
├─ which retrieval pipeline to run
├─ where context is placed
└─ how much budget it receives

agent gets focused context,
not the whole database
`}
  />
  <CtaBlock
    heading="Give agents memory they can scale, reshape, and inject."
    buttons={[{"label":"Explore Architecture","href":"/architecture","variant":"primary"},{"label":"Back to Features","href":"/engine","variant":"secondary"}]}
  />
</BaseLayout>
