---
// Auto-generated from site content. Edit source content and regenerate.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, navigation } from '../../data/site-data.js';
import ProductHero from '../../components/ProductHero.astro';
import CenteredText from '../../components/CenteredText.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import CtaBlock from '../../components/CtaBlock.astro';
---
<BaseLayout title="Codebolt Cloud — Agent Control Plane" navbarVariant="solid" site={site} navigation={navigation}>
  <ProductHero
    eyebrow="CODEBOLT CLOUD"
    title="The cloud control plane for agent work"
    subtitle="Run agents in managed or bring-your-own sandboxes, connect local Codebolt instances, schedule goals, monitor usage, and manage marketplace registries from one portal."
    buttons={[{"label":"Open Cloud","href":"https://cloud.codebolt.ai","variant":"primary"},{"label":"Explore Sandboxes","href":"https://docs.codebolt.ai/docs/04_build-on-codebolt/08a_multi-environment-orchestration/01_overview","variant":"secondary"}]}
    media={{"label":"Codebolt Cloud Portal","src":"/images/cloud.png","placeholder":"Cloud product GIF / portal screenshot","alt":"Codebolt Cloud portal for agents, sandboxes, automations, usage, and registries"}}
  />
  <CenteredText
    variant="thesis"
    text="Codebolt Cloud lets you start in the browser, CLI, or desktop app and scale into managed or bring-your-own sandboxes. Run cloud agents, connect local Codebolt instances, schedule goals, monitor usage, and manage public or private plugin and template registries from one portal."
  />
  <BentoGrid
    kicker="CLOUD CAPABILITIES"
    heading="Run and manage agents across every environment"
    description="Cloud is not just a hosted editor. It is the shared control plane for launching, routing, supervising, and scaling Codebolt work."
    columns={3}
    gap="none"
    items={[{"title":"Bring your own sandboxes","tag":"Sandboxes","description":"Run cloud agents in managed or self-owned sandboxes such as <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/08a_multi-environment-orchestration/01_overview'>E2B, Daytona, Docker, worktrees, remote servers, or custom providers</a>. Start sandboxes from the portal UI, API calls, webhooks, or automations.","span":2,"image":{"src":"/images/cloud-sandboxes.svg","alt":"Cloud sandbox provider routing from portal API and automation into E2B Daytona Docker worktrees remote servers and custom providers"}},{"title":"Scale from CLI or Desktop","tag":"Handoff","description":"Start local in the <a href='/products/cli'>CLI</a> or <a href='/products/editor'>Editor</a>, then scale the same work into Cloud when you need longer runs, remote capacity, team visibility, or scheduled execution.","image":{"src":"/images/cloud-scale-handoff.svg","alt":"Local CLI and desktop work handed off to Codebolt Cloud for remote capacity and team visibility"}},{"title":"Connect local instances","tag":"Local + Cloud","description":"Use the cloud plugin to connect local Codebolt instances to Cloud, manage local sessions from the portal, and hand work off between local and cloud runtimes without losing context.","image":{"src":"/images/cloud-local-instances.svg","alt":"Cloud plugin connecting local and cloud Codebolt sessions to the portal"}},{"title":"Automations and goals","tag":"Always-on","description":"Define goals, scheduled runs, webhook triggers, and API-triggered jobs so agents can operate on a cadence instead of waiting for a human to open a prompt.","image":{"src":"/images/cloud-automations-goals.svg","alt":"Schedules webhooks and API jobs becoming Cloud agent goals"}},{"title":"Backend agents for native apps","tag":"App backend","description":"Use Cloud agents as scalable backend workers for Codebolt-native applications. Apps can invoke agents directly through the API and let Cloud handle routing, sandboxing, execution, and run state.","image":{"src":"/images/cloud-app-backend-card.svg","alt":"Codebolt-native app UI invoking Cloud API and scalable agent runs"}}]}
  />
  <FeatureBlock
    kicker="01 · SANDBOX AGENTS"
    heading="Start cloud agents in the sandbox you choose"
    body="Codebolt Cloud can launch agent work into provider-backed environments instead of forcing everything into one hosted runtime. Use Codebolt-managed sandboxes, connect your own E2B or Daytona accounts, route work to Docker or worktree environments, or build a custom provider for your infrastructure. The portal, API, and automations all talk to the same environment model."
    cta={{"label":"Read environment orchestration docs","href":"https://docs.codebolt.ai/docs/04_build-on-codebolt/08a_multi-environment-orchestration/01_overview"}}
    image="/images/cloud-sandbox-agents.svg"
    imageAlt="Codebolt Cloud launching agents into provider-backed sandbox environments"
  />
  <FeatureBlock
    kicker="02 · LOCAL HANDOFF"
    heading="Manage local Codebolt sessions from Cloud"
    body="Cloud can connect to local Codebolt instances through the cloud plugin. That gives you a shared portal for local sessions, cloud sessions, and handoffs between them. You can begin in the desktop app or CLI, promote a run to cloud infrastructure, or keep a local machine as an environment Cloud can coordinate."
    reverse={true}
    image="/images/cloud-local-handoff.svg"
    imageAlt="Codebolt Cloud portal managing desktop and CLI sessions through the cloud plugin"
  />
  <FeatureBlock
    kicker="03 · AUTOMATIONS"
    heading="Turn prompts into scheduled goals"
    body="Cloud agents do not have to start from a person typing in a chat box. Define recurring goals, cron-style schedules, webhook triggers, or API-triggered jobs. Agents can triage issues, run maintenance, generate reports, watch repos, check deployments, or execute business workflows on a schedule."
    image="/images/cloud-scheduled-goals.svg"
    imageAlt="Codebolt Cloud turning prompts into recurring goals schedules webhooks and API jobs"
  />
  <FeatureBlock
    kicker="04 · APP BACKENDS"
    heading="Use Cloud agents as the backend for Codebolt-native applications"
    body="Codebolt-native applications do not need to run every agent inside the user's local editor session. They can call the Cloud API, start the right agent in the right sandbox, stream status back to the application UI, and scale invocations independently from the frontend. The application owns the workflow; Codebolt Cloud supplies the agent runtime, provider routing, environment lifecycle, memory, logs, and execution state."
    reverse={true}
    cta={{"label":"Read custom agentic apps","href":"https://docs.codebolt.ai/docs/04_build-on-codebolt/04b_custom-agentic-applications/01_overview"}}
    image="/images/cloud-app-backends.svg"
    imageAlt="Codebolt-native application calling Cloud APIs to route providers start sandboxes run workflows stream events and persist state"
  />
  <FeatureBlock
    kicker="05 · OPERATIONS"
    heading="Track usage, cost, and runtime activity"
    body="When agents run across local machines, cloud sandboxes, API jobs, and scheduled automations, visibility matters. Codebolt Cloud gives teams a central place to track run history, usage, costs, token consumption, environment activity, and operational status across the whole agent fleet."
    image="/images/cloud-operations.svg"
    imageAlt="Codebolt Cloud operations dashboard tracking runs costs runtime activity failures retries teams and projects"
  />
  <FeatureBlock
    kicker="06 · REGISTRY"
    heading="Manage public and private marketplaces"
    body="Cloud also acts as the registry layer for your agent ecosystem. Publish and install agents, plugins, MCP servers, templates, and reusable packages. Keep some public, keep internal ones private, mirror approved marketplace entries, and give teams a controlled catalog instead of unmanaged scripts."
    cta={{"label":"Read marketplace docs","href":"https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/04_the-marketplace"}}
    image="/images/cloud-registry.svg"
    imageAlt="Codebolt Cloud registry managing public marketplace private registries agents plugins MCP servers templates and approved packages"
  />
  <CtaBlock
    heading="Start local. Scale through Cloud when the work grows."
    buttons={[{"label":"Get Started","href":"/pricing","variant":"primary"},{"label":"Explore the Engine","href":"/engine","variant":"secondary"}]}
  />
</BaseLayout>
