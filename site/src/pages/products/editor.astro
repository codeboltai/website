---
// Auto-generated from site content. Edit source content and regenerate.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, navigation } from '../../data/site-data.js';
import ProductHero from '../../components/ProductHero.astro';
import CenteredText from '../../components/CenteredText.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import CtaBlock from '../../components/CtaBlock.astro';
---
<BaseLayout title="Codebolt Editor — Desktop Agent Environment" navbarVariant="solid" site={site} navigation={navigation}>
  <ProductHero
    eyebrow="CODEBOLT EDITOR"
    title="The desktop command center for agent work"
    subtitle="A complete AI code editor, orchestration console, and runtime surface for Codebolt-native applications. Open projects, edit code, run terminals, talk to agents, inspect their work, manage plans, and launch runtime panels from one workspace."
    buttons={[{"label":"Download Editor","href":"/download","variant":"primary"},{"label":"Read Editor Docs","href":"https://docs.codebolt.ai/docs/02_using-codebolt/02_surfaces/02_desktop-app/01_workspace-and-projects","variant":"secondary"}]}
    media={{"label":"Codebolt Editor Demo","src":"/images/desktop.png","placeholder":"Editor product screenshot","alt":"Codebolt Editor desktop agent workspace"}}
  />
  <CenteredText
    variant="thesis"
    text="Codebolt Editor is the desktop command center for the engine. Open projects, edit code, run terminals, talk to agents, inspect their work, manage plans, coordinate environments, install plugins, and launch application interfaces that run directly on the Codebolt runtime."
  />
  <BentoGrid
    kicker="EDITOR CAPABILITIES"
    heading="A full editor built around agent work"
    description="The editor is not only chat next to files. It is a complete workspace where code, context, agents, planning artifacts, runtime panels, and observability live together."
    columns={3}
    gap="none"
    items={[{"title":"Project workspace","tag":"Workspace","description":"Open <a href='https://docs.codebolt.ai/docs/02_using-codebolt/02_surfaces/02_desktop-app/01_workspace-and-projects'>workspaces</a> with file tree, editor state, chat threads, project-local config, checkpoints, indexes, codemap, and memory. Tune the <a href='https://docs.codebolt.ai/docs/02_using-codebolt/02_surfaces/02_desktop-app/02_panels-and-layout'>panel layout</a> and <a href='https://docs.codebolt.ai/docs/02_using-codebolt/02_surfaces/02_desktop-app/03_settings-and-profiles'>settings profiles</a> per project.","span":2,"image":{"src":"/images/editor-project-workspace.svg","alt":"Codebolt Editor project workspace with file tree, code, chat, and memory panels"}},{"title":"AI coding surface","tag":"Editor","description":"Code editing, terminals, file explorer, project context, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/03_chat/01_overview'>chat</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/03_chat/04_checkpoints-and-rollback'>checkpoints and rollback</a>, and <a href='https://docs.codebolt.ai/docs/02_using-codebolt/03_chat/06_model-selection'>model selection</a> in one desktop surface.","image":{"src":"/images/editor-coding-surface.svg","alt":"AI coding surface with editor, terminal, model selector, and checkpoint controls"}},{"title":"Agent workspace","tag":"Agents","description":"<a href='https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/03_running-agents'>Run agents</a> from the project, including <a href='https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/02_built-in-agents'>built-in agents</a>, remixes, custom agents, third-party agents, and remote agents. Use <a href='https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/06_agent-portfolios'>agent portfolios</a> and the <a href='https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/08_thread-panel'>thread panel</a> to manage work.","image":{"src":"/images/editor-agent-workspace.svg","alt":"Agent workspace with built-in agents, remixes, custom agents, and remote agents"}},{"title":"Debug and observability","tag":"Observe","description":"Inspect <a href='https://docs.codebolt.ai/docs/02_using-codebolt/05c_agent-observability/02_agent-debug'>agent logs</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/05c_agent-observability/03_ai-debug-and-console'>LLM calls, token budgets, and console output</a>, plus <a href='https://docs.codebolt.ai/docs/02_using-codebolt/09b_code-observability/03_narrative-graph'>narrative graphs</a> and run history without leaving the workspace.","image":{"src":"/images/editor-observability.svg","alt":"Debug and observability panels showing agent logs, LLM calls, token budgets, and narrative graphs"}},{"title":"Planning tools","tag":"Plan","description":"<a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/02_roadmap'>Roadmaps</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/03_specs'>specs</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/04_ui-flow'>UI flows</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/05_requirement-plan'>requirement plans</a>, <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/06_action-plan'>action plans</a>, and <a href='https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/07_tasks'>tasks</a> live beside the code so humans and agents share the same source of truth.","image":{"src":"/images/editor-planning-tools.svg","alt":"Planning tools for roadmaps, specs, UI flows, requirement plans, action plans, and tasks"}},{"title":"Runtime UI panels","tag":"Apps","description":"Agents and plugins can open <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/04_custom-uis/05_dynamic-panels'>dynamic panels</a>, stream data into them, and receive user actions back. Build a <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/04_custom-uis/07_build-your-first-dynamic-panel'>first panel</a>, package <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/05_plugins/05_dynamic-panel-plugins'>plugin-backed panels</a>, or create <a href='https://docs.codebolt.ai/docs/04_build-on-codebolt/04b_custom-agentic-applications/01_overview'>custom agentic apps</a>.","image":{"src":"/images/editor-runtime-panels.svg","alt":"Runtime UI panels opened by agents and plugins inside the editor"}}]}
  />
  <FeatureBlock
    kicker="01 · ORCHESTRATION HUB"
    heading="The control room for multi-environment agent work"
    body="Codebolt Editor sits on top of the same server runtime used by CLI, cloud, and headless deployments. The editor becomes the human-facing control plane for agent runs that may execute locally, in Docker, in cloud sandboxes, on remote servers, or across provider-backed environments. You can monitor the run, inspect artifacts, review changes, and keep coordination state in one place."
    cta={{"label":"Read multi-environment docs","href":"https://docs.codebolt.ai/docs/04_build-on-codebolt/08a_multi-environment-orchestration/01_overview"}}
    image="/images/editor-orchestration-hub.svg"
    imageAlt="Codebolt Editor orchestration hub connected to local, Docker, cloud, remote, and fleet environments"
  />
  <FeatureBlock
    kicker="02 · EXTENSIBLE EDITOR"
    heading="Agents and plugins can extend the interface at runtime"
    body="The editor is an application host. Plugins can add panels, commands, provider integrations, and backend behavior. Agents can open dynamic panels for reviews, dashboards, forms, status views, approvals, or domain-specific workflows. The UI is not fixed to a single sidebar or chat panel; it can change with the task."
    cta={{"label":"Explore dynamic panels","href":"https://docs.codebolt.ai/docs/04_build-on-codebolt/04_custom-uis/05_dynamic-panels"}}
    reverse={true}
    image="/images/editor-extensible-interface.svg"
    imageAlt="Extensible editor interface with plugin backend, commands, providers, hooks, and dynamic panels"
  />
  <FeatureBlock
    kicker="03 · CODEBOLT-NATIVE APPS"
    heading="Run full application experiences on the engine"
    body="The biggest shift is that Codebolt Editor is not only where you write applications. It is also where Codebolt-native applications can run. A plugin can act as the backend, a dynamic panel can act as the frontend, and the Codebolt engine provides agents, tools, memory, events, project state, and execution. This is closer to cloud-native applications than a normal extension model: the app is designed around the runtime, not just hosted beside it."
    cta={{"label":"Read custom agentic apps","href":"https://docs.codebolt.ai/docs/04_build-on-codebolt/04b_custom-agentic-applications/01_overview"}}
    image="/images/editor-native-apps.svg"
    imageAlt="Codebolt-native application running with dynamic panel frontend, plugin backend, agents, tools, memory, and project state"
  />
  <BentoGrid
    kicker="DEVELOPMENT LIFECYCLE"
    heading="Manage the full software lifecycle in one workspace"
    description="Codebolt Editor connects planning, implementation, agent management, evaluation, optimization, and delivery instead of scattering them across disconnected tools."
    columns={3}
    gap="none"
    items={[{"title":"Plan the work","tag":"Roadmap","description":"Capture product phases, features, specs, UI flows, and requirement plans as project files that agents can read before acting.","href":"https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/01_overview","image":{"src":"/images/editor-lifecycle-plan.svg","alt":"Roadmap planning artifacts available inside Codebolt Editor"}},{"title":"Break it into execution","tag":"Action Plan","description":"Create structured action plans with tasks, dependencies, parallel groups, and progress that agents can update while they work.","href":"https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/06_action-plan","image":{"src":"/images/editor-lifecycle-action-plan.svg","alt":"Action plan with tasks, dependencies, parallel groups, and progress"}},{"title":"Track tasks on Kanban","tag":"Tasks","description":"Manage standalone tasks, subtasks, statuses, and kanban columns alongside the codebase and agent message history.","href":"https://docs.codebolt.ai/docs/02_using-codebolt/06_planning/07_tasks","image":{"src":"/images/editor-lifecycle-kanban.svg","alt":"Kanban board for tasks, statuses, and agent message history"}},{"title":"Develop with agents","tag":"Build","description":"Run coding agents against the project context, inspect file edits, review checkpoints, and keep human control over the work.","href":"https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/03_running-agents","image":{"src":"/images/editor-lifecycle-build.svg","alt":"Coding agent run with project context, file edits, checkpoints, and review controls"}},{"title":"Manage agent portfolios","tag":"Agents","description":"Use built-in agents, remixes, custom agents, remote agents, and specialized teams without leaving the editor surface.","href":"https://docs.codebolt.ai/docs/02_using-codebolt/04_agents/06_agent-portfolios","image":{"src":"/images/editor-lifecycle-portfolios.svg","alt":"Agent portfolio with built-in agents, remixes, custom agents, remote agents, and specialized teams"}},{"title":"Evaluate and optimize","tag":"Quality","description":"Define eval tasks, score outputs, compare runs, and run optimization loops that improve agents over iterations.","href":"https://docs.codebolt.ai/docs/02_using-codebolt/05e_eval-and-optimization/01_overview","image":{"src":"/images/editor-lifecycle-quality.svg","alt":"Evaluation and optimization loop comparing agent runs and scores"}},{"title":"Observe every run","tag":"Trace","description":"Use debug panels, AI call inspection, console streams, and narrative graphs to see why an agent made each decision.","href":"https://docs.codebolt.ai/docs/02_using-codebolt/05c_agent-observability/01_overview","span":2,"image":{"src":"/images/editor-lifecycle-trace.svg","alt":"Trace view connecting roadmap, specs, action plans, tasks, logs, evals, and optimization"}},{"title":"Ship through the same runtime","tag":"Runtime","description":"Move from editor work to CLI, cloud, remote environments, or Codebolt-native application surfaces without changing the underlying engine.","href":"/engine","image":{"src":"/images/editor-lifecycle-runtime.svg","alt":"Editor work shipping through the same runtime to CLI, cloud, remote, and app surfaces"}}]}
  />
  <CtaBlock
    heading="A desktop editor, orchestration console, and application runtime in one."
    buttons={[{"label":"Download","href":"/download","variant":"primary"},{"label":"Explore the Engine","href":"/engine","variant":"secondary"}]}
  />
</BaseLayout>
