---
// Auto-generated from site content. Edit source content and regenerate.
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, navigation } from '../data/site-data.js';
import PageHeader from '../components/PageHeader.astro';
import CenteredText from '../components/CenteredText.astro';
import EngineArchitectureDiagram from '../components/EngineArchitectureDiagram.astro';
import DiagramSection from '../components/DiagramSection.astro';
import CardGrid from '../components/CardGrid.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ThreeColumnGrid from '../components/ThreeColumnGrid.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import Accordion from '../components/Accordion.astro';
import CtaBlock from '../components/CtaBlock.astro';
---
<BaseLayout title="The Engine — Codebolt" navbarVariant="solid" site={site} navigation={navigation}>
  <PageHeader
    title="The Codebolt Engine"
    subtitle="An advanced agent execution engine. As simple as a coding CLI. As powerful as autonomous company infrastructure."
  />
  <CenteredText
    variant="thesis"
    text="Codebolt is not an agent — it's the engine that runs agents. Not a framework — it's the execution environment where agents, plugins, and applications operate. Every other tool is one thing. Codebolt is the engine that becomes what you need."
  />
  <EngineArchitectureDiagram
    kicker="TOPOLOGY"
    heading="Engine + Channels + Interfaces"
    description="Agents connect through the Agent SDK. Plugins extend through the Plugin SDK. Interfaces connect through the Client SDK. All three channels meet at the engine core."
  />
  <DiagramSection
    heading="Engine Architecture"
    layers={[{"label":"Interface Layer — IDE, TUI, CLI, Web","tag":"surface","style":"surface"},{"label":"Communication Layer — Agent SDK, Plugin SDK, Client SDK","tag":"runtime","style":"runtime"},{"label":"Coordination Layer — Stigmergy, Deliberation, Pheromones","tag":"coordination","style":"drift"},{"label":"Intelligence Layer — Drift Engine, Narrative Versioning (Rust)","tag":"intelligence","style":"versioning"},{"label":"Infrastructure Layer — Governance, Environments, Providers","tag":"core","style":"governance"}]}
    annotation="Other tools operate at Layer 1-2. Agent frameworks at Layer 2. Codebolt is all five layers — a complete engine."
  />
  <CardGrid
    heading="Four Pillars of the Engine"
    columns={2}
    cards={[{"title":"System Extensibility","body":"Extend the engine itself. Write custom agents with the 63-module SDK. Build plugins with 3 communication channels. Create custom clients with 72 REST APIs + 33 WebSocket modules. The system is open at every layer.","href":"/engine/system-extensibility"},{"title":"Agent Extensibility","body":"Make any agent more powerful. Remix agents inherit and customize without code. Add skills from 675+ tools. Flow-based visual composition. Role-specific LLM configs. Capability declarations. Every agent is extensible.","href":"/engine/agent-extensibility"},{"title":"Multi-Agent Scaling","body":"Within a single environment, agents spawn sub-agents, run parallel child threads, coordinate via stigmergy and pheromones, hold deliberation councils, and review each other's work. From 1 to 100+ agents.","href":"/engine/multi-agent"},{"title":"Multi-Environment Scaling","body":"Across machines: proxy execution chains environments together. Env A calls Env B calls Env C. Providers bridge via WebSocket. Git bundles transfer state. Heartbeat monitoring. Hierarchical or peer-to-peer.","href":"/engine/multi-environment"}]}
  />
  <SectionHeader
    kicker="SYSTEM EXTENSIBILITY"
    kickerDot="primary"
    title={`Open at every layer
Agents, Plugins, Clients — all extensible
`}
    description="Three SDKs. Three extension points. Complete control over the engine."
  />
  <ThreeColumnGrid
    divider={true}
    columnsHtml={["<div class=\"p-8 md:p-12\">\n  <div class=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-4\">AGENT SDK</div>\n  <h3 class=\"text-xl font-medium text-foreground mb-3 tracking-tight\">Custom Agents</h3>\n  <p class=\"text-sm text-muted-foreground leading-relaxed\">Write agents in JavaScript with 63+ SDK modules — filesystem, git, browser, terminal, LLM, vector DB, memory, knowledge graphs. Full control over the agentic loop.</p>\n</div>\n","<div class=\"p-8 md:p-12\">\n  <div class=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-4\">PLUGIN SDK</div>\n  <h3 class=\"text-xl font-medium text-foreground mb-3 tracking-tight\">Custom Plugins</h3>\n  <p class=\"text-sm text-muted-foreground leading-relaxed\">Three communication channels — WebSocket actions, multiplexed events, HTTP REST. Plugins run inside the engine. No separate agent instance needed.</p>\n</div>\n","<div class=\"p-8 md:p-12\">\n  <div class=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-4\">CLIENT SDK</div>\n  <h3 class=\"text-xl font-medium text-foreground mb-3 tracking-tight\">Custom Clients</h3>\n  <p class=\"text-sm text-muted-foreground leading-relaxed\">72 REST API modules + 33 WebSocket modules. Build dashboards, mobile apps, Slack bots, VS Code extensions — anything that talks to the engine.</p>\n</div>\n"]}
  />
  <SectionHeader
    kicker="AGENT EXTENSIBILITY"
    kickerDot="emerald"
    title={`Every agent is extensible
Remix, Skills, Flows, Capabilities
`}
    description="Multiple ways to make agents more powerful — from no-code to full code."
  />
  <FeatureBlock
    heading="Agent Types — From No-Code to Full Code"
    body="Remix Agents inherit from a base agent and add custom instructions in YAML+Markdown — no code required, git-friendly, composable. Flow Agents use a visual graph editor (LiteGraph) for drag-and-drop agent workflows. Custom Agents are pure code with full SDK access. Remote Agents run in external environments. All types share the same 675+ skill library."
    diagram={`Remix Agent (no-code):
---
baseAgent: code-gen
supportedlanguages: [python]
---
Custom instructions here...

Flow Agent (visual):
[Node A] → [Node B] → [Node C]

Custom Agent (full code):
codebolt.onMessage(async (msg) => {
  // your logic, your tools
});
`}
  />
  <FeatureBlock
    heading="675+ Skills Across 72 Domains"
    body="Agents access skills organized across 72 tool domains — file operations, git, browser control, terminal, LLM, vector database, agent control, memory, knowledge graphs, and more. Skills are scoped by environment capabilities — the engine prevents agents from calling unavailable tools. Add skills, declare capabilities, set per-agent model preferences."
    reverse={true}
    diagram={`72 tool domains:
├─ file (read, write, search, diff)
├─ git (commit, push, branch, merge)
├─ browser (navigate, click, screenshot)
├─ terminal (execute, stream, PTY)
├─ llm (chat, embed, count tokens)
├─ vectordb (store, query, search)
├─ agent (start, stop, list, spawn)
├─ memory (persist, retrieve, graph)
└─ ... 64 more domains
= 675+ individual tools
`}
  />
  <SectionHeader
    kicker="MULTI-AGENT SCALING"
    kickerDot="amber"
    title={`Multiple agents, one environment
Coordination, not collision
`}
    description="Sub-agents, parallel execution, stigmergy, deliberation, and review — all within a single Codebolt instance."
  />
  <FeatureBlock
    heading="Sub-Agent Spawning & Parallel Execution"
    body="An agent can spawn background child threads that run in parallel. Parent agents wait for individual completions, grouped completions, or any external event. Children are full agent instances with complete SDK access — not async tasks. Group multiple children and await batch completion. Message-driven communication between parent and children."
    diagram={`Parent Agent
  ├─ spawn → Child 1 (review)
  ├─ spawn → Child 2 (test)
  ├─ spawn → Child 3 (docs)
  │
  └─ waitForGroup('batch-1')
          ↓
  All children complete
  → Merge results
  → Continue
`}
  />
  <FeatureBlock
    heading="Stigmergy, Deliberation & Auto Review"
    body="Agents coordinate through shared state (stigmergy), not fragile message passing. Pheromone-based task ownership prevents conflicts. Deliberation councils let agents propose, debate, vote, and reach consensus. The review-merge system lets agents review each other's work and auto-merge without GitHub PR bottleneck. Drift tracking catches deviation across all agents."
    reverse={true}
    diagram={`Agent A: implements feature
Agent B: reviews (auto-assigned)
Agent C: checks for drift
      ↓
Deliberation if conflict
      ↓
Auto-merged. Traced. Auditable.
No human bottleneck.
`}
  />
  <SectionHeader
    kicker="MULTI-ENVIRONMENT SCALING"
    kickerDot="purple"
    title={`Chain environments together
Proxy execution across machines
`}
    description="One environment's agent can trigger work in another. Chain them. Scale them. Any topology."
  />
  <FeatureBlock
    heading="Proxy Execution — Environment Chaining"
    body="The RemoteExecutionPlugin bridges environments via WebSocket. Environment A's agent sends work to Environment B, which can forward to Environment C. Any topology — linear chains, trees, peer-to-peer. Each environment runs its own Codebolt instance with full capabilities. The proxy is plugin-based — not hardcoded — so any environment can claim the execution gateway."
    diagram={`Env A (laptop)
  │ proxy execution
  ↓
Env B (Docker GPU)
  │ proxy execution
  ↓
Env C (cloud cluster)

Or: Env A ↔ Env B ↔ Env C (peer)
Or: Env A → [Env B, Env C, Env D] (fan-out)
Any topology. Plugin-based routing.
`}
  />
  <FeatureBlock
    heading="State Transfer & Lifecycle"
    body="Git bundles transfer workspace state between environments. The Narrative Engine snapshots per-environment with per-thread git refs. Full lifecycle management — CREATED, STARTING, RUNNING, STOPPING, STOPPED — with heartbeat monitoring every 30 seconds. The provider system treats local, Docker, cloud, and hierarchical environments identically."
    reverse={true}
    diagram={`Environment Lifecycle:
CREATED → STARTING → RUNNING
                     ↕ heartbeat (30s)
STOPPING ← STOPPED ← ERROR

State Transfer:
Env A [snapshot] → git bundle
                → Env B [restore]
Bidirectional. Any topology.
`}
  />
  <Accordion
    heading="Engine Internals"
    items={[{"question":"Narrative Engine (Rust)","answer":"A Rust-based flight recorder capturing the full reasoning chain for every agent action. Shadow git for snapshot versioning. Per-thread commit history. Agent attribution for every change. Git bundle export for cross-environment transfer. Deterministic replay of any decision point. 12 snapshot operations including create, browse, merge, checkout, import/export."},{"question":"Drift Tracking — Two Levels","answer":"Local Rust engine instances assess drift within each agent context — structural, scope, constraint, and coverage drift. The global JavaScript coordination layer aggregates signals across all agents, detecting systemic drift that no single agent would catch. When agents deviate from intent, the system flags it before it compounds."},{"question":"Governance & Guardrails","answer":"The policy engine evaluates agent actions against configurable rules. Scoped by agent role, agent ID, environment, provider, and execution phase. LLM-based risk classification. Decisions: allow, deny, or escalate to human. Every decision logged for audit."},{"question":"Three-Tier Memory","answer":"Episodic memory for time-based recall. Persistent memory with chunking, embedding, and retrieval pipelines. The Context Assembly Engine assembles optimal context from all memory types using rules, pipelines, and token budgets. Agents know what to remember and when."},{"question":"HostBridge Abstraction","answer":"The engine never calls platform APIs directly. It defines a HostBridge interface for process spawning, SQLite, Kuzu graph DB, and ONNX inference. Each runtime implements its own bridge: Electron uses UtilityProcess, CLI uses child_process and better-sqlite3, TUI connects via WebSocket proxy. One codebase, every runtime."}]}
  />
  <CtaBlock
    heading="The engine that scales with your ambition."
    buttons={[{"label":"Get Started","href":"/pricing","variant":"primary"},{"label":"Explore the Engine","href":"/engine","variant":"secondary"}]}
  />
</BaseLayout>
